                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ParamLabelCol"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*" SharedSizeGroup="ParamValueCol"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Translate Key=Ui.Macro.StepEditor.DeltaX}" Style="{StaticResource ParamLabel}"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding DeltaX}" Style="{StaticResource ParamValue}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Translate Key=Ui.Macro.Steps.DeltaY}" Style="{StaticResource ParamLabel}"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding DeltaY}" Style="{StaticResource ParamValue}"/>
                </Grid>
            </Grid>
        </DataTemplate>

