                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Translate Key=Ui.Macro.StepEditor.Key}" Style="{StaticResource ParamLabel}"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Key}" Style="{StaticResource ParamValue}"/>
