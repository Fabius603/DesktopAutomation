<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:loc="clr-namespace:DesktopAutomationApp.Localization"
                    xmlns:jobs="clr-namespace:TaskAutomation.Jobs;assembly=TaskAutomation"
                    xmlns:conv="clr-namespace:DesktopAutomationApp.Converters">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Resources/Jobs/Templates/Shared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ShowTextStep -->
    <DataTemplate DataType="{x:Type jobs:ShowTextStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.Job.Steps.Text}"/><Run Text="{Binding Settings.Text}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.Job.Steps.Size}"/><Run Text="{Binding Settings.FontSize}"/>
                        <Run Text="{loc:Translate Key=Ui.Job.Steps.FontColor}"/><Run Text="{Binding Settings.FontColor}"/>
                        <Run Text="{loc:Translate Key=Ui.Job.Steps.Opacity}"/><Run Text="{Binding Settings.Opacity, StringFormat={}{0:P0}}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.Job.Steps.Monitor}"/><Run Text="{Binding Settings.DesktopIndex}"/>
                        <Run Text="{loc:Translate Key=Ui.Job.Steps.PositionOffset}"/><Run Text="{Binding Settings.OffsetX}"/>
                        <Run Text="{loc:Translate Key=Ui.Job.Steps.CommaSeparator}"/><Run Text="{Binding Settings.OffsetY}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>
</ResourceDictionary>
