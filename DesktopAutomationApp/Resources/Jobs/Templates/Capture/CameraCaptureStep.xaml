<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:loc="clr-namespace:DesktopAutomationApp.Localization"
                    xmlns:jobs="clr-namespace:TaskAutomation.Jobs;assembly=TaskAutomation">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Resources/Jobs/Templates/Shared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate DataType="{x:Type jobs:CameraCaptureStep}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}"
                       FontWeight="Bold"
                       VerticalAlignment="Top"/>
            <TextBlock Grid.Column="2" Style="{StaticResource ParamText}">
                <Run Text="{loc:Translate Key=Ui.Step.Camera.CameraWithColon}"/>
                <Run Text="{Binding Settings.CameraName}"/>
            </TextBlock>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
