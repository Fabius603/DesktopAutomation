<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:loc="clr-namespace:DesktopAutomationApp.Localization"
                    xmlns:jobs="clr-namespace:TaskAutomation.Jobs;assembly=TaskAutomation"
                    xmlns:conv="clr-namespace:DesktopAutomationApp.Converters">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Resources/Jobs/Templates/Shared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- EndJobStep -->
    <DataTemplate DataType="{x:Type jobs:EndJobStep}">
            <StackPanel>
                <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" Foreground="{DynamicResource App.Brush.Accent}"/>
                <TextBlock Style="{StaticResource ParamText}">
                    <Run Text="{loc:Translate Key=Ui.Job.Steps.SkipEndStepsLabel}"/><Run Text="{Binding Settings.SkipEndSteps, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                </TextBlock>
            </StackPanel>
        </DataTemplate>
</ResourceDictionary>
