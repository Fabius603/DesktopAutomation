<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:loc="clr-namespace:DesktopAutomationApp.Localization"
                    xmlns:jobs="clr-namespace:TaskAutomation.Jobs;assembly=TaskAutomation"
                    xmlns:conv="clr-namespace:DesktopAutomationApp.Converters">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Resources/Jobs/Templates/Shared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ElseIfStep -->
    <DataTemplate DataType="{x:Type jobs:ElseIfStep}">
            <StackPanel>
                <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" Foreground="{DynamicResource App.Brush.Accent}"/>
                <ItemsControl ItemsSource="{Binding Settings.Conditions}" Margin="0,4,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource ParamText}"
                                       TextWrapping="Wrap">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource StepConditionDisplayConverter}">
                                        <Binding Mode="OneWay"/>
                                        <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                        <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Style="{StaticResource ParamText}" Margin="0,3,0,0" FontStyle="Italic">
                    <Run Text="{loc:Translate Key=Ui.Job.Steps.OpenParenthesis}"/><Run Text="{Binding Settings.MatchMode, Mode=OneWay, Converter={StaticResource ConditionMatchModeConverter}}"/><Run Text="{loc:Translate Key=Ui.Job.Steps.CloseParenthesis}"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="{loc:Translate Key=Ui.Job.Steps.AddElseIf}"
                            Command="{Binding DataContext.AddElseIfCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource ButtonSecondary}"
                            Padding="8,4" Margin="0,0,6,0" FontSize="11"/>
                    <Button Content="{loc:Translate Key=Ui.Job.Steps.AddElse}"
                            Command="{Binding DataContext.AddElseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource ButtonSecondary}"
                            Padding="8,4" FontSize="11"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
</ResourceDictionary>
