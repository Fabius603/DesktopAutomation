<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" xmlns:jobs="clr-namespace:TaskAutomation.Jobs;assembly=TaskAutomation">
 <ResourceDictionary.MergedDictionaries><ResourceDictionary Source="/Resources/Jobs/Templates/Shared.xaml"/></ResourceDictionary.MergedDictionaries>
 <DataTemplate DataType="{x:Type jobs:TerminateProcessStep}">
  <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
   <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" VerticalAlignment="Top"/>
   <StackPanel Grid.Column="2">
    <TextBlock Style="{StaticResource ParamText}" Visibility="{Binding Settings.Target.ProcessSource.IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}"><Run Text="{loc:Translate Key=Ui.Job.Steps.ProcessSource}"/><Run><Run.Text><MultiBinding Converter="{StaticResource SourceStepNameConverter}"><Binding Path="Settings.Target.ProcessSource"/><Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/><Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/></MultiBinding></Run.Text></Run></TextBlock>
    <TextBlock Style="{StaticResource ParamText}" Visibility="{Binding Settings.Target.ProcessSource.IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}"><Run Text="{loc:Translate Key=Ui.Job.Steps.ProcessNameLabel}"/><Run Text="{Binding Settings.Target.ProcessName}"/></TextBlock>
    <TextBlock Style="{StaticResource ParamText}"><Run Text="{loc:Translate Key=Ui.Job.Steps.WindowTitle}"/><Run Text="{Binding Settings.Target.WindowTitleContains}"/></TextBlock>
   </StackPanel>
  </Grid>
 </DataTemplate>
</ResourceDictionary>
