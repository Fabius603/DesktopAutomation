<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:loc="clr-namespace:DesktopAutomationApp.Localization"
                    xmlns:jobs="clr-namespace:TaskAutomation.Jobs;assembly=TaskAutomation"
                    xmlns:conv="clr-namespace:DesktopAutomationApp.Converters">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Resources/Jobs/Templates/Shared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- FocusProcessStep -->
    <DataTemplate DataType="{x:Type jobs:FocusProcessStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}"
                               Visibility="{Binding Settings.Target.ProcessSource.IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Run Text="{loc:Translate Key=Ui.Job.Steps.ProcessSource}"/>
                        <Run><Run.Text><MultiBinding Converter="{StaticResource SourceStepNameConverter}">
                            <Binding Path="Settings.Target.ProcessSource"/>
                            <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                            <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                        </MultiBinding></Run.Text></Run>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.Job.Steps.Action}"/><Run Text="{Binding Settings.Action, Converter={StaticResource LocalizedEnumConverter}}"/>
                    </TextBlock>
                    <StackPanel Visibility="{Binding Settings.Target.ProcessSource.IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <TextBlock Style="{StaticResource ParamText}">
                            <Run Text="{loc:Translate Key=Ui.Job.Steps.Program}"/><Run Text="{Binding Settings.Target.ExecutablePath}"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.Job.Steps.WindowTitle}"/><Run Text="{Binding Settings.Target.WindowTitleContains}"/>
                    </TextBlock>
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ParamText}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Settings.Action}" Value="{x:Static jobs:FocusProcessAction.BringToFront}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{loc:Translate Key=Ui.Job.Steps.WindowMode}"/><Run Text="{Binding Settings.WindowMode}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>
</ResourceDictionary>
