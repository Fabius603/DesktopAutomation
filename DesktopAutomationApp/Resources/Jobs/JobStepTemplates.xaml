                        <Run Text="{loc:Translate Key=Ui.Job.Steps.ROIXYWidthHeight}"/>
                        <Run Text="{Binding Settings.ROI, Converter={StaticResource RectToStringConverter}}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

