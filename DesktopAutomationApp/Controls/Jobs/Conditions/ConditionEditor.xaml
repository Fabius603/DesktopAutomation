<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Conditions.ConditionEditor"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:jobs="clr-namespace:DesktopAutomationApp.Controls.Jobs"
             xmlns:conv="clr-namespace:DesktopAutomationApp.Converters"
             xmlns:loc="clr-namespace:DesktopAutomationApp.Localization">
    <UserControl.Resources>
        <conv:OneBasedIndexConverter x:Key="OneBasedIndexConverter"/>
        <Style x:Key="ConditionFieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextMuted}"/>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <Border Background="{DynamicResource App.Brush.SurfaceHover}"
                BorderBrush="{DynamicResource App.Brush.CardBorder}"
                BorderThickness="1" CornerRadius="7" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Evaluation}"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <RadioButton Content="{loc:Translate Key=Ui.Step.Settings.AllAND}"
                                 IsChecked="{Binding IsAll, ElementName=Root}"
                                 VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <RadioButton Content="{loc:Translate Key=Ui.Step.Settings.OneOR}"
                                 IsChecked="{Binding IsAny, ElementName=Root}"
                                 VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <ItemsControl ItemsSource="{Binding Conditions, ElementName=Root}" AlternationCount="1000">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <Border HorizontalAlignment="Left"
                                Background="{DynamicResource App.Brush.AccentSubtle}"
                                CornerRadius="9" Padding="9,2" Margin="14,0,0,5">
                            <TextBlock FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource App.Brush.Accent}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{loc:Translate Key=Ui.Step.IfEditor.AndConnector}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAny, ElementName=Root}" Value="True">
                                                <Setter Property="Text" Value="{loc:Translate Key=Ui.Step.IfEditor.OrConnector}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <Border Background="{DynamicResource App.Brush.Surface}"
                                BorderBrush="{DynamicResource App.Brush.CardBorder}"
                                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="25" Height="25" CornerRadius="13"
                                                Background="{DynamicResource App.Brush.AccentSubtle}" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource OneBasedIndexConverter}}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource App.Brush.Accent}"
                                                       FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Text="{loc:Translate Key=Ui.Step.IfEditor.Condition}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Style="{StaticResource ButtonIconDanger}"
                                            Command="{Binding RemoveCommand}"
                                            IsEnabled="{Binding CanRemove}"
                                            ToolTip="{loc:Translate Key=Ui.Step.Settings.RemoveCondition}">
                                        <TextBlock Text="{loc:Translate Key=Ui.Common.RemoveSymbol}"
                                                   FontSize="22" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>

                                <!-- Step/property, operator and value deliberately form one vertical flow. -->
                                <StackPanel>
                                    <TextBlock Text="{loc:Translate Key=Ui.Step.IfEditor.ResultPath}"
                                               Style="{StaticResource ConditionFieldLabel}"/>
                                    <jobs:ResultPathPicker ItemsSource="{Binding SelectionTree}"
                                                           DisplayText="{Binding SelectedPath}"/>

                                    <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Operator}"
                                               Style="{StaticResource ConditionFieldLabel}" Margin="0,12,0,4"/>
                                    <ComboBox ItemsSource="{Binding AvailableOperators}"
                                              SelectedItem="{Binding SelectedOperator}"
                                              Height="36">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource ConditionOperatorConverter}}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <StackPanel Margin="0,12,0,0"
                                                Visibility="{Binding ShowComparisonValue, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Value}"
                                                   Style="{StaticResource ConditionFieldLabel}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <RadioButton Content="{loc:Translate Key=Ui.Step.IfEditor.LiteralValue}"
                                                         IsChecked="{Binding ComparisonIsLiteral}"
                                                         Margin="0,0,18,0"/>
                                            <RadioButton Content="{loc:Translate Key=Ui.Step.IfEditor.JobResultValue}"
                                                         IsChecked="{Binding ComparisonIsJobResult}"/>
                                        </StackPanel>
                                        <Border Height="38" BorderThickness="1" CornerRadius="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsComparisonValueValid}" Value="False">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Danger}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <mah:NumericUpDown Value="{Binding ComparisonNumber, UpdateSourceTrigger=PropertyChanged}"
                                                                   Minimum="-1000000000" Maximum="1000000000"
                                                                   mah:TextBoxHelper.Watermark="{Binding InputExample}"
                                                                   Visibility="{Binding ShowNumericValue, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <TextBox Text="{Binding ComparisonValue, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="{Binding InputHint}"
                                                         mah:TextBoxHelper.Watermark="{Binding InputExample}"
                                                         VerticalContentAlignment="Center"
                                                         Visibility="{Binding ShowTextValue, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <mah:DateTimePicker SelectedDateTime="{Binding ComparisonDate, UpdateSourceTrigger=PropertyChanged}"
                                                                    Culture="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=CurrentCulture}"
                                                                    SelectedDateFormat="Short"
                                                                    SelectedTimeFormat="Long"
                                                                    mah:TextBoxHelper.Watermark="{Binding InputExample}"
                                                                    Visibility="{Binding ShowDateValue, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <ComboBox ItemsSource="{Binding BooleanValues}"
                                                          SelectedItem="{Binding ComparisonBoolean, UpdateSourceTrigger=PropertyChanged}"
                                                          Height="36"
                                                          VerticalContentAlignment="Center"
                                                          Visibility="{Binding ShowBooleanValue, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <jobs:ResultPathPicker ItemsSource="{Binding ComparisonSelectionTree}"
                                                                       DisplayText="{Binding ComparisonPath}"
                                                                       Visibility="{Binding ShowJobResultComparisonValue, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock Text="{Binding ComparisonValueValidationError}"
                                                   FontSize="11" Margin="0,4,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource App.Brush.Danger}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsComparisonValueValid}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Command="{Binding AddCommand, ElementName=Root}"
                HorizontalAlignment="Stretch" Style="{StaticResource ButtonSecondary}"
                Padding="10,8" Margin="0,2,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" Margin="0,0,6,0"/>
                <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.AddCondition}"/>
            </StackPanel>
        </Button>
    </StackPanel>
</UserControl>
