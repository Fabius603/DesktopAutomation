<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.ResultPathPicker"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <UserControl.Resources>
        <Style x:Key="PickerToggleStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="9,0"/>
            <Setter Property="Background" Value="{DynamicResource App.Brush.WindowBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource App.Brush.SurfaceHover}"/>
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource App.Brush.SurfaceHover}"/>
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/>
                                <Setter TargetName="ToggleBorder" Property="CornerRadius" Value="5,5,0,0"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PickerTreeItemStyle" TargetType="TreeViewItem"
               BasedOn="{StaticResource {x:Type TreeViewItem}}">
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>

        <Style x:Key="PickerTreeRowStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RowBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource App.Brush.AccentSubtle}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource App.Brush.SurfaceHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ToggleButton x:Name="DropDownToggle"
                      Style="{StaticResource PickerToggleStyle}"
                      IsChecked="{Binding IsOpen, ElementName=SelectionPopup, Mode=TwoWay}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <iconPacks:PackIconMaterial Kind="SourceBranch"
                                            Width="14" Height="14" Margin="0,0,8,0"
                                            Foreground="{DynamicResource App.Brush.Accent}"
                                            VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding DisplayText, ElementName=Root}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="2" Margin="8,0,0,0" Padding="5,1"
                        Background="{DynamicResource App.Brush.Surface}"
                        CornerRadius="3">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SecondaryText, ElementName=Root}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SecondaryText, ElementName=Root}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding SecondaryText, ElementName=Root}"
                               FontSize="9" Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                </Border>
                <iconPacks:PackIconMaterial Grid.Column="3"
                                            Width="14" Height="14" Margin="8,0,0,0"
                                            Foreground="{DynamicResource App.Brush.TextMuted}"
                                            VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial.Style>
                        <Style TargetType="iconPacks:PackIconMaterial">
                            <Setter Property="Kind" Value="ChevronDown"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOpen, ElementName=SelectionPopup}" Value="True">
                                    <Setter Property="Kind" Value="ChevronUp"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </iconPacks:PackIconMaterial.Style>
                </iconPacks:PackIconMaterial>
            </Grid>
        </ToggleButton>

        <Popup x:Name="SelectionPopup"
               PlacementTarget="{Binding ElementName=DropDownToggle}"
               Placement="Bottom"
               VerticalOffset="-1"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Width="{Binding ActualWidth, ElementName=DropDownToggle}"
                    MinWidth="260" MaxHeight="320"
                    Padding="5"
                    Background="{DynamicResource App.Brush.Surface}"
                    BorderBrush="{DynamicResource App.Brush.Accent}"
                    BorderThickness="1"
                    CornerRadius="0,0,7,7">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.28" Color="Black"/>
                </Border.Effect>
                <TreeView ItemsSource="{Binding ItemsSource, ElementName=Root}"
                          ItemContainerStyle="{StaticResource PickerTreeItemStyle}"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="0"
                          MaxHeight="306"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <Button Style="{StaticResource PickerTreeRowStyle}"
                                    Command="{Binding SelectCommand}"
                                    Click="TreeNode_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Margin="12,0,0,0" Padding="6,2"
                                            Background="{DynamicResource App.Brush.WindowBackground}"
                                            CornerRadius="3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SecondaryText}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding SecondaryText}"
                                                   FontSize="9"
                                                   Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                                    </Border>
                                </Grid>
                            </Button>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>
        </Popup>
    </Grid>
</UserControl>
