<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Capture.CameraCaptureStepEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:DesktopAutomationApp.Localization">
    <StackPanel>
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{loc:Translate Key=Ui.Step.Camera.Camera}"
                       Style="{StaticResource StepFieldLabel}"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding AvailableCameras}"
                      SelectedItem="{Binding CameraCaptureStep_SelectedCamera}"
                      DisplayMemberPath="Name"
                      MinWidth="220"/>
            <Button Grid.Column="2"
                    Command="{Binding RefreshCamerasCommand}"
                    Content="{loc:Translate Key=Ui.Step.Camera.Refresh}"
                    Margin="8,0,0,0"/>
        </Grid>
        <TextBlock Text="{Binding CameraLoadStatus}"
                   Foreground="{DynamicResource App.Brush.TextMuted}"
                   TextWrapping="Wrap"
                   Margin="140,2,0,0"/>
    </StackPanel>
</UserControl>
