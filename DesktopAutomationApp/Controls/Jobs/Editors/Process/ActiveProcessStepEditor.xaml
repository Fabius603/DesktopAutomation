<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Process.ActiveProcessStepEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" xmlns:jobs="clr-namespace:DesktopAutomationApp.Controls.Jobs">
 <StackPanel Visibility="{Binding ShowActiveProcess, Converter={StaticResource BooleanToVisibilityConverter}}"><jobs:ProcessTargetModeSelector Picker="{Binding ActiveProcessStep_ProcessSource}" UseProcessReference="{Binding ActiveProcessStep_UsesProcessSource}"/><Grid Style="{StaticResource StepFieldGrid}" Visibility="{Binding ActiveProcessStep_UsesProcessSource, Converter={StaticResource InverseBooleanToVisibilityConverter}}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Common.ProcessName}" Style="{StaticResource StepFieldLabel}"/><ComboBox Grid.Column="1" IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True" ItemsSource="{Binding AvailableProcessNames}" Text="{Binding ActiveProcessStep_ProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Step.Settings.ProcessNamePlaceholder}"/></Grid><TextBlock Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="11" TextWrapping="Wrap" Text="{loc:Translate Key=Ui.Step.Settings.ProcessResultHint}"/></StackPanel>
</UserControl>
