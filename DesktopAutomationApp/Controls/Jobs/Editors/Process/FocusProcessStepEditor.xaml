<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Process.FocusProcessStepEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" xmlns:jobs="clr-namespace:DesktopAutomationApp.Controls.Jobs">
 <StackPanel Visibility="{Binding ShowFocusProcess, Converter={StaticResource BooleanToVisibilityConverter}}">
  <jobs:ProcessTargetModeSelector Picker="{Binding FocusProcessStep_ProcessSource}" UseProcessReference="{Binding FocusProcessStep_UsesProcessSource}"/>
  <Grid Style="{StaticResource StepFieldGrid}" Visibility="{Binding FocusProcessStep_UsesProcessSource, Converter={StaticResource InverseBooleanToVisibilityConverter}}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.PathProgram}" Style="{StaticResource StepFieldLabel}"/><ComboBox Grid.Column="1" IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True" ItemsSource="{Binding AvailableExecutablePrograms}" TextSearch.TextPath="Command" Text="{Binding FocusProcessStep_ExecutablePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Step.Settings.PathToExeOrProgramName}"><ComboBox.ItemTemplate><DataTemplate><StackPanel><TextBlock Text="{Binding DisplayName}"/><TextBlock Text="{Binding Command}" FontSize="10" Foreground="{DynamicResource App.Brush.TextMuted}"/></StackPanel></DataTemplate></ComboBox.ItemTemplate></ComboBox><Button Grid.Column="2" Content="{loc:Translate Key=Ui.Common.Ellipsis}" Width="32" Height="28" Margin="6,0,0,0" Command="{Binding BrowseFocusProcessPathCommand}"/></Grid>
  <Grid Style="{StaticResource StepFieldGrid}" Visibility="{Binding FocusProcessStep_UsesProcessSource, Converter={StaticResource InverseBooleanToVisibilityConverter}}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.WindowTitleContains}" Style="{StaticResource StepFieldLabel}"/><TextBox Grid.Column="1" Text="{Binding FocusProcessStep_WindowTitleContains, UpdateSourceTrigger=PropertyChanged}" mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Step.Settings.Optional}"/></Grid>
  <Expander Style="{StaticResource StepAdvancedExpander}"><StackPanel Margin="0,10,0,0"><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Action}" Margin="0,2,0,4" Foreground="{DynamicResource App.Brush.TextSecondary}"/><StackPanel Orientation="Horizontal" Margin="0,0,0,12"><RadioButton GroupName="FocusProcessAction" Content="{loc:Translate Key=Ui.Step.Settings.BringToFront}" IsChecked="{Binding FocusProcessStep_IsBringToFrontAction}" Margin="0,0,16,0"/><RadioButton GroupName="FocusProcessAction" Content="{loc:Translate Key=Ui.Step.Settings.Minimize}" IsChecked="{Binding FocusProcessStep_IsMinimizeAction}"/></StackPanel><Grid Visibility="{Binding FocusProcessStep_IsBringToFrontAction, Converter={StaticResource BooleanToVisibilityConverter}}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.WindowMode}" Style="{StaticResource StepFieldLabel}"/><ComboBox Grid.Column="1" Width="160" HorizontalAlignment="Left" ItemsSource="{Binding FocusProcessWindowModes}" SelectedItem="{Binding FocusProcessStep_WindowMode}"/></Grid></StackPanel></Expander>
 </StackPanel>
</UserControl>
