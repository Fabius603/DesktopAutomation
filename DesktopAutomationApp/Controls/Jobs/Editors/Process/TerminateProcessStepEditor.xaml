<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Process.TerminateProcessStepEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" xmlns:jobs="clr-namespace:DesktopAutomationApp.Controls.Jobs">
 <StackPanel Visibility="{Binding ShowTerminateProcess, Converter={StaticResource BooleanToVisibilityConverter}}">
  <jobs:ProcessTargetModeSelector Picker="{Binding StartProcessStep_ProcessSource}" UseProcessReference="{Binding StartProcessStep_UsesProcessSource}"/>
  <Grid Style="{StaticResource StepFieldGrid}" Visibility="{Binding StartProcessStep_UsesProcessSource, Converter={StaticResource InverseBooleanToVisibilityConverter}}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.ProcessName}" Style="{StaticResource StepFieldLabel}"/><ComboBox Grid.Column="1" IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True" ItemsSource="{Binding AvailableProcessNames}" Text="{Binding StartProcessStep_ProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Step.Settings.ProcessNamePlaceholder}"/></Grid>
  <Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.WindowTitleContains}" Style="{StaticResource StepFieldLabel}"/><TextBox Grid.Column="1" Text="{Binding StartProcessStep_WindowTitleContains, UpdateSourceTrigger=PropertyChanged}" mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Step.Settings.Optional}"/></Grid>
 </StackPanel>
</UserControl>
