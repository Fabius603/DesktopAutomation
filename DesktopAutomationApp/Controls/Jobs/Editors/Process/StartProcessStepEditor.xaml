<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Process.StartProcessStepEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" xmlns:shared="clr-namespace:DesktopAutomationApp.Controls.Jobs.Shared">
 <StackPanel Visibility="{Binding ShowStartProcess, Converter={StaticResource BooleanToVisibilityConverter}}">
  <Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.PathProgram}" Style="{StaticResource StepFieldLabel}"/><ComboBox Grid.Column="1" IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True" ItemsSource="{Binding AvailableStartPrograms}" TextSearch.TextPath="Command" Text="{Binding StartProcessStep_ExecutablePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Step.Settings.PathToExeOrProgramName}"><ComboBox.ItemTemplate><DataTemplate><StackPanel><TextBlock Text="{Binding DisplayName}"/><TextBlock Text="{Binding Command}" FontSize="10" Foreground="{DynamicResource App.Brush.TextMuted}"/></StackPanel></DataTemplate></ComboBox.ItemTemplate></ComboBox><Button Grid.Column="2" Content="{loc:Translate Key=Ui.Common.Ellipsis}" Width="32" Height="28" Margin="6,0,0,0" Command="{Binding BrowseExecutablePathCommand}"/></Grid>
  <CheckBox Content="{loc:Translate Key=Ui.Step.Settings.WaitForCompletion}" IsChecked="{Binding StartProcessStep_WaitForExit}"/>
  <Expander Style="{StaticResource StepAdvancedExpander}"><StackPanel Margin="0,10,0,0">
   <Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Arguments}" Style="{StaticResource StepFieldLabel}"/><TextBox Grid.Column="1" Text="{Binding StartProcessStep_Arguments, UpdateSourceTrigger=PropertyChanged}" mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Step.Settings.ArgumentsPlaceholder}"/></Grid>
   <Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.WorkingDirectory}" Style="{StaticResource StepFieldLabel}"/><TextBox Grid.Column="1" Text="{Binding StartProcessStep_WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Step.Settings.WorkingDirectoryPlaceholder}"/></Grid>
   <Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Monitor}" Style="{StaticResource StepFieldLabel}"/><shared:MonitorPicker Grid.Column="1" MonitorIndex="{Binding StartProcessStep_MonitorIndex}" SelectCommand="{Binding ChooseMonitorForStartProcessCommand}" HorizontalAlignment="Left"/></Grid>
   <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.WindowMode}" Margin="0,8,0,4" Foreground="{DynamicResource App.Brush.TextSecondary}"/><StackPanel Orientation="Horizontal" Margin="0,0,0,8"><RadioButton GroupName="StartProcessWindowMode" Content="{loc:Translate Key=Ui.Step.Settings.ApplicationDefault}" IsChecked="{Binding StartProcessStep_WindowApplicationDefault}" Margin="0,0,16,0"/><RadioButton GroupName="StartProcessWindowMode" Content="{loc:Translate Key=Ui.Step.Settings.Windowed}" IsChecked="{Binding StartProcessStep_WindowNormal}" Margin="0,0,16,0"/><RadioButton GroupName="StartProcessWindowMode" Content="{loc:Translate Key=Ui.Step.Settings.Maximized}" IsChecked="{Binding StartProcessStep_WindowMaximized}"/></StackPanel>
   <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Position}" Margin="0,8,0,4" Foreground="{DynamicResource App.Brush.TextSecondary}"/><StackPanel Orientation="Horizontal" Margin="0,0,0,8"><RadioButton GroupName="StartProcessPlacement" Content="{loc:Translate Key=Ui.Step.Settings.Centered}" IsChecked="{Binding StartProcessStep_PositionCentered}" Margin="0,0,16,0"/><RadioButton GroupName="StartProcessPlacement" Content="{loc:Translate Key=Ui.Step.Settings.Custom}" IsChecked="{Binding StartProcessStep_PositionCustom}"/></StackPanel>
   <Grid Visibility="{Binding StartProcessStep_PositionCustom, Converter={StaticResource BooleanToVisibilityConverter}}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Position}" Style="{StaticResource StepFieldLabel}"/><StackPanel Grid.Column="1" Orientation="Horizontal"><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.X}" Style="{StaticResource StepAxisLabel}"/><TextBox Width="70" Text="{Binding StartProcessStep_OffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Y}" Style="{StaticResource StepAxisLabel}"/><TextBox Width="70" Text="{Binding StartProcessStep_OffsetY, UpdateSourceTrigger=PropertyChanged}"/></StackPanel></Grid>
  </StackPanel></Expander>
 </StackPanel>
</UserControl>
