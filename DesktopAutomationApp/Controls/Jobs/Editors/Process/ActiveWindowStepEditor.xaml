<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Process.ActiveWindowStepEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" xmlns:jobs="clr-namespace:DesktopAutomationApp.Controls.Jobs">
 <StackPanel Visibility="{Binding ShowActiveWindow, Converter={StaticResource BooleanToVisibilityConverter}}"><jobs:ProcessTargetModeSelector Picker="{Binding ActiveWindowStep_ProcessSource}" UseProcessReference="{Binding ActiveWindowStep_UsesProcessSource}"/><Grid Style="{StaticResource StepFieldGrid}" Visibility="{Binding ActiveWindowStep_UsesProcessSource, Converter={StaticResource InverseBooleanToVisibilityConverter}}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Common.ProcessName}" Style="{StaticResource StepFieldLabel}"/><ComboBox Grid.Column="1" IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True" ItemsSource="{Binding AvailableProcessNames}" Text="{Binding ActiveWindowStep_ProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Step.Settings.ProcessNamePlaceholder}"/></Grid><Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.WindowTitleContains}" Style="{StaticResource StepFieldLabel}"/><TextBox Grid.Column="1" Text="{Binding ActiveWindowStep_WindowTitleContains, UpdateSourceTrigger=PropertyChanged}" mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Step.Settings.Optional}"/></Grid><Expander Style="{StaticResource StepAdvancedExpander}"><StackPanel Margin="0,10,0,0"><Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.CacheMs}" Style="{StaticResource StepFieldLabel}"/><TextBox Grid.Column="1" Text="{Binding ActiveWindowStep_CacheMs, UpdateSourceTrigger=PropertyChanged}"/></Grid><TextBlock Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="11" TextWrapping="Wrap" Text="{loc:Translate Key=Ui.Step.Settings.ActiveWindowResultHint}"/></StackPanel></Expander></StackPanel>
</UserControl>
