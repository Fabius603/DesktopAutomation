<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Execution.JobExecutionStepEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization">
 <StackPanel Visibility="{Binding ShowJobExecution, Converter={StaticResource BooleanToVisibilityConverter}}"><Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Job}" Style="{StaticResource StepFieldLabel}"/><ComboBox Grid.Column="1" ItemsSource="{Binding AvailableJobs}" DisplayMemberPath="Name" SelectedItem="{Binding JobExecutionStep_SelectedJob}"/></Grid><CheckBox Content="{loc:Translate Key=Ui.Step.Settings.WaitForCompletion}" IsChecked="{Binding JobExecutionStep_WaitForCompletion}"/></StackPanel>
</UserControl>
