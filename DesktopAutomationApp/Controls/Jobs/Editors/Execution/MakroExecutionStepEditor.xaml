<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Execution.MakroExecutionStepEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization">
 <Grid Visibility="{Binding ShowMakroExecution, Converter={StaticResource BooleanToVisibilityConverter}}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Macro}" Style="{StaticResource StepFieldLabel}"/><ComboBox Grid.Column="1" ItemsSource="{Binding AvailableMakros}" DisplayMemberPath="Name" SelectedItem="{Binding MakroExecutionStep_SelectedMakro}"/></Grid>
</UserControl>
