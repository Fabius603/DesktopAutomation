<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Analysis.AxisExpressionEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization">
 <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions><ComboBox Margin="0,0,6,0" ItemsSource="{Binding AvailableAxes}" SelectedItem="{Binding Axis}"/><ComboBox Grid.Column="1" Margin="0,0,6,0" ItemsSource="{Binding AvailableOperators}" SelectedItem="{Binding Operator}"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource PointAxisOperatorConverter}}"/></DataTemplate></ComboBox.ItemTemplate></ComboBox><TextBox Grid.Column="2" Margin="0,0,6,0" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/><Button Grid.Column="3" Content="{loc:Translate Key=Ui.Common.RemoveSymbol}" Command="{Binding RemoveCommand}" FontSize="13" Padding="4,2" ToolTip="{loc:Translate Key=Ui.Step.Settings.RemoveExpression}"/></Grid>
</UserControl>
