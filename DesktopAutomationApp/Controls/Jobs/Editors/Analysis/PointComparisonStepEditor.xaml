<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Analysis.PointComparisonStepEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" xmlns:jobs="clr-namespace:DesktopAutomationApp.Controls.Jobs" xmlns:editors="clr-namespace:DesktopAutomationApp.Controls.Jobs.Editors.Analysis">
 <StackPanel Visibility="{Binding ShowPointComparison, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,4">
  <Border Background="{DynamicResource App.Brush.Surface}" BorderBrush="{DynamicResource App.Brush.CardBorder}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10"><StackPanel><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.BasicSettings}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.Brush.TextMuted}" Margin="0,0,0,8"/><Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Mode}" Style="{StaticResource StepFieldLabel}"/><Grid Grid.Column="1"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="6"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border CornerRadius="4" Padding="8,5" BorderThickness="1"><Border.Style><Style TargetType="Border"><Setter Property="BorderBrush" Value="{DynamicResource App.Brush.CardBorder}"/><Style.Triggers><DataTrigger Binding="{Binding PointComparisonStep_ModeIsOffset}" Value="True"><Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/><Setter Property="Background" Value="{DynamicResource App.Brush.AccentSubtle}"/></DataTrigger></Style.Triggers></Style></Border.Style><RadioButton IsChecked="{Binding PointComparisonStep_ModeIsOffset}"><StackPanel><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.OffsetTolerance}" FontSize="11" FontWeight="Medium"/><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.NearReferencePoint}" FontSize="10" Foreground="{DynamicResource App.Brush.TextMuted}" TextWrapping="Wrap"/></StackPanel></RadioButton></Border><Border Grid.Column="2" CornerRadius="4" Padding="8,5" BorderThickness="1"><Border.Style><Style TargetType="Border"><Setter Property="BorderBrush" Value="{DynamicResource App.Brush.CardBorder}"/><Style.Triggers><DataTrigger Binding="{Binding PointComparisonStep_ModeIsExpression}" Value="True"><Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/><Setter Property="Background" Value="{DynamicResource App.Brush.AccentSubtle}"/></DataTrigger></Style.Triggers></Style></Border.Style><RadioButton IsChecked="{Binding PointComparisonStep_ModeIsExpression}"><StackPanel><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Expression}" FontSize="11" FontWeight="Medium"/><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.XYComparisonX100}" FontSize="10" Foreground="{DynamicResource App.Brush.TextMuted}" TextWrapping="Wrap"/></StackPanel></RadioButton></Border></Grid></Grid><Rectangle Height="1" Fill="{DynamicResource App.Brush.CardBorder}" Margin="0,0,0,8"/><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Evaluation}" Style="{StaticResource StepFieldLabel}"/><StackPanel Grid.Column="1" Orientation="Horizontal"><RadioButton Content="{loc:Translate Key=Ui.Step.Settings.AllAND}" IsChecked="{Binding PointComparisonStep_MatchRequirementIsAll}" Margin="0,0,16,0"/><RadioButton Content="{loc:Translate Key=Ui.Step.Settings.AtLeastOneOR}" IsChecked="{Binding PointComparisonStep_MatchRequirementIsAny}"/></StackPanel></Grid></StackPanel></Border>
  <Border Visibility="{Binding PointComparisonStep_ModeIsOffset, Converter={StaticResource BooleanToVisibilityConverter}}" Background="{DynamicResource App.Brush.Surface}" BorderBrush="{DynamicResource App.Brush.CardBorder}" BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,10"><StackPanel><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.ReferencePointTolerance}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.Brush.TextMuted}" Margin="0,0,0,10"/><Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.ReferenceSource}" Style="{StaticResource StepFieldLabel}"/><StackPanel Grid.Column="1" Orientation="Horizontal"><RadioButton Content="{loc:Translate Key=Ui.Step.Settings.EnterManually}" IsChecked="{Binding PointComparisonStep_RefIsManual}" Margin="0,0,20,0"/><RadioButton Content="{loc:Translate Key=Ui.Step.Settings.FromDetectionResult}" IsChecked="{Binding PointComparisonStep_RefIsJobResult}"/></StackPanel></Grid><Grid Style="{StaticResource StepFieldGrid}" Visibility="{Binding PointComparisonStep_RefIsManual, Converter={StaticResource BooleanToVisibilityConverter}}"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.CoordinatesXY}" Style="{StaticResource StepFieldLabel}"/><StackPanel Grid.Column="1" Orientation="Horizontal"><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.X}" Style="{StaticResource StepAxisLabel}"/><TextBox Width="80" Text="{Binding PointComparisonStep_RefX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,16,0"/><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Y}" Style="{StaticResource StepAxisLabel}"/><TextBox Width="80" Text="{Binding PointComparisonStep_RefY, UpdateSourceTrigger=PropertyChanged}"/></StackPanel></Grid><Grid Style="{StaticResource StepFieldGrid}" Visibility="{Binding PointComparisonStep_RefIsJobResult, Converter={StaticResource BooleanToVisibilityConverter}}"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.DetectionStep}" Style="{StaticResource StepFieldLabel}"/><jobs:ResultBindingPicker Grid.Column="1" DataContext="{Binding PointComparisonStep_ReferencePointsSource}"/></Grid><Rectangle Height="1" Fill="{DynamicResource App.Brush.CardBorder}" Margin="0,0,0,10"/><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.TolerancePixels}" Foreground="{DynamicResource App.Brush.TextSecondary}"/><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.MaximumDeviation}" FontSize="10" Foreground="{DynamicResource App.Brush.TextMuted}"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal"><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.X}" Style="{StaticResource StepAxisLabel}"/><TextBox Width="80" Text="{Binding PointComparisonStep_OffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,16,0"/><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Y}" Style="{StaticResource StepAxisLabel}"/><TextBox Width="80" Text="{Binding PointComparisonStep_OffsetY, UpdateSourceTrigger=PropertyChanged}"/></StackPanel></Grid></StackPanel></Border>
  <Border Visibility="{Binding PointComparisonStep_ModeIsExpression, Converter={StaticResource BooleanToVisibilityConverter}}" Background="{DynamicResource App.Brush.Surface}" BorderBrush="{DynamicResource App.Brush.CardBorder}" BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,10"><StackPanel><Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.AxisExpressions}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.Brush.TextMuted}"/><StackPanel Grid.Column="1" Orientation="Horizontal"><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.CombineWith}" FontSize="11" Foreground="{DynamicResource App.Brush.TextSecondary}" Margin="0,0,8,0"/><RadioButton Content="{loc:Translate Key=Ui.Step.Settings.ANDAll}" IsChecked="{Binding PointComparisonStep_ExprCombineIsAnd}" Margin="0,0,12,0"/><RadioButton Content="{loc:Translate Key=Ui.Step.Settings.ORAny}" IsChecked="{Binding PointComparisonStep_ExprCombineIsOr}"/></StackPanel></Grid><Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Axis}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.Brush.TextMuted}"/><TextBlock Grid.Column="1" Text="{loc:Translate Key=Ui.Step.Settings.Operator}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.Brush.TextMuted}"/><TextBlock Grid.Column="2" Text="{loc:Translate Key=Ui.Step.Settings.ComparisonValue}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.Brush.TextMuted}"/></Grid><ItemsControl ItemsSource="{Binding PointComparisonStep_Expressions}"><ItemsControl.ItemTemplate><DataTemplate><editors:AxisExpressionEditor/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><Button Content="{loc:Translate Key=Ui.Step.Settings.AddExpression}" Command="{Binding PointComparisonStep_AddExpressionCommand}" HorizontalAlignment="Left" Margin="0,8,0,0" Style="{StaticResource ButtonSecondary}" Padding="10,5" FontSize="11"/></StackPanel></Border>
  <Border Background="{DynamicResource App.Brush.Surface}" BorderBrush="{DynamicResource App.Brush.CardBorder}" BorderThickness="1" CornerRadius="6" Padding="14,12"><StackPanel><Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.PointsToCheck}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource App.Brush.TextMuted}"/><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.ThesePointsAreCheckedAgainstTheCondition}" FontSize="11" Foreground="{DynamicResource App.Brush.TextMuted}"/></StackPanel><Button Grid.Column="1" Content="{loc:Translate Key=Ui.Step.Settings.AddPoint}" Command="{Binding PointComparisonStep_AddPointCommand}" Style="{StaticResource ButtonSecondary}" Padding="10,5" FontSize="11" VerticalAlignment="Top"/></Grid><ItemsControl ItemsSource="{Binding PointComparisonStep_Points}"><ItemsControl.ItemTemplate><DataTemplate><editors:PointEntryEditor/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border>
 </StackPanel>
</UserControl>
