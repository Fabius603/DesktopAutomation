<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Analysis.PointEntryEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" xmlns:jobs="clr-namespace:DesktopAutomationApp.Controls.Jobs">
 <Border Background="{DynamicResource App.Brush.WindowBackground}" BorderBrush="{DynamicResource App.Brush.CardBorder}" BorderThickness="1" CornerRadius="5" Padding="12,10" Margin="0,0,0,6"><StackPanel><Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.PointSource}" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource App.Brush.TextSecondary}"/><StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><RadioButton Content="{loc:Translate Key=Ui.Step.Settings.Manual}" IsChecked="{Binding IsManual}" Margin="0,0,16,0"/><RadioButton Content="{loc:Translate Key=Ui.Step.Settings.FromDetectionResult}" IsChecked="{Binding IsJobResult}"/></StackPanel><Button Grid.Column="2" Content="{loc:Translate Key=Ui.Step.Settings.RemovePoint}" Command="{Binding RemoveCommand}" FontSize="11" Padding="8,3"/></Grid><Grid Visibility="{Binding ShowManual, Converter={StaticResource BooleanToVisibilityConverter}}"><Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Coordinates}" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource App.Brush.TextSecondary}"/><StackPanel Grid.Column="1" Orientation="Horizontal"><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.X}" Style="{StaticResource StepAxisLabel}" Width="16"/><TextBox Width="90" Margin="0,0,16,0" Text="{Binding ManualX, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Y}" Style="{StaticResource StepAxisLabel}" Width="16"/><TextBox Width="90" Text="{Binding ManualY, UpdateSourceTrigger=PropertyChanged}"/></StackPanel></Grid><Grid Visibility="{Binding ShowJobResult, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.DetectionStep}" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource App.Brush.TextSecondary}"/><jobs:ResultBindingPicker Grid.Column="1" DataContext="{Binding PointsSource}"/></Grid></StackPanel></Border>
</UserControl>
