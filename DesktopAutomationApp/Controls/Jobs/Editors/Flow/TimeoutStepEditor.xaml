<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Flow.TimeoutStepEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization">
 <Grid Visibility="{Binding ShowTimeout, Converter={StaticResource BooleanToVisibilityConverter}}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.WaitTimeMs}" Style="{StaticResource StepFieldLabel}"/><TextBox Grid.Column="1" Width="120" HorizontalAlignment="Left" Text="{Binding TimeoutStep_DelayMs, UpdateSourceTrigger=PropertyChanged}"/></Grid>
</UserControl>
