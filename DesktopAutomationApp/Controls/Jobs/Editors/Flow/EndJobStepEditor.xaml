<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Flow.EndJobStepEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization"><StackPanel Visibility="{Binding ShowEndJob, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.EndJobDescription}" TextWrapping="Wrap" Foreground="{DynamicResource App.Brush.TextMuted}" FontStyle="Italic" FontSize="12" Margin="0,0,0,10"/><CheckBox Content="{loc:Translate Key=Ui.Step.Settings.SkipEndSteps}" IsChecked="{Binding EndJobStep_SkipEndSteps}"/><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.SkipEndStepsHint}" TextWrapping="Wrap" Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="11" Margin="24,3,0,0"/></StackPanel></UserControl>
