<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Roi.DynamicRoiStepEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" xmlns:jobs="clr-namespace:DesktopAutomationApp.Controls.Jobs">
 <StackPanel Visibility="{Binding ShowDynamicRoi, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Text="{loc:Translate Key=Ui.Step.DynamicRoi.Description}" TextWrapping="Wrap" Margin="0,0,0,12" Foreground="{DynamicResource App.Brush.TextSecondary}"/><TextBlock Text="{loc:Translate Key=Ui.Step.DynamicRoi.Source}" Margin="0,0,0,4"/><jobs:ResultBindingPicker DataContext="{Binding DynamicRoiStep_BoundsSource}" Margin="0,0,0,10"/><TextBlock Text="{loc:Translate Key=Ui.Step.DynamicRoi.Padding}" Margin="0,0,0,4"/><TextBox Text="{Binding DynamicRoiStep_Padding, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/><Expander Style="{StaticResource StepAdvancedExpander}"><StackPanel Margin="0,10,0,0"><TextBlock Text="{loc:Translate Key=Ui.Step.DynamicRoi.MinimumConfidence}" Margin="0,0,0,4"/><TextBox Text="{Binding DynamicRoiStep_MinimumConfidence, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/><TextBlock Text="{loc:Translate Key=Ui.Step.DynamicRoi.FullSearchInterval}" TextWrapping="Wrap" Margin="0,0,0,4"/><TextBox Text="{Binding DynamicRoiStep_FullSearchInterval, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/><TextBlock Text="{loc:Translate Key=Ui.Step.DynamicRoi.ResetAfterMisses}" TextWrapping="Wrap" Margin="0,0,0,4"/><TextBox Text="{Binding DynamicRoiStep_ResetAfterMisses, UpdateSourceTrigger=PropertyChanged}"/></StackPanel></Expander></StackPanel>
</UserControl>
