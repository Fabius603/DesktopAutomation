<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Detection.KeyPointMatchingStepEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" xmlns:jobs="clr-namespace:DesktopAutomationApp.Controls.Jobs" xmlns:roi="clr-namespace:DesktopAutomationApp.Controls.Jobs.Roi" xmlns:shared="clr-namespace:DesktopAutomationApp.Controls.Jobs.Shared">
 <StackPanel Visibility="{Binding ShowKeyPointMatching, Converter={StaticResource BooleanToVisibilityConverter}}">
  <Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.CaptureStep}" Style="{StaticResource StepFieldLabel}"/><jobs:ResultBindingPicker Grid.Column="1" DataContext="{Binding KeyPointMatchingStep_ImageSource}"/></Grid>
  <Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Template}" Style="{StaticResource StepFieldLabel}"/><shared:PathPickerField Grid.Column="1" PathValue="{Binding KeyPointMatchingStep_TemplatePath}" BrowseCommand="{Binding BrowseKeyPointMatchingTemplatePathCommand}" PreviewSource="{Binding KeyPointMatchingStep_TemplatePreview}" HasPreview="{Binding KeyPointMatchingStep_HasTemplatePreview}"/></Grid>
  <Expander Style="{StaticResource StepAdvancedExpander}"><StackPanel Margin="0,10,0,0"><roi:RoiEditor IsRoiEnabled="{Binding KeyPointMatchingStep_EnableROI}" X="{Binding KeyPointMatchingStep_RoiX}" Y="{Binding KeyPointMatchingStep_RoiY}" RoiWidth="{Binding KeyPointMatchingStep_RoiW}" RoiHeight="{Binding KeyPointMatchingStep_RoiH}" CaptureCommand="{Binding CaptureKeyPointMatchingRoiCommand}"/><Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.MinMatches}" Style="{StaticResource StepFieldLabel}"/><TextBox Grid.Column="1" Style="{StaticResource StepCompactTextBox}" HorizontalAlignment="Left" Text="{Binding KeyPointMatchingStep_MinMatchCount, UpdateSourceTrigger=PropertyChanged}"/></Grid><Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.LoweSRatio01}" Style="{StaticResource StepFieldLabel}"/><TextBox Grid.Column="1" Style="{StaticResource StepCompactTextBox}" HorizontalAlignment="Left" Text="{Binding KeyPointMatchingStep_LowesRatioThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/></Grid></StackPanel></Expander>
 </StackPanel>
</UserControl>
