<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Editors.Interaction.KlickOnPointStepEditor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:sys="clr-namespace:System;assembly=System.Runtime" xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" xmlns:jobs="clr-namespace:DesktopAutomationApp.Controls.Jobs">
 <StackPanel Visibility="{Binding ShowKlickOnPoint, Converter={StaticResource BooleanToVisibilityConverter}}">
  <Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.DetectionStep}" Style="{StaticResource StepFieldLabel}"/><jobs:ResultBindingPicker Grid.Column="1" DataContext="{Binding KlickOnPointStep_PointsSource}"/></Grid>
  <Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.ClickType}" Style="{StaticResource StepFieldLabel}"/><ComboBox Grid.Column="1" Width="120" HorizontalAlignment="Left" SelectedItem="{Binding KlickOnPointStep_ClickType}"><sys:String>left</sys:String><sys:String>right</sys:String><sys:String>middle</sys:String><sys:String>none</sys:String></ComboBox></Grid>
  <Expander Style="{StaticResource StepAdvancedExpander}"><StackPanel Margin="0,10,0,0">
   <Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Offset}" Style="{StaticResource StepFieldLabel}"/><StackPanel Grid.Column="1" Orientation="Horizontal"><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.X}" Style="{StaticResource StepAxisLabel}"/><TextBox Style="{StaticResource StepCompactTextBox}" Text="{Binding KlickOnPointStep_OffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Y}" Style="{StaticResource StepAxisLabel}"/><TextBox Style="{StaticResource StepCompactTextBox}" Text="{Binding KlickOnPointStep_OffsetY, UpdateSourceTrigger=PropertyChanged}"/></StackPanel></Grid>
   <Grid Style="{StaticResource StepFieldGrid}"><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Step.Settings.TimeoutMs}" Style="{StaticResource StepFieldLabel}"/><TextBox Grid.Column="1" Style="{StaticResource StepCompactTextBox}" HorizontalAlignment="Left" Text="{Binding KlickOnPointStep_TimeoutMs, UpdateSourceTrigger=PropertyChanged}"/></Grid>
   <CheckBox Content="{loc:Translate Key=Ui.Step.Settings.DoubleClick}" IsChecked="{Binding KlickOnPointStep_DoubleClick}" Margin="140,0,0,0"/>
  </StackPanel></Expander>
 </StackPanel>
</UserControl>
