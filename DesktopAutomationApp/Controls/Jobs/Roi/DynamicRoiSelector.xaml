<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Roi.DynamicRoiSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:jobControls="clr-namespace:DesktopAutomationApp.Controls.Jobs"
             xmlns:loc="clr-namespace:DesktopAutomationApp.Localization">
    <Border Background="{DynamicResource App.Brush.Surface}" BorderBrush="{DynamicResource App.Brush.CardBorder}"
            BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,2,0,10">
        <StackPanel>
            <CheckBox Content="{loc:Translate Key=Ui.Step.DynamicRoi.Use}"
                      IsChecked="{Binding UseDynamicRoi, Mode=TwoWay}"
                      FontWeight="SemiBold"
                      Margin="0,0,0,6"/>
            <jobControls:ResultBindingPicker DataContext="{Binding DetectionDynamicRoiSource}"
                                             Visibility="{Binding UseDynamicRoi, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>
    </Border>
</UserControl>
