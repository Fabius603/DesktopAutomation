<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Roi.StaticRoiEditor"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:DesktopAutomationApp.Localization">
    <UserControl.Resources>
        <Style x:Key="RoiFieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/><Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextSecondary}"/>
        </Style>
        <Style x:Key="RoiNumber" TargetType="TextBox">
            <Setter Property="MinWidth" Value="88"/><Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Border Background="{DynamicResource App.Brush.Surface}" BorderBrush="{DynamicResource App.Brush.CardBorder}"
            BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,2,0,10">
        <StackPanel>
            <DockPanel Margin="0,0,0,10">
                <Button DockPanel.Dock="Right" Content="{loc:Translate Key=Ui.Step.Settings.Capture}"
                        Style="{StaticResource ButtonSecondary}" Padding="10,4"
                        Command="{Binding CaptureCommand, ElementName=Root}"/>
                <CheckBox Content="{loc:Translate Key=Ui.Step.Settings.EnableROI}" FontWeight="SemiBold"
                          VerticalAlignment="Center" IsChecked="{Binding IsRoiEnabled, ElementName=Root}"/>
            </DockPanel>
            <Border Padding="10" CornerRadius="4" Background="{DynamicResource App.Brush.Surface}">
                <UniformGrid Columns="4">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.X}" Style="{StaticResource RoiFieldLabel}"/>
                        <TextBox Style="{StaticResource RoiNumber}"
                                 Text="{Binding X, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Y}" Style="{StaticResource RoiFieldLabel}"/>
                        <TextBox Style="{StaticResource RoiNumber}"
                                 Text="{Binding Y, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Width}" Style="{StaticResource RoiFieldLabel}"/>
                        <TextBox Style="{StaticResource RoiNumber}"
                                 Text="{Binding RoiWidth, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Height}" Style="{StaticResource RoiFieldLabel}"/>
                        <TextBox Style="{StaticResource RoiNumber}"
                                 Text="{Binding RoiHeight, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </UniformGrid>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
