<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.Shared.MonitorPicker"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:DesktopAutomationApp.Localization">
    <StackPanel Orientation="Horizontal">
        <TextBox Width="60" IsReadOnly="True"
                 Text="{Binding MonitorIndex, ElementName=Root}"/>
        <Button Content="{loc:Translate Key=Ui.Step.Settings.SelectMonitor}"
                Margin="8,0,0,0" Padding="10,5"
                Command="{Binding SelectCommand, ElementName=Root}"/>
    </StackPanel>
</UserControl>
