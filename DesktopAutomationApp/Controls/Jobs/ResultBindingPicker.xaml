<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.ResultBindingPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:jobs="clr-namespace:DesktopAutomationApp.Controls.Jobs"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <jobs:ResultPathPicker ItemsSource="{Binding SelectionTree}"
                               DisplayText="{Binding SelectedPath}"
                               SecondaryText="{Binding SelectedCardinality}"/>

        <Button Grid.Column="1"
                Width="30" Height="30"
                Margin="5,0,0,0"
                VerticalAlignment="Center"
                Style="{StaticResource ButtonIconDanger}"
                Command="{Binding ClearCommand}"
                Visibility="{Binding CanClear, Converter={StaticResource BooleanToVisibilityConverter}}">
            <iconPacks:PackIconMaterial Kind="Close" Width="13" Height="13"/>
        </Button>
    </Grid>
</UserControl>
