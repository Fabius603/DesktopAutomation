<UserControl x:Class="DesktopAutomationApp.Controls.Jobs.ResultBindingPicker"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Button x:Name="PickerButton"
                MinHeight="44"
                Padding="10,5"
                HorizontalContentAlignment="Stretch"
                Style="{StaticResource ButtonSecondary}"
                Click="OpenPicker_Click">
            <Button.ContextMenu>
                <ContextMenu ItemsSource="{Binding SelectionTree}"
                             DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <ContextMenu.Resources>
                        <Style TargetType="{x:Type MenuItem}">
                            <Setter Property="Command" Value="{Binding SelectCommand}"/>
                        </Style>
                    </ContextMenu.Resources>
                    <ContextMenu.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <Grid MinWidth="190">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding DisplayName}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SecondaryText}"
                                           Margin="14,0,0,0"
                                           FontSize="10"
                                           Foreground="{DynamicResource App.Brush.TextMuted}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </HierarchicalDataTemplate>
                    </ContextMenu.ItemTemplate>
                </ContextMenu>
            </Button.ContextMenu>

            <Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedPath}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding SelectedPath}"/>
                    <TextBlock Text="{Binding SelectedCardinality}"
                               Margin="0,1,0,0" FontSize="10"
                               Foreground="{DynamicResource App.Brush.TextMuted}"/>
                </StackPanel>
                <iconPacks:PackIconMaterial Grid.Column="1"
                                            Kind="ChevronRight"
                                            Width="15" Height="15"
                                            Margin="8,0,0,0"
                                            Foreground="{DynamicResource App.Brush.TextMuted}"
                                            VerticalAlignment="Center"/>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConfigured}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="28" Height="28" CornerRadius="14"
                        Background="{DynamicResource App.Brush.Surface}" Margin="0,0,9,0">
                    <iconPacks:PackIconMaterial Kind="LinkVariantOff" Width="14" Height="14"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Foreground="{DynamicResource App.Brush.TextMuted}"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding EmptyTitle}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding EmptyHint}" FontSize="10"
                               Foreground="{DynamicResource App.Brush.TextMuted}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <iconPacks:PackIconMaterial Grid.Column="2" Kind="ChevronRight"
                                            Width="15" Height="15" Margin="8,0,0,0"
                                            Foreground="{DynamicResource App.Brush.TextMuted}"
                                            VerticalAlignment="Center"/>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConfigured}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
            </Grid>
            </Grid>
        </Button>

        <Button Grid.Column="1"
                Width="30" Height="30"
                Margin="5,0,0,0"
                VerticalAlignment="Center"
                Style="{StaticResource ButtonIcon}"
                Command="{Binding ClearCommand}"
                Visibility="{Binding CanClear, Converter={StaticResource BooleanToVisibilityConverter}}">
            <iconPacks:PackIconMaterial Kind="Close" Width="13" Height="13"/>
        </Button>
    </Grid>
</UserControl>
