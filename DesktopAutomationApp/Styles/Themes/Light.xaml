<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <sys:String xmlns:sys="clr-namespace:System;assembly=System.Runtime" x:Key="App.Palette.Kind">AppThemePalette</sys:String>
    <Color x:Key="App.Color.WindowBackground">#FFF4F5F8</Color>
    <Color x:Key="App.Color.Surface">#FFFFFFFF</Color>
    <Color x:Key="App.Color.SurfaceHover">#FFE9ECF2</Color>
    <Color x:Key="App.Color.SidebarBackground">#FFE7EAF0</Color>
    <Color x:Key="App.Color.CardBorder">#FFD2D6DF</Color>
    <Color x:Key="App.Color.RowEven">#FFF7F8FA</Color>
    <Color x:Key="App.Color.RowOdd">#FFFFFFFF</Color>
    <Color x:Key="App.Color.TextPrimary">#FF202330</Color>
    <Color x:Key="App.Color.TextSecondary">#FF4C5263</Color>
    <Color x:Key="App.Color.TextMuted">#FF747B8C</Color>
    <SolidColorBrush x:Key="App.Brush.WindowBackground" Color="{StaticResource App.Color.WindowBackground}"/>
    <SolidColorBrush x:Key="App.Brush.Surface" Color="{StaticResource App.Color.Surface}"/>
    <SolidColorBrush x:Key="App.Brush.SurfaceHover" Color="{StaticResource App.Color.SurfaceHover}"/>
    <SolidColorBrush x:Key="App.Brush.SidebarBackground" Color="{StaticResource App.Color.SidebarBackground}"/>
    <SolidColorBrush x:Key="App.Brush.CardBorder" Color="{StaticResource App.Color.CardBorder}"/>
    <SolidColorBrush x:Key="App.Brush.RowEven" Color="{StaticResource App.Color.RowEven}"/>
    <SolidColorBrush x:Key="App.Brush.RowOdd" Color="{StaticResource App.Color.RowOdd}"/>
    <SolidColorBrush x:Key="App.Brush.TextPrimary" Color="{StaticResource App.Color.TextPrimary}"/>
    <SolidColorBrush x:Key="App.Brush.TextSecondary" Color="{StaticResource App.Color.TextSecondary}"/>
    <SolidColorBrush x:Key="App.Brush.TextMuted" Color="{StaticResource App.Color.TextMuted}"/>
    <SolidColorBrush x:Key="MahApps.Brushes.ThemeBackground" Color="{StaticResource App.Color.WindowBackground}"/>
    <SolidColorBrush x:Key="MahApps.Brushes.ThemeForeground" Color="{StaticResource App.Color.TextPrimary}"/>
</ResourceDictionary>

