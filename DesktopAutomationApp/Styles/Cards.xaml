<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Basis-Style für alle Content-Views -->
    <Style x:Key="ContentViewBase" TargetType="UserControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource App.Brush.TextPrimary}"/>
        <Setter Property="TextElement.FontSize" Value="14"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <!-- Standard-Karte mit abgerundeten Ecken und dezenter Elevation -->
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.CardBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource App.Brush.Surface}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Direction="270" BlurRadius="6" ShadowDepth="2"
                                  Opacity="0.12" Color="Black"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Karten-Box für gleichmäßige Layouts (kein Margin, dehnbar) -->
    <Style x:Key="CardBox" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="Margin" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- Item-Karte für ItemsControl-Einträge (z. B. YOLO Model-Cards) -->
    <Style x:Key="ItemCardStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.CardBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource App.Brush.Surface}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

</ResourceDictionary>
