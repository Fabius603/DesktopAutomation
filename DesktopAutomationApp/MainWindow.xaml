<!-- MainWindow.xaml -->
<mah:MetroWindow x:Class="DesktopAutomationApp.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:loc="clr-namespace:DesktopAutomationApp.Localization"
                 xmlns:controls="clr-namespace:DesktopAutomationApp.Controls"
                 Title="{Binding WindowTitle}"
                 Icon="Assets/App.ico"
                 MinWidth="1300" MinHeight="600"
                 Background="{DynamicResource App.Brush.WindowBackground}"
                 WindowTitleBrush="{DynamicResource App.Brush.Accent}"
                 NonActiveWindowTitleBrush="{DynamicResource App.Brush.AccentDark}"
                 TitleForeground="White"
                 BorderBrush="Transparent"
                 BorderThickness="0"
                 GlowBrush="Transparent"
                 WindowStartupLocation="CenterScreen">
    <mah:MetroWindow.TitleTemplate>
        <DataTemplate>
            <TextBlock VerticalAlignment="Center">
                <Run Text="{loc:Translate Key=Ui.App.Title}" FontWeight="SemiBold"/><Run Text="{Binding DataContext.VersionLabel, RelativeSource={RelativeSource AncestorType={x:Type mah:MetroWindow}}, Mode=OneWay}" FontSize="10" FontWeight="Light"/>
            </TextBlock>
        </DataTemplate>
    </mah:MetroWindow.TitleTemplate>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Sidebar ═══ -->
        <Border Background="{DynamicResource App.Brush.SidebarBackground}">
            <DockPanel>
                <!-- App Branding -->
                <StackPanel DockPanel.Dock="Top" Margin="20,20,20,28">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="24" Height="24"
                               Source="{Binding Icon, RelativeSource={RelativeSource AncestorType={x:Type mah:MetroWindow}}}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.App.Title}"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource App.Brush.Accent}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Update-Notification (nur sichtbar wenn neue Version vorhanden) -->
                <Border DockPanel.Dock="Bottom"
                        Visibility="{Binding HasUpdate, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Background="{DynamicResource App.Brush.AccentSubtle}"
                        BorderBrush="{DynamicResource App.Brush.Accent}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="12,0,12,16"
                        Padding="12,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <iconPacks:PackIconMaterial Kind="ArrowUpCircleOutline"
                                                        Width="14" Height="14"
                                                        Foreground="{DynamicResource App.Brush.Accent}"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Translate Key=Ui.App.UpdateAvailable}"
                                       FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource App.Brush.Accent}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding LatestVersion}"
                                   FontSize="11"
                                   Foreground="{DynamicResource App.Brush.TextSecondary}"
                                   Margin="0,0,0,8"/>

                        <!-- Fortschrittsbalken (nur während Download sichtbar) -->
                        <ProgressBar Value="{Binding UpdateProgress, Mode=OneWay}"
                                     Minimum="0" Maximum="100"
                                     Height="4" Margin="0,0,0,4"
                                     Visibility="{Binding IsUpdating, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding UpdateStatusText}"
                                   FontSize="10"
                                   Foreground="{DynamicResource App.Brush.TextMuted}"
                                   Margin="0,0,0,6"
                                   Visibility="{Binding IsUpdating, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <!-- Statustext wenn Update fertig heruntergeladen -->
                        <TextBlock Text="{Binding UpdateStatusText}"
                                   FontSize="10"
                                   Foreground="{DynamicResource App.Brush.Accent}"
                                   Margin="0,0,0,6"
                                   Visibility="{Binding IsUpdateReady, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <!-- Jetzt updaten (nur sichtbar solange noch nicht heruntergeladen) -->
                        <Button Style="{StaticResource ButtonPrimary}"
                                Command="{Binding InstallUpdateCommand}"
                                FontSize="11"
                                Padding="8,4"
                                HorizontalAlignment="Stretch"
                                Visibility="{Binding ShowDownloadButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="Download"
                                                            Width="12" Height="12"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,5,0"/>
                                <TextBlock Text="{loc:Translate Key=Ui.App.UpdateNow}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Neu starten (erscheint wenn Download abgeschlossen) -->
                        <Button Style="{StaticResource ButtonDanger}"
                                Click="RestartToUpdate_Click"
                                FontSize="11"
                                Padding="8,4"
                                HorizontalAlignment="Stretch"
                                Visibility="{Binding IsUpdateReady, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="Restart"
                                                            Width="12" Height="12"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,5,0"/>
                                <TextBlock Text="{loc:Translate Key=Ui.App.RestartToInstallUpdate}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <StackPanel Margin="0,0,0,0">
                    <!-- Start -->
                    <Button Command="{Binding ShowStart}"
                            Tag="StartViewModel"
                            Style="{DynamicResource SidebarNavButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Home" Width="18" Height="18"
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{loc:Translate Key=Ui.App.Home}" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <!-- Automationen -->
                    <Button Command="{Binding ShowListAutomations}"
                            Tag="ListAutomationsViewModel"
                            Style="{DynamicResource SidebarNavButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CalendarClock" Width="18" Height="18"
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{loc:Translate Key=Ui.Automation.List.Automations}" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <!-- Makros -->
                    <Button Command="{Binding ShowListMakros}"
                            Tag="ListMakrosViewModel"
                            Style="{DynamicResource SidebarNavButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="RepeatVariant" Width="18" Height="18"
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{loc:Translate Key=Ui.Dashboard.Makros}" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <!-- Jobs -->
                    <Button Command="{Binding ShowListJobs}"
                            Tag="ListJobsViewModel"
                            Style="{DynamicResource SidebarNavButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="PlaylistPlay" Width="18" Height="18"
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{loc:Translate Key=Ui.Job.List.Jobs}" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <!-- YOLO Downloads -->
                    <Button Command="{Binding ShowYoloDownloads}"
                            Tag="YoloDownloadsViewModel"
                            Style="{DynamicResource SidebarNavButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Download" Width="18" Height="18"
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{loc:Translate Key=Ui.Yolo.YOLODownloads}" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <!-- Logs -->
                    <Button Command="{Binding ShowExecutionLogs}"
                            Tag="ExecutionLogsViewModel"
                            Style="{DynamicResource SidebarNavButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="TextBoxSearchOutline" Width="18" Height="18"
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{loc:Translate Key=Ui.App.Logs}" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowSettings}"
                            Tag="SettingsViewModel"
                            Style="{DynamicResource SidebarNavButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CogOutline" Width="18" Height="18"
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{loc:Translate Navigation.Settings}" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Separator -->
        <Border Grid.Column="1"
                Background="{DynamicResource App.Brush.CardBorder}"/>

        <!-- ═══ Content ═══ -->
        <Grid Grid.Column="2"
              Background="{DynamicResource App.Brush.WindowBackground}">
            <Border Padding="24,16">
                <controls:PageTransitionContentControl Content="{Binding CurrentContent}"/>
            </Border>

            <!-- Sichtbares Feedback, bevor und während eine Seite asynchron geladen wird. -->
            <ProgressBar Height="1"
                         VerticalAlignment="Top"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding NavigationProgress, Mode=OneWay}"
                         IsHitTestVisible="False"
                         Foreground="{DynamicResource App.Brush.Accent}"
                         Background="Transparent"
                         BorderThickness="0"
                         Visibility="{Binding IsNavigating, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Panel.ZIndex="10">
                <ProgressBar.Template>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid Background="Transparent" ClipToBounds="True">
                            <Border x:Name="PART_Track" Background="Transparent"/>
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"/>
                        </Grid>
                    </ControlTemplate>
                </ProgressBar.Template>
            </ProgressBar>
        </Grid>
    </Grid>
</mah:MetroWindow>
