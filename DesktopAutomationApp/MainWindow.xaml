<!-- MainWindow.xaml -->
<mah:MetroWindow x:Class="DesktopAutomationApp.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 Title="DesktopAutomation"
                 MinWidth="1300" MinHeight="600"
                 Background="{DynamicResource App.Brush.WindowBackground}"
                 GlowBrush="{DynamicResource App.Brush.AccentDark}"
                 WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Sidebar ═══ -->
        <Border Background="{DynamicResource App.Brush.SidebarBackground}">
            <DockPanel>
                <!-- App Branding -->
                <StackPanel DockPanel.Dock="Top" Margin="20,20,20,28">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="RobotIndustrial"
                                                    Width="24" Height="24"
                                                    Foreground="{DynamicResource App.Brush.Accent}"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Desktop" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource App.Brush.Accent}"/>
                            <TextBlock Text="Automation" FontSize="14" FontWeight="Light"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"
                                       Margin="0,-2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Update-Notification (nur sichtbar wenn neue Version vorhanden) -->
                <Border DockPanel.Dock="Bottom"
                        Visibility="{Binding HasUpdate, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Background="{DynamicResource App.Brush.AccentSubtle}"
                        BorderBrush="{DynamicResource App.Brush.Accent}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="12,0,12,16"
                        Padding="12,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <iconPacks:PackIconMaterial Kind="ArrowUpCircleOutline"
                                                        Width="14" Height="14"
                                                        Foreground="{DynamicResource App.Brush.Accent}"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,6,0"/>
                            <TextBlock Text="Update verfügbar"
                                       FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource App.Brush.Accent}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding LatestVersion}"
                                   FontSize="11"
                                   Foreground="{DynamicResource App.Brush.TextSecondary}"
                                   Margin="0,0,0,8"/>

                        <!-- Fortschrittsbalken (nur während Download sichtbar) -->
                        <ProgressBar Value="{Binding UpdateProgress, Mode=OneWay}"
                                     Minimum="0" Maximum="100"
                                     Height="4" Margin="0,0,0,4"
                                     Visibility="{Binding IsUpdating, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding UpdateStatusText}"
                                   FontSize="10"
                                   Foreground="{DynamicResource App.Brush.TextMuted}"
                                   Margin="0,0,0,6"
                                   Visibility="{Binding IsUpdating, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <!-- Jetzt updaten -->
                        <Button Style="{StaticResource ButtonPrimary}"
                                Command="{Binding InstallUpdateCommand}"
                                FontSize="11"
                                Padding="8,4"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="Download"
                                                            Width="12" Height="12"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,5,0"/>
                                <TextBlock Text="Jetzt updaten" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <StackPanel Margin="0,0,0,0">
                    <!-- Start -->
                    <Button Command="{Binding ShowStart}"
                            Tag="StartViewModel"
                            Style="{DynamicResource SidebarNavButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Home" Width="18" Height="18"
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Start" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <!-- Hotkeys -->
                    <Button Command="{Binding ShowListHotkeys}"
                            Tag="ListHotkeysViewModel"
                            Style="{DynamicResource SidebarNavButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Keyboard" Width="18" Height="18"
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Hotkeys" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <!-- Makros -->
                    <Button Command="{Binding ShowListMakros}"
                            Tag="ListMakrosViewModel"
                            Style="{DynamicResource SidebarNavButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="RepeatVariant" Width="18" Height="18"
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Makros" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <!-- Jobs -->
                    <Button Command="{Binding ShowListJobs}"
                            Tag="ListJobsViewModel"
                            Style="{DynamicResource SidebarNavButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="PlaylistPlay" Width="18" Height="18"
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Jobs" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <!-- YOLO Downloads -->
                    <Button Command="{Binding ShowYoloDownloads}"
                            Tag="YoloDownloadsViewModel"
                            Style="{DynamicResource SidebarNavButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Download" Width="18" Height="18"
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="YOLO Downloads" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Separator -->
        <Border Grid.Column="1"
                Background="{DynamicResource App.Brush.CardBorder}"/>

        <!-- ═══ Content ═══ -->
        <Border Grid.Column="2"
                Background="{DynamicResource App.Brush.WindowBackground}"
                Padding="24,16">
            <ContentControl Content="{Binding CurrentContent}"/>
        </Border>
    </Grid>
</mah:MetroWindow>
