<UserControl xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" x:Class="DesktopAutomationApp.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Style="{StaticResource ContentViewBase}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding RefreshCommand}" ToolTip="{loc:Translate Key=Ui.Dashboard.RefreshDashboard}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.Refresh}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{loc:Translate Key=Ui.App.Title}" Style="{StaticResource PageTitle}" Margin="0,0,12,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Dashboard Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Stat Cards Row -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Automationen -->
                    <Border Grid.Column="0" Style="{StaticResource CardBox}" Margin="0,0,6,0">
                        <StackPanel Margin="16,12" HorizontalAlignment="Center">
                            <TextBlock Text="{loc:Translate Key=Ui.Automation.List.Automations}" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="12"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock Text="{Binding ActiveAutomationCount}" FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource App.Brush.Accent}"/>
                                <TextBlock Text="{loc:Translate Key=Ui.Dashboard.Separator}" FontSize="20" VerticalAlignment="Bottom" Margin="2,0"
                                           Foreground="{DynamicResource App.Brush.TextMuted}"/>
                                <TextBlock Text="{Binding TotalAutomationCount}" FontSize="20" VerticalAlignment="Bottom"
                                           Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            </StackPanel>
                            <TextBlock Text="{loc:Translate Key=Ui.Dashboard.ActiveTotal}" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <!-- Jobs -->
                    <Border Grid.Column="1" Style="{StaticResource CardBox}" Margin="3,0">
                        <StackPanel Margin="16,12" HorizontalAlignment="Center">
                            <TextBlock Text="{loc:Translate Key=Ui.Job.List.Jobs}" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="12"/>
                            <TextBlock Text="{Binding TotalJobCount}" HorizontalAlignment="Center"
                                       FontSize="28" FontWeight="Bold" Margin="0,4,0,0"
                                       Foreground="{DynamicResource App.Brush.Accent}"/>
                            <TextBlock Text="{loc:Translate Key=Ui.Dashboard.Total}" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <!-- Makros -->
                    <Border Grid.Column="2" Style="{StaticResource CardBox}" Margin="6,0,0,0">
                        <StackPanel Margin="16,12" HorizontalAlignment="Center">
                            <TextBlock Text="{loc:Translate Key=Ui.Dashboard.Makros}" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="12"/>
                            <TextBlock Text="{Binding TotalMakroCount}" HorizontalAlignment="Center"
                                       FontSize="28" FontWeight="Bold" Margin="0,4,0,0"
                                       Foreground="{DynamicResource App.Brush.Accent}"/>
                            <TextBlock Text="{loc:Translate Key=Ui.Dashboard.Total}" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Aktive Automationen -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel Margin="12">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Style="{StaticResource Heading2}" Text="{loc:Translate Key=Ui.Dashboard.ActiveAutomations}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Border Style="{StaticResource CountBadge}" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ActiveAutomationCount}" Foreground="{DynamicResource App.Brush.Accent}" FontSize="13"/>
                            </Border>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding ActiveAutomations}" AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                  HeadersVisibility="Column" MaxHeight="240">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Translate Key=Ui.Common.Name}" Binding="{Binding Name}" Width="2*"/>
                                <DataGridTextColumn Header="{loc:Translate Key=Ui.Automation.Details.Trigger}" Binding="{Binding Trigger}" Width="3*"/>
                                <DataGridTextColumn Header="{loc:Translate Key=Ui.Automation.Details.Action}" Binding="{Binding Action}" Width="2*"/>
                                <DataGridTextColumn Header="{loc:Translate Key=Ui.Automation.List.LastRun}" Binding="{Binding LastRun}" Width="2*"/>
                                <DataGridTextColumn Header="{loc:Translate Key=Ui.Automation.List.NextRun}" Binding="{Binding NextRun}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="{loc:Translate Key=Ui.Dashboard.NoActiveAutomation}" Foreground="{DynamicResource App.Brush.TextMuted}"
                                   FontStyle="Italic" Margin="0,8,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveAutomationCount}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Laufende Jobs & Makros -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel Margin="12">
                        <DockPanel Margin="0,0,0,8">
                            <!-- Rechts: Stop All (F10) -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource ButtonDanger}"
                                        Command="{Binding StopAllJobsCommand}"
                                        ToolTip="{loc:Translate Key=Ui.Dashboard.StopAllRunningJobsMacrosF10}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="StopCircleOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Translate Key=Ui.Dashboard.StopAll}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="{loc:Translate Key=Ui.Dashboard.CountExecutions}" Margin="8,0,0,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="11"/>
                            </StackPanel>
                            <!-- Links: Titel + Zähler -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource Heading2}" Text="{loc:Translate Key=Ui.Dashboard.RunningJobsMacros}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Border Style="{StaticResource CountBadge}" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding RunningTotalCount, Mode=OneWay}"
                                               Foreground="{DynamicResource App.Brush.Accent}" FontSize="13"/>
                                </Border>
                            </StackPanel>
                        </DockPanel>

                        <!-- Kombinierte Liste: Jobs und Makros gleich dargestellt -->
                        <ItemsControl ItemsSource="{Binding RunningItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBox}" Margin="0,0,0,4">
                                        <DockPanel Margin="12,8">
                                            <Button DockPanel.Dock="Right"
                                                    Style="{StaticResource ButtonDanger}"
                                                    Command="{Binding DataContext.CancelItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="{loc:Translate Key=Ui.Dashboard.StopAllInstancesOfThisJob}">
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial Kind="Stop" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{loc:Translate Key=Ui.Common.Stop}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <iconPacks:PackIconMaterial Width="14" Height="14"
                                                                            Foreground="{DynamicResource App.Brush.Accent}"
                                                                            VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <iconPacks:PackIconMaterial.Style>
                                                        <Style TargetType="iconPacks:PackIconMaterial">
                                                            <Setter Property="Kind" Value="Play"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMakro}" Value="True">
                                                                    <Setter Property="Kind" Value="RepeatVariant"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </iconPacks:PackIconMaterial.Style>
                                                </iconPacks:PackIconMaterial>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <!-- Instanz-Zähler: nur sichtbar wenn mehr als eine Instanz läuft -->
                                                <Border Margin="6,0,0,0" VerticalAlignment="Center"
                                                        Background="{DynamicResource App.Brush.Surface}"
                                                        BorderBrush="{DynamicResource App.Brush.Border}"
                                                        BorderThickness="1" CornerRadius="8" Padding="6,2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding InstanceCount}" Value="1">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Foreground="{DynamicResource App.Brush.Accent}" FontSize="11">
                                                        <Run Text="{loc:Translate Key=Ui.Common.RemoveSymbol}"/><Run Text="{Binding InstanceCount}"/>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Fallback wenn nichts läuft -->
                        <TextBlock Text="{loc:Translate Key=Ui.Dashboard.NoActiveJobMacro}"
                                   Foreground="{DynamicResource App.Brush.TextMuted}"
                                   FontStyle="Italic" Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RunningTotalCount}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
