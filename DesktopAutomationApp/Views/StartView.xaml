<UserControl x:Class="DesktopAutomationApp.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Style="{StaticResource ContentViewBase}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding RefreshCommand}" ToolTip="Dashboard aktualisieren">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Aktualisieren" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="DesktopAutomation" Style="{StaticResource PageTitle}" Margin="0,0,12,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Dashboard Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Stat Cards Row -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Hotkeys -->
                    <Border Grid.Column="0" Style="{StaticResource CardBox}" Margin="0,0,6,0">
                        <StackPanel Margin="16,12" HorizontalAlignment="Center">
                            <TextBlock Text="Hotkeys" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="12"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock Text="{Binding ActiveHotkeyCount}" FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource App.Brush.Accent}"/>
                            </StackPanel>
                            <TextBlock Text="aktiv" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <!-- Jobs -->
                    <Border Grid.Column="1" Style="{StaticResource CardBox}" Margin="3,0">
                        <StackPanel Margin="16,12" HorizontalAlignment="Center">
                            <TextBlock Text="Jobs" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="12"/>
                            <TextBlock Text="{Binding TotalJobCount}" HorizontalAlignment="Center"
                                       FontSize="28" FontWeight="Bold" Margin="0,4,0,0"
                                       Foreground="{DynamicResource App.Brush.Accent}"/>
                            <TextBlock Text="gesamt" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <!-- Makros -->
                    <Border Grid.Column="2" Style="{StaticResource CardBox}" Margin="6,0,0,0">
                        <StackPanel Margin="16,12" HorizontalAlignment="Center">
                            <TextBlock Text="Makros" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="12"/>
                            <TextBlock Text="{Binding TotalMakroCount}" HorizontalAlignment="Center"
                                       FontSize="28" FontWeight="Bold" Margin="0,4,0,0"
                                       Foreground="{DynamicResource App.Brush.Accent}"/>
                            <TextBlock Text="gesamt" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Aktive Hotkeys -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel Margin="12">
                        <DockPanel Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right" Command="{Binding ToggleHotkeyPauseCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ButtonSecondary}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHotkeysPaused}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource App.Brush.Accent}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0">
                                        <iconPacks:PackIconMaterial.Style>
                                            <Style TargetType="iconPacks:PackIconMaterial">
                                                <Setter Property="Kind" Value="Pause"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHotkeysPaused}" Value="True">
                                                        <Setter Property="Kind" Value="Play"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </iconPacks:PackIconMaterial.Style>
                                    </iconPacks:PackIconMaterial>
                                    <TextBlock Text="{Binding PauseButtonText}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Style="{StaticResource Heading2}" Text="Aktive Hotkeys" VerticalAlignment="Center"/>
                        </DockPanel>

                        <DataGrid ItemsSource="{Binding ActiveHotkeys}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  MaxHeight="250"
                                  ScrollViewer.CanContentScroll="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                                <DataGridTextColumn Header="Trigger" Binding="{Binding Trigger}" Width="*"/>
                                <DataGridTextColumn Header="Job" Binding="{Binding ActionName}" Width="2*"/>
                                <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Keine Hotkeys registriert"
                                   Foreground="{DynamicResource App.Brush.TextMuted}"
                                   FontStyle="Italic" Margin="0,8,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveHotkeys.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Laufende Jobs -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel Margin="12">
                        <DockPanel Margin="0,0,0,8">
                            <Border DockPanel.Dock="Right" Style="{StaticResource CountBadge}" VerticalAlignment="Center">
                                <TextBlock Text="{Binding RunningJobCount}"
                                           Foreground="{DynamicResource App.Brush.Accent}" FontSize="13"/>
                            </Border>
                            <TextBlock Style="{StaticResource Heading2}" Text="Laufende Jobs" VerticalAlignment="Center"/>
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding RunningJobs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBox}" Margin="0,0,0,4">
                                        <DockPanel Margin="12,8">
                                            <Button DockPanel.Dock="Right"
                                                    Style="{StaticResource ButtonDanger}"
                                                    Command="{Binding DataContext.CancelJobCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip="Job abbrechen">
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial Kind="Stop" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="Stop" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14"
                                                                           Foreground="{DynamicResource App.Brush.Accent}"
                                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Keine Jobs aktiv"
                                   Foreground="{DynamicResource App.Brush.TextMuted}"
                                   FontStyle="Italic" Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RunningJobCount}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
