<UserControl x:Class="DesktopAutomationApp.Views.ListMakrosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Style="{StaticResource ContentViewBase}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonPrimary}" Command="{Binding NewMakroCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Neues Makro" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonDanger}" Command="{Binding DeleteMakroCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Löschen" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Border Style="{StaticResource ToolbarSeparator}"/>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Aktualisieren" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding OpenFolderCommand}" Margin="8,0,0,0" ToolTip="Ordner im Explorer öffnen">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}" Margin="0,0,12,0"/>
                <Border Style="{StaticResource CountBadge}" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Items.Count, StringFormat='({0})'}"
                               Foreground="{DynamicResource App.Brush.Accent}"
                               FontSize="13"/>
                </Border>
            </StackPanel>
        </DockPanel>

        <!-- Liste der Makros -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <DataGrid x:Name="MakroGrid"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionChanged="MakroGrid_SelectionChanged"
                      PreviewMouseLeftButtonDown="MakroGrid_PreviewMouseDown">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"
                        Binding="{Binding Name}"
                        IsReadOnly="True"
                        Width="2*"/>
                    <DataGridTextColumn Header="# Befehle"
                        Binding="{Binding Befehle.Count}"
                        IsReadOnly="True" Width="*"/>
                    <DataGridTemplateColumn Header="" IsReadOnly="True" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <!-- Play Button: sichtbar wenn Makro NICHT läuft -->
                                    <Button Style="{StaticResource ButtonPrimary}"
                                            Command="{Binding DataContext.StartMakroCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}"
                                            ToolTip="Makro starten">
                                        <Button.Visibility>
                                            <MultiBinding Converter="{StaticResource CollectionContainsConverter}" ConverterParameter="Invert">
                                                <Binding Path="Id"/>
                                                <Binding Path="DataContext.RunningMakroIds" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                                <Binding Path="DataContext.RunningMakroIds.Count" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Kind="Play" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="Start" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <!-- Stop Button: sichtbar wenn Makro läuft -->
                                    <Button Style="{StaticResource ButtonDanger}"
                                            Command="{Binding DataContext.StopMakroCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}"
                                            ToolTip="Makro stoppen">
                                        <Button.Visibility>
                                            <MultiBinding Converter="{StaticResource CollectionContainsConverter}">
                                                <Binding Path="Id"/>
                                                <Binding Path="DataContext.RunningMakroIds" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                                <Binding Path="DataContext.RunningMakroIds.Count" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Kind="Stop" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="Stop" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" IsReadOnly="True" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource ButtonPrimary}"
                                        Command="{Binding DataContext.OpenMakroCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ArrowRight" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="Öffnen" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
