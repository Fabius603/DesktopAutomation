<mah:MetroWindow x:Class="DesktopAutomationApp.Views.RecordingSettingsDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:loc="clr-namespace:DesktopAutomationApp.Localization"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 Title="{loc:Translate Key=Ui.Macro.Recording.Settings}"
                 Width="680" Height="720" MinWidth="620" MinHeight="650"
                 WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
                 ShowInTaskbar="False" Style="{StaticResource DialogWindowStyle}">
    <mah:MetroWindow.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}"/>
        </Style>
        <Style x:Key="Description" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="ModeCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource App.Brush.WindowBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="OptionCard" TargetType="Border" BasedOn="{StaticResource ModeCard}">
            <Setter Property="Margin" Value="0,0,0,7"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Margin="24,20,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Width="36" Height="36" CornerRadius="8" Background="{DynamicResource App.Brush.AccentSubtle}">
                <iconPacks:PackIconMaterial Kind="RecordRec" Width="19" Height="19"
                                            Foreground="{DynamicResource App.Brush.Accent}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.Settings}" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.Settings.Help}" Style="{StaticResource Description}" Margin="0,3,0,0"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,8,0">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.Mode}" Style="{StaticResource SectionTitle}" Margin="0,0,0,12"/>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource ModeCard}">
                                    <Style.Triggers><DataTrigger Binding="{Binding IsScreenAccurate}" Value="True"><Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/><Setter Property="Background" Value="{DynamicResource App.Brush.AccentSubtle}"/></DataTrigger></Style.Triggers>
                                </Style>
                            </Border.Style>
                            <RadioButton GroupName="Mode" IsChecked="{Binding IsScreenAccurate}">
                                <Grid Margin="6,0,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <iconPacks:PackIconMaterial Kind="MonitorScreenshot" Width="20" Height="20" Foreground="{DynamicResource App.Brush.Accent}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.ScreenAccurate}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.ScreenAccurate.Help}" Style="{StaticResource Description}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </RadioButton>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource ModeCard}">
                                    <Style.Triggers><DataTrigger Binding="{Binding IsMotionFaithful}" Value="True"><Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/><Setter Property="Background" Value="{DynamicResource App.Brush.AccentSubtle}"/></DataTrigger></Style.Triggers>
                                </Style>
                            </Border.Style>
                            <RadioButton GroupName="Mode" IsChecked="{Binding IsMotionFaithful}">
                                <Grid Margin="6,0,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <iconPacks:PackIconMaterial Kind="CursorMove" Width="20" Height="20" Foreground="{DynamicResource App.Brush.Accent}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.MotionFaithful}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.MotionFaithful.Help}" Style="{StaticResource Description}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </RadioButton>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource ModeCard}">
                                    <Setter Property="Margin" Value="0"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsClicksOnly}" Value="True"><Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/><Setter Property="Background" Value="{DynamicResource App.Brush.AccentSubtle}"/></DataTrigger></Style.Triggers>
                                </Style>
                            </Border.Style>
                            <RadioButton GroupName="Mode" IsChecked="{Binding IsClicksOnly}">
                                <Grid Margin="6,0,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <iconPacks:PackIconMaterial Kind="CursorDefaultClick" Width="20" Height="20" Foreground="{DynamicResource App.Brush.Accent}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.ClicksOnly}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.ClicksOnly.Help}" Style="{StaticResource Description}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </RadioButton>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <iconPacks:PackIconMaterial Kind="TuneVariant" Width="18" Height="18" Foreground="{DynamicResource App.Brush.Accent}" Margin="0,0,9,0"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.Precision}" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.Recommendation}" Style="{StaticResource Description}" Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,10">
                                <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.IntervalMs}" FontWeight="SemiBold"/>
                                <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.Interval.Help}" Style="{StaticResource Description}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <mah:NumericUpDown Grid.Column="1" Value="{Binding MinimumIntervalMilliseconds}" Minimum="0" Maximum="1000" Interval="0.25" StringFormat="{}{0:0.###}" Margin="0,0,0,10"/>
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.Distance}" FontWeight="SemiBold"/>
                                <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.Distance.Help}" Style="{StaticResource Description}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <mah:NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding MinimumDistancePixels}" Minimum="0" Maximum="10000" Interval="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <iconPacks:PackIconMaterial Kind="KeyboardSettingsOutline" Width="18" Height="18" Foreground="{DynamicResource App.Brush.Accent}" Margin="0,0,9,0"/>
                            <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.Inputs}" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <Border Style="{StaticResource OptionCard}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.Hotkey}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding HotkeyDisplay}" Foreground="{DynamicResource App.Brush.Accent}" FontSize="14" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                    <TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.Hotkey.Help}" Style="{StaticResource Description}" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="{loc:Translate Key=Ui.Macro.Recording.Hotkey.Capture}"
                                        Style="{StaticResource ButtonSecondary}" Click="CaptureHotkey_Click" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource OptionCard}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.Keyboard}" VerticalAlignment="Center"/><CheckBox Grid.Column="1" IsChecked="{Binding RecordKeyboard}" VerticalAlignment="Center"/></Grid></Border>
                        <Border Style="{StaticResource OptionCard}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.MouseButtons}" VerticalAlignment="Center"/><CheckBox Grid.Column="1" IsChecked="{Binding RecordMouseButtons}" VerticalAlignment="Center"/></Grid></Border>
                        <Border Style="{StaticResource OptionCard}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Margin="0,0,16,0"><TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.AutoGroups}"/><TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.AutoGroups.Help}" Style="{StaticResource Description}" Margin="0,2,0,0"/></StackPanel><CheckBox Grid.Column="1" IsChecked="{Binding AutomaticMovementGroups}" VerticalAlignment="Center"/></Grid></Border>
                        <Border Style="{StaticResource OptionCard}" Margin="0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Margin="0,0,16,0"><TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.RemoveStop}"/><TextBlock Text="{loc:Translate Key=Ui.Macro.Recording.RemoveStop.Help}" Style="{StaticResource Description}" Margin="0,2,0,0"/></StackPanel><CheckBox Grid.Column="1" IsChecked="{Binding RemoveStopGesture}" VerticalAlignment="Center"/></Grid></Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Border Height="1" Background="{DynamicResource App.Brush.CardBorder}" VerticalAlignment="Top"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="{loc:Translate Key=Ui.Common.Cancel}" Style="{StaticResource ButtonSecondary}" Click="Cancel_Click" IsCancel="True" MinWidth="96" Margin="0,0,8,0"/>
                <Button Content="{loc:Translate Key=Common.Apply}" Style="{StaticResource ButtonPrimary}" Click="Apply_Click" IsDefault="True" MinWidth="110"/>
            </StackPanel>
        </Grid>
    </Grid>
</mah:MetroWindow>
