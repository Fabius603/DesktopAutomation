<UserControl xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" x:Class="DesktopAutomationApp.Views.MakroStepsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DesktopAutomationApp.ViewModels"
             xmlns:mak="clr-namespace:TaskAutomation.Makros;assembly=TaskAutomation"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:conv="clr-namespace:DesktopAutomationApp.Converters"
             xmlns:behaviors="clr-namespace:DesktopAutomationApp.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Style="{StaticResource ContentViewBase}">
    <UserControl.Resources>
        <ResourceDictionary Source="/Resources/Makros/MakroStepTemplates.xaml"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonPrimary}" Command="{Binding StartMakroCommand}"
                        Visibility="{Binding IsMakroRunning, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                        ToolTip="{loc:Translate Key=Ui.Macro.Steps.RunMacro}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{loc:Translate Common.Execute}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonDanger}" Command="{Binding StopMakroCommand}"
                        Visibility="{Binding IsMakroRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                        ToolTip="{loc:Translate Key=Ui.Macro.Steps.StopMacro}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Stop" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.Stop}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Border Style="{StaticResource ToolbarSeparator}"/>
                <Button Style="{StaticResource ButtonPrimary}" Command="{Binding SaveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.Save}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding CancelCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Cancel" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.Discard}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding BackCommand}" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.Back}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}" Margin="0,0,12,0"/>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding RenameCommand}" Margin="0,0,12,0" ToolTip="{loc:Translate Key=Ui.Common.Rename}">
                    <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                </Button>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding OpenFileCommand}" Margin="0,0,12,0" ToolTip="{loc:Translate Key=Ui.Logs.OpenFile}">
                    <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14"/>
                </Button>
                <Border Style="{StaticResource CountBadge}" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Steps.Count, StringFormat='({0})'}"
                               Foreground="{DynamicResource App.Brush.Accent}"
                               FontSize="13"/>
                </Border>
            </StackPanel>
        </DockPanel>

        <!-- Card mit Inhalt -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <DockPanel>

                <!-- Toolbar -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">

                    <Button Style="{StaticResource ButtonPrimary}" Command="{Binding AddStepCommand}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Translate Key=Ui.Common.NewStep}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Style="{StaticResource ToolbarSeparator}"/>

                    <!-- Aufnahme starten/stoppen -->
                    <Button Command="{Binding RecordStepsCommand}"
                            Content="{Binding RecordButtonText}"
                            Margin="0,0,8,0"
                            FontSize="13"
                            Focusable="False"
                            IsTabStop="False"
                            IsDefault="False"
                            IsCancel="False"
                            ClickMode="Release">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ButtonToolbar}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource App.Brush.Accent}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Einzelklick erfassen -->
                    <Button Command="{Binding CaptureClickCommand}"
                            Content="{Binding CaptureClickButtonText}"
                            Margin="0,0,8,0"
                            FontSize="13"
                            Focusable="False"
                            IsTabStop="False"
                            IsDefault="False"
                            IsCancel="False"
                            ClickMode="Release">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ButtonToolbar}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCapturingClick}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Background" Value="{DynamicResource App.Brush.Accent}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Mauspfad umschalten -->
                    <Button Command="{Binding ToggleMousePathCommand}"
                            Content="{Binding RecordMousePathText}"
                            Margin="0,0,0,0"
                            FontSize="13"
                            ToolTip="{loc:Translate Key=Ui.Macro.Steps.ToggleRecordMousePathOrClicksOnly}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ButtonToolbar}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecordMousePath}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource App.Brush.Accent}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextPrimary}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Border Style="{StaticResource ToolbarSeparator}"/>

                    <!-- Vorschau -->
                    <Button Style="{StaticResource ButtonToolbar}" Command="{Binding PreviewOverviewCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Eye" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Translate Key=Ui.Macro.Steps.Overview}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ButtonToolbar}" Command="{Binding PreviewPlaybackCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Translate Key=Ui.Macro.Steps.Sequence}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ButtonToolbar}" Command="{Binding PreviewStopCommand}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Stop" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Translate Key=Ui.Common.Stop}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Steps-Liste -->
                <ListBox x:Name="StepsList"
                         ItemsSource="{Binding Steps}"
                         SelectionMode="Extended"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingStackPanel.ScrollUnit="Pixel"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         SelectionChanged="StepsList_SelectionChanged"
                         ItemContainerStyle="{StaticResource StepCardListBoxItemStyle}"
                         behaviors:StepDragDrop.MoveCommand="{Binding ReorderStepCommand}">

                    <ListBox.InputBindings>
                        <KeyBinding Key="Delete"             Command="{Binding DeleteSelectedCommand}"/>
                        <KeyBinding Key="C" Modifiers="Ctrl" Command="{Binding CopyCommand}"/>
                        <KeyBinding Key="V" Modifiers="Ctrl" Command="{Binding PasteCommand}"/>
                        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}"/>
                        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}"/>
                    </ListBox.InputBindings>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Grid.IsSharedSizeScope="True">
                                <Grid.ToolTip><ToolTip Content="{Binding ValidationMessage}"/></Grid.ToolTip>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                <Setter Property="Background" Value="#30FF0000"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Schrittnummer -->
                                <TextBlock Grid.Column="0"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           VerticalAlignment="Top"
                                           Margin="0,0,12,0"
                                           Foreground="{DynamicResource MahApps.Brushes.Accent}">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource StepNumberConverter}">
                                            <Binding/>
                                            <Binding RelativeSource="{RelativeSource AncestorType=ListBox}" Path="ItemsSource"/>
                                            <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>

                                <!-- Inhalt via implizite DataTemplates -->
                                <StackPanel Grid.Column="1">
                                    <ContentPresenter Content="{Binding}"/>
                                </StackPanel>

                                <!-- Aktionen -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Margin="8,0,0,0">
                                    <Button Style="{StaticResource ButtonIcon}" Margin="0,0,6,0"
                                            ToolTip="{loc:Translate Key=Ui.Common.EditStep}"
                                            Command="{Binding DataContext.EditStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="Pencil"/>
                                    </Button>
                                    <Button Style="{StaticResource ButtonIcon}" Margin="0,0,6,0"
                                            ToolTip="{loc:Translate Key=Ui.Common.MoveStepUp}"
                                            Command="{Binding DataContext.MoveStepUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="ArrowUp"/>
                                    </Button>
                                    <Button Style="{StaticResource ButtonIcon}" Margin="0,0,6,0"
                                            ToolTip="{loc:Translate Key=Ui.Common.MoveStepDown}"
                                            Command="{Binding DataContext.MoveStepDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="ArrowDown"/>
                                    </Button>
                                    <Button Style="{StaticResource ButtonIcon}" Margin="0,0,6,0"
                                            ToolTip="{loc:Translate Key=Ui.Macro.Steps.DuplicateStep}"
                                            Command="{Binding DataContext.DuplicateStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="ContentDuplicate"/>
                                    </Button>
                                    <Button Style="{StaticResource ButtonIconDanger}"
                                            ToolTip="{loc:Translate Key=Ui.Macro.Steps.DeleteStep}"
                                            Command="{Binding DataContext.DeleteStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="Delete"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>
    </Grid>
</UserControl>
