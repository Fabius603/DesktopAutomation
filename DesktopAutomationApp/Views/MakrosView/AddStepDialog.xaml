<mah:MetroWindow xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" x:Class="DesktopAutomationApp.Views.AddStepDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 Title="{Binding DialogTitle}" Height="350" Width="480"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize" ShowInTaskbar="False"
                 Style="{StaticResource DialogWindowStyle}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Typauswahl -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="{loc:Translate Key=Ui.Macro.StepEditor.Type}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Width="180" ItemsSource="{Binding StepTypes}" SelectedItem="{Binding SelectedType}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource MacroStepTypeConverter}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <!-- Dynamische Felder -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <!-- Maus: X/Y (Absolute) -->
            <StackPanel Orientation="Horizontal" Visibility="{Binding ShowMouseXY, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{loc:Translate Key=Ui.Macro.StepEditor.X}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Width="60" Text="{Binding X}"/>
                <TextBlock Text="{loc:Translate Key=Ui.Macro.StepEditor.Y}" VerticalAlignment="Center" Margin="8,0,4,0"/>
                <TextBox Width="60" Text="{Binding Y}"/>
            </StackPanel>

            <!-- Maus: DeltaX/DeltaY (Relativ) -->
            <StackPanel Orientation="Horizontal" Visibility="{Binding ShowMouseDelta, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{loc:Translate Key=Ui.Macro.StepEditor.DeltaX}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Width="60" Text="{Binding DeltaX}"/>
                <TextBlock Text="{loc:Translate Key=Ui.Macro.StepEditor.DeltaY}" VerticalAlignment="Center" Margin="8,0,4,0"/>
                <TextBox Width="60" Text="{Binding DeltaY}"/>
            </StackPanel>

            <!-- Maus: Button -->
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Visibility="{Binding ShowMouseButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{loc:Translate Key=Ui.Macro.StepEditor.Button}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="100" SelectedValuePath="Content" SelectedValue="{Binding MouseButton}">
                    <ComboBoxItem Content="{loc:Translate Key=Ui.Macro.StepEditor.Left}"/>
                    <ComboBoxItem Content="{loc:Translate Key=Ui.Macro.StepEditor.Right}"/>
                    <ComboBoxItem Content="{loc:Translate Key=Ui.Macro.StepEditor.Middle}"/>
                </ComboBox>
            </StackPanel>

            <!-- Key -->
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
            Visibility="{Binding ShowKey, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{loc:Translate Key=Ui.Macro.StepEditor.Key}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Width="160" IsReadOnly="True" VerticalAlignment="Center"
               Text="{Binding Key}" />
                <Button Command="{Binding CaptureKeyCommand}" Margin="8,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ButtonSecondary}">
                            <Setter Property="Content" Value="Aufnehmen"/>
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                    <Setter Property="Content" Value="Aufnahme läuft..."/>
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Timeout -->
            <Grid Margin="0,8,0,0" Visibility="{Binding ShowDuration, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/><ColumnDefinition Width="74"/></Grid.ColumnDefinitions>
                <TextBlock Text="{loc:Translate Key=Ui.Macro.StepEditor.Duration}" VerticalAlignment="Center"/>
                <mah:NumericUpDown Grid.Column="1" Value="{Binding DurationValue}" Minimum="0" Maximum="1000000" Interval="1" StringFormat="{}{0:0.###}"/>
                <ComboBox Grid.Column="2" ItemsSource="{Binding DurationUnits}" SelectedItem="{Binding SelectedDurationUnit}" DisplayMemberPath="Label" Margin="8,0,0,0"/>
            </Grid>

            <Border Height="1" Background="{DynamicResource App.Brush.CardBorder}" Margin="0,14,0,12"/>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/><ColumnDefinition Width="74"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{loc:Translate Key=Ui.Macro.StepEditor.DelayBefore}" FontWeight="SemiBold"/>
                    <TextBlock Text="{loc:Translate Key=Ui.Macro.StepEditor.DelayBefore.Help}" FontSize="11"
                               Foreground="{DynamicResource App.Brush.TextMuted}" TextWrapping="Wrap"/>
                </StackPanel>
                <mah:NumericUpDown Grid.Column="1" Value="{Binding DelayBeforeValue, TargetNullValue=''}" Minimum="0" Maximum="1000000" Interval="1" StringFormat="{}{0:0.###}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="2" ItemsSource="{Binding DelayUnits}" SelectedItem="{Binding SelectedDelayUnit}" DisplayMemberPath="Label" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="2">
        <TextBlock Text="{Binding ValidationError}" Foreground="#FFD13438" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,180,0"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{loc:Translate Key=Ui.Common.Cancel}" IsCancel="True" Margin="0,0,8,0" Click="Cancel_Click" Style="{StaticResource ButtonSecondary}"/>
            <Button Content="{Binding ConfirmButtonText}" IsDefault="True" Click="Ok_Click" Style="{StaticResource ButtonPrimary}"/>
        </StackPanel>
        </Grid>
    </Grid>
</mah:MetroWindow>
