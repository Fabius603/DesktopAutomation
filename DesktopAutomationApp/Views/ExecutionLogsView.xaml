<UserControl x:Class="DesktopAutomationApp.Views.ExecutionLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Style="{StaticResource ContentViewBase}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding RefreshCommand}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Aktualisieren" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding OpenLogFileCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="FileDocumentOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Datei öffnen" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <TextBlock Text="Job-Logs" Style="{StaticResource PageTitle}"/>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <DockPanel Margin="12">
                    <TextBlock DockPanel.Dock="Top" Text="Ausführungen" Style="{StaticResource Heading2}" Margin="0,0,0,8"/>
                    <ListBox ItemsSource="{Binding Sessions}"
                             SelectedItem="{Binding SelectedSession}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBox}" Margin="0,0,0,6">
                                    <StackPanel Margin="10,8">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding StatusText}"
                                                       Foreground="{DynamicResource App.Brush.Accent}"
                                                       FontSize="11"
                                                       Margin="8,0,0,0"/>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding StartedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                   Foreground="{DynamicResource App.Brush.TextMuted}"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <DockPanel Margin="12">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Level" VerticalAlignment="Center" Foreground="{DynamicResource App.Brush.TextMuted}" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding AvailableLevels}"
                                      SelectedItem="{Binding SelectedMinimumLevel}"
                                      MinWidth="150"/>
                        </StackPanel>
                        <TextBlock Text="Live-Log" Style="{StaticResource Heading2}" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ListBox x:Name="LogEntriesList"
                             ItemsSource="{Binding Entries}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBox}" Margin="0,0,0,6">
                                    <Grid Margin="10,8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss.fff}'}"
                                                   Foreground="{DynamicResource App.Brush.TextMuted}"
                                                   FontFamily="Consolas"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding Level}"
                                                   Foreground="{DynamicResource App.Brush.Accent}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2"
                                                   Text="{Binding StepType}"
                                                   Foreground="{DynamicResource App.Brush.TextMuted}"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                   Text="{Binding Message}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,5,0,0"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                                   Text="{Binding DisplayDetails}"
                                                   Foreground="{DynamicResource App.Brush.TextMuted}"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
