<UserControl xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" x:Class="DesktopAutomationApp.Views.AutomationDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Style="{StaticResource ContentViewBase}">
    <UserControl.Resources>
        <Style x:Key="AutomationExpanderToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="HeaderBorder" Background="Transparent" CornerRadius="4" Padding="6,5">
                            <DockPanel>
                                <TextBlock x:Name="Arrow" Text="{loc:Translate Key=Ui.Common.ChevronRight}" FontSize="20" Margin="0,0,8,0"
                                           VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform><RotateTransform Angle="0"/></TextBlock.RenderTransform>
                                </TextBlock>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform"><Setter.Value><RotateTransform Angle="90"/></Setter.Value></Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource App.Brush.SurfaceHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AutomationExpanderStyle" TargetType="Expander">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <ToggleButton Grid.Row="0" Style="{StaticResource AutomationExpanderToggleStyle}"
                                          Content="{TemplateBinding Header}"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>
                            <ContentPresenter x:Name="ContentSite" Grid.Row="1" ContentSource="Content" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True"><Setter TargetName="ContentSite" Property="Visibility" Value="Visible"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonPrimary}" Command="{Binding SaveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.Save}"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding CancelCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Cancel" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.Discard}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding BackCommand}" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.Back}"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}" Margin="0,0,12,0"/>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding RenameCommand}" ToolTip="{loc:Translate Key=Ui.Common.Rename}">
                    <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                </Button>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding OpenFileCommand}" Margin="8,0,0,0" ToolTip="{loc:Translate Key=Ui.Logs.OpenFile}">
                    <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14"/>
                </Button>
            </StackPanel>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,12,0">
                <Expander Style="{StaticResource AutomationExpanderStyle}" IsExpanded="True" Margin="0,0,0,12">
                    <Expander.Header>
                        <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.General}" Style="{StaticResource Heading2}" Margin="4,6"/>
                    </Expander.Header>
                    <Border Style="{StaticResource CardBorderStyle}">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Text="{loc:Translate Key=Ui.Automation.Details.Description}" VerticalAlignment="Top"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditedAutomation.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="54" MaxHeight="120" MaxLength="500" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                        <TextBlock Grid.Row="1" Text="{loc:Translate Key=Ui.Automation.Details.Active}" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding EditedAutomation.Active, Mode=TwoWay}"
                                  Margin="0,10,0,0" VerticalAlignment="Center"/>
                    </Grid>
                    </Border>
                </Expander>

                <Expander Style="{StaticResource AutomationExpanderStyle}" IsExpanded="True" Margin="0,0,0,12">
                    <Expander.Header>
                        <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.Trigger}" Style="{StaticResource Heading2}" Margin="4,6"/>
                    </Expander.Header>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Text="{loc:Translate Key=Ui.Automation.Details.TriggerType}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding TriggerKinds}"
                                      SelectedItem="{Binding EditedAutomation.TriggerKind, Mode=TwoWay}" MinWidth="240">
                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource LocalizedEnumConverter}}"/></DataTemplate></ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TriggerDescription}"
                                       TextWrapping="Wrap" MaxWidth="720" HorizontalAlignment="Left"
                                       Foreground="{DynamicResource App.Brush.TextMuted}" Margin="0,7,0,2"/>

                            <TextBlock Grid.Row="2" Text="{loc:Translate Key=Ui.Automation.Details.Hotkey}" VerticalAlignment="Center" Margin="0,10,0,0"
                                       Visibility="{Binding EditedAutomation.IsHotkeyTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0"
                                        Visibility="{Binding EditedAutomation.IsHotkeyTrigger, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBox IsReadOnly="True" Width="240" Text="{Binding EditedAutomation.DisplayTrigger, Mode=OneWay}"/>
                                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding CaptureHotkeyCommand}" Margin="8,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Keyboard" Width="14" Height="14" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.CaptureHotkey}"/>
                                    </StackPanel>
                                </Button>
                                <mah:ProgressRing IsActive="{Binding IsCapturingHotkey}" Width="20" Height="20" Margin="10,0,0,0"
                                                  Visibility="{Binding IsCapturingHotkey, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <TextBlock Text="{Binding HotkeyCaptureStatus}" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{DynamicResource App.Brush.Accent}"
                                           Visibility="{Binding IsCapturingHotkey, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="3" Text="{loc:Translate Key=Ui.Automation.Details.Execution}" VerticalAlignment="Center" Margin="0,10,0,0"
                                       Visibility="{Binding EditedAutomation.IsOnceAtTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <mah:DateTimePicker Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Width="230" HorizontalAlignment="Left"
                                                Culture="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=CurrentCulture}"
                                                SelectedDateFormat="Short" SelectedTimeFormat="Short" IsClockVisible="False"
                                                LostKeyboardFocus="Picker_LostKeyboardFocus" Tag="RunAt|Required" SelectedDateTime="{Binding EditedAutomation.RunAt, Mode=TwoWay}"
                                                Visibility="{Binding EditedAutomation.IsOnceAtTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <TextBlock Grid.Row="3" Text="{loc:Translate Key=Ui.Automation.Details.TimeAndDays}" VerticalAlignment="Top" Margin="0,16,0,0"
                                       Visibility="{Binding EditedAutomation.IsScheduleTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,10,0,0"
                                        Visibility="{Binding EditedAutomation.IsScheduleTrigger, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <mah:TimePicker LostKeyboardFocus="Picker_LostKeyboardFocus" Tag="ScheduleTime|Required" SelectedTimeFormat="Short" IsClockVisible="False"
                                                Culture="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=CurrentCulture}"
                                                SelectedDateTime="{Binding EditedAutomation.ScheduleTime, Mode=TwoWay}"
                                                Width="150" HorizontalAlignment="Left"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <CheckBox Content="{loc:Translate Key=Ui.Automation.Details.Mon}" IsChecked="{Binding EditedAutomation.Monday}" Margin="0,0,10,0"/>
                                    <CheckBox Content="{loc:Translate Key=Ui.Automation.Details.Tue}" IsChecked="{Binding EditedAutomation.Tuesday}" Margin="0,0,10,0"/>
                                    <CheckBox Content="{loc:Translate Key=Ui.Automation.Details.Wed}" IsChecked="{Binding EditedAutomation.Wednesday}" Margin="0,0,10,0"/>
                                    <CheckBox Content="{loc:Translate Key=Ui.Automation.Details.Thu}" IsChecked="{Binding EditedAutomation.Thursday}" Margin="0,0,10,0"/>
                                    <CheckBox Content="{loc:Translate Key=Ui.Automation.Details.Fri}" IsChecked="{Binding EditedAutomation.Friday}" Margin="0,0,10,0"/>
                                    <CheckBox Content="{loc:Translate Key=Ui.Automation.Details.Sat}" IsChecked="{Binding EditedAutomation.Saturday}" Margin="0,0,10,0"/>
                                    <CheckBox Content="{loc:Translate Key=Ui.Automation.Details.Sun}" IsChecked="{Binding EditedAutomation.Sunday}"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Grid.Row="4" Text="{loc:Translate Key=Ui.Automation.Details.Interval}" VerticalAlignment="Center" Margin="0,10,0,0"
                                       Visibility="{Binding EditedAutomation.IsIntervalTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0"
                                        Visibility="{Binding EditedAutomation.IsIntervalTrigger, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBox Text="{Binding EditedAutomation.IntervalValue, Mode=TwoWay}" Width="70"/>
                                <ComboBox ItemsSource="{Binding IntervalUnits}" SelectedItem="{Binding EditedAutomation.IntervalUnit, Mode=TwoWay}"
                                          Width="140" Margin="8,0,0,0">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource LocalizedEnumConverter}}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>
                                <CheckBox Content="{loc:Translate Key=Ui.Automation.Details.ImmediatelyAfterAppStart}" IsChecked="{Binding EditedAutomation.StartImmediately, Mode=TwoWay}"
                                          Margin="14,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Row="5" Text="{loc:Translate Key=Ui.Automation.Details.ProcessTrigger}" VerticalAlignment="Top" Margin="0,16,0,0"
                                       Visibility="{Binding EditedAutomation.IsProcessTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <Grid Grid.Row="5" Grid.Column="1" Margin="0,10,0,0"
                                  Visibility="{Binding EditedAutomation.IsProcessTrigger, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Translate Key=Ui.Common.ProcessName}" Margin="0,0,0,4"/>
                                    <ComboBox Text="{Binding EditedAutomation.ProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding AvailableProcessNames}"
                                              IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True" Height="34"
                                              mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Automation.Details.ProcessNamePlaceholder}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.WindowTitleContainsOptional}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditedAutomation.WindowTitleContains, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="34"
                                             mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Automation.Details.WindowTitlePlaceholder}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.DelayS}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditedAutomation.DelayAfterEventSeconds, Mode=TwoWay}" Height="34"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Row="6" Text="{loc:Translate Key=Ui.Automation.Details.WindowEvent}" VerticalAlignment="Top" Margin="0,16,0,0"
                                       Visibility="{Binding EditedAutomation.IsWindowEventTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <Grid Grid.Row="6" Grid.Column="1" Margin="0,10,0,0"
                                  Visibility="{Binding EditedAutomation.IsWindowEventTrigger, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.Event}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding WindowEventKinds}" SelectedItem="{Binding EditedAutomation.WindowEventKind, Mode=TwoWay}" Height="34">
                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource LocalizedEnumConverter}}"/></DataTemplate></ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.ProcessNameOptional}" Margin="0,0,0,4"/>
                                    <ComboBox Text="{Binding EditedAutomation.ProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding AvailableProcessNames}"
                                              IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True" Height="34"
                                              mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Automation.Details.ProcessNamePlaceholder}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.WindowTitleContainsOptional}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditedAutomation.WindowTitleContains, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="34"
                                             mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Automation.Details.WindowTitlePlaceholder}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="6">
                                    <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.DelayS}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditedAutomation.DelayAfterEventSeconds, Mode=TwoWay}" Height="34"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Row="7" Text="{loc:Translate Key=Ui.Automation.Details.FileSystemEvent}" VerticalAlignment="Top" Margin="0,16,0,0"
                                       Visibility="{Binding EditedAutomation.IsFileSystemEventTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <StackPanel Grid.Row="7" Grid.Column="1" Margin="0,10,0,0"
                                        Visibility="{Binding EditedAutomation.IsFileSystemEventTrigger, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding EditedAutomation.FileSystemPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="{loc:Translate Key=Ui.Automation.Details.FolderPath}"/>
                                    <Button Grid.Column="1" Style="{StaticResource ButtonSecondary}" Command="{Binding BrowseFileSystemFolderCommand}" Margin="8,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" Margin="0,0,6,0"/>
                                            <TextBlock Text="{loc:Translate Key=Ui.Common.Browse}"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/><ColumnDefinition Width="16"/><ColumnDefinition Width="150"/><ColumnDefinition Width="20"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.Event}" Margin="0,0,0,4"/>
                                        <ComboBox ItemsSource="{Binding FileSystemEventKinds}" SelectedItem="{Binding EditedAutomation.FileSystemEventKind, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource LocalizedEnumConverter}}"/></DataTemplate></ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.FileFilter}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding EditedAutomation.FileSystemFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                                        <CheckBox Content="{loc:Translate Key=Ui.Automation.Details.IncludeSubdirectories}" IsChecked="{Binding EditedAutomation.IncludeSubdirectories}"/>
                                        <CheckBox Content="{loc:Translate Key=Ui.Automation.Details.WaitUntilFileReady}" IsChecked="{Binding EditedAutomation.WaitUntilFileReady}" Margin="0,7,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <TextBlock Grid.Row="8" Text="{loc:Translate Key=Ui.Automation.Details.SystemEvent}" VerticalAlignment="Center" Margin="0,10,0,0"
                                       Visibility="{Binding EditedAutomation.IsSystemEventTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <ComboBox Grid.Row="8" Grid.Column="1" ItemsSource="{Binding SystemEventKinds}"
                                      SelectedItem="{Binding EditedAutomation.SystemEventKind, Mode=TwoWay}" Width="260" HorizontalAlignment="Left" Margin="0,10,0,0"
                                      Visibility="{Binding EditedAutomation.IsSystemEventTrigger, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource LocalizedEnumConverter}}"/></DataTemplate></ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </Border>
                </Expander>

                <Expander Style="{StaticResource AutomationExpanderStyle}" IsExpanded="True" Margin="0,0,0,12">
                    <Expander.Header>
                        <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.Action}" Style="{StaticResource Heading2}" Margin="4,6"/>
                    </Expander.Header>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid Margin="12">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.JobOrMacro}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding ActionsView}" DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedAction, Mode=TwoWay}" MinWidth="280">
                                <ComboBox.GroupStyle>
                                    <GroupStyle><GroupStyle.HeaderTemplate><DataTemplate>
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource App.Brush.Accent}" FontWeight="SemiBold" Margin="4"/>
                                    </DataTemplate></GroupStyle.HeaderTemplate></GroupStyle>
                                </ComboBox.GroupStyle>
                            </ComboBox>
                        </Grid>
                    </Border>
                </Expander>

                <Expander Style="{StaticResource AutomationExpanderStyle}" IsExpanded="True">
                    <Expander.Header>
                        <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.ExecutionRules}" Style="{StaticResource Heading2}" Margin="4,6"/>
                    </Expander.Header>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid Margin="12">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.IfAlreadyActive}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding RunningBehaviors}"
                                      SelectedItem="{Binding EditedAutomation.AlreadyRunningBehavior, Mode=TwoWay}"
                                      Width="200" HorizontalAlignment="Left">
                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource LocalizedEnumConverter}}"/></DataTemplate></ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Text="{loc:Translate Key=Ui.Automation.Details.Cooldown}" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBox Text="{Binding EditedAutomation.CooldownSeconds, Mode=TwoWay}" Width="80"/>
                                <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.Seconds}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Row="2" Text="{loc:Translate Key=Ui.Automation.Details.ActiveFrom}" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
                                <mah:TimePicker LostKeyboardFocus="Picker_LostKeyboardFocus" Tag="EnabledFrom|Optional" SelectedTimeFormat="Short" IsClockVisible="False"
                                                Culture="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=CurrentCulture}"
                                                SelectedDateTime="{Binding EditedAutomation.EnabledFrom, Mode=TwoWay}" Width="150"/>
                                <TextBlock Text="{loc:Translate Key=Ui.Automation.Details.ActiveUntil}" VerticalAlignment="Center" Margin="14,0,8,0"/>
                                <mah:TimePicker LostKeyboardFocus="Picker_LostKeyboardFocus" Tag="EnabledUntil|Optional" SelectedTimeFormat="Short" IsClockVisible="False"
                                                Culture="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=CurrentCulture}"
                                                SelectedDateTime="{Binding EditedAutomation.EnabledUntil, Mode=TwoWay}" Width="150"
                                                ToolTip="{loc:Translate Key=Ui.Automation.Details.TimeWindowsSpanningMidnightAreSupported}"/>
                                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding ClearActiveWindowCommand}" Margin="8,0,0,0"
                                        ToolTip="{loc:Translate Key=Ui.Automation.Details.ClearActiveWindow}">
                                    <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
