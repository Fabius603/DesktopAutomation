<UserControl xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" x:Class="DesktopAutomationApp.Views.JobStepsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DesktopAutomationApp.ViewModels"
             xmlns:jobs="clr-namespace:TaskAutomation.Jobs;assembly=TaskAutomation"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:DesktopAutomationApp.Converters"
             xmlns:behaviors="clr-namespace:DesktopAutomationApp.Behaviors"
             mc:Ignorable="d"
             Style="{StaticResource ContentViewBase}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Jobs/JobStepTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:JobStepDetailsConverter x:Key="JobStepDetailsConverter"/>
            <conv:StepHasDetailsConverter x:Key="StepHasDetailsConverter"/>
            <conv:StepBlockShapeConverter x:Key="StepBlockShapeConverter"/>
            <conv:StepCanAddBranchesConverter x:Key="StepCanAddBranchesConverter"/>
            <conv:StepDetailsEnabledConverter x:Key="StepDetailsEnabledConverter"/>
            <conv:StepBlockVisualConverter x:Key="StepBlockVisualConverter"/>
            <conv:StepRegularSummaryVisibilityConverter x:Key="StepRegularSummaryVisibilityConverter"/>
            <conv:StepBranchSummaryConverter x:Key="StepBranchSummaryConverter"/>
            <Style x:Key="JobStepSectionExpanderStyle" TargetType="Expander">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Expander">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ToggleButton Grid.Row="0"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              HorizontalContentAlignment="Stretch"
                                              Background="Transparent" BorderThickness="0" Padding="0"
                                              FocusVisualStyle="{x:Null}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <ContentPresenter HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Stretch"
                                                              Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                    <ContentPresenter Content="{TemplateBinding Header}"
                                                      ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                      HorizontalAlignment="Stretch"/>
                                </ToggleButton>
                                <ContentPresenter x:Name="SectionContent"
                                                  Grid.Row="1"
                                                  ContentSource="Content"
                                                  Visibility="Collapsed"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsExpanded" Value="True">
                                    <Setter TargetName="SectionContent" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="JobStepSectionHeaderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource App.Brush.SurfaceHover}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.CardBorder}"/>
                <Setter Property="BorderThickness" Value="0,1,0,1"/>
                <Setter Property="CornerRadius" Value="0"/>
                <Setter Property="Padding" Value="14,12"/>
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=Expander}}" Value="False"/>
                            <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#30FF0000"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Danger}"/>
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
            <DataTemplate x:Key="JobStepSectionCompactCardTemplate">
                <Border Margin="0,0,0,6" Padding="12,9" CornerRadius="6" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource App.Brush.CardBackground}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.CardBorder}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                    <Setter Property="Background" Value="#30FF0000"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Danger}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontWeight="Bold" FontSize="13" Margin="0,0,2,0"
                                   VerticalAlignment="Center" Foreground="{DynamicResource MahApps.Brushes.Accent}">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource StepNumberConverter}">
                                    <Binding/>
                                    <Binding Path="DataContext.AllJobSteps" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Grid.Column="1" Text="{Binding Converter={StaticResource StepDisplayNameConverter}}"
                                   FontWeight="SemiBold" FontSize="14"/>
                        <Button Grid.Column="2" Style="{StaticResource ButtonIcon}" Margin="8,0,2,0"
                                ToolTip="{loc:Translate Key=Ui.Common.Ellipsis}"
                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Click="StepMoreButton_Click">
                            <iconPacks:PackIconMaterial Kind="DotsVertical"/>
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{loc:Translate Key=Ui.Common.MoveStepUp}"
                                              Command="{Binding PlacementTarget.Tag.MoveStepUpCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="{loc:Translate Key=Ui.Common.MoveStepDown}"
                                              Command="{Binding PlacementTarget.Tag.MoveStepDownCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="{loc:Translate Key=Ui.Job.Steps.MoveToStart}"
                                              Command="{Binding PlacementTarget.Tag.MoveToStartSectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="{loc:Translate Key=Ui.Job.Steps.MoveToRun}"
                                              Command="{Binding PlacementTarget.Tag.MoveToRunSectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="{loc:Translate Key=Ui.Job.Steps.MoveToEnd}"
                                              Command="{Binding PlacementTarget.Tag.MoveToEndSectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="{loc:Translate Key=Ui.Job.Steps.DeleteStep}"
                                              Command="{Binding PlacementTarget.Tag.DeleteStepCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <iconPacks:PackIconMaterial Grid.Column="3" Kind="AlertCircleOutline"
                                                    Width="16" Height="16" Margin="8,0,0,0"
                                                    Foreground="{DynamicResource App.Brush.Danger}"
                                                    ToolTip="{Binding ValidationError}"
                                                    Visibility="{Binding IsValid, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                    </Grid>
                </Border>
            </DataTemplate>
            <Style x:Key="JobStepCompactListItemStyle" TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style x:Key="JobStepCardListBoxItemStyle" TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin">
                    <Setter.Value>
                        <MultiBinding Converter="{StaticResource StepBlockVisualConverter}" ConverterParameter="itemMargin">
                            <Binding/>
                            <Binding Path="ItemsSource" RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                            <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                        </MultiBinding>
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Frame" BorderBrush="{DynamicResource App.Brush.CardBorder}" SnapsToDevicePixels="True">
                                <Border.Background><MultiBinding Converter="{StaticResource StepBlockVisualConverter}" ConverterParameter="frameBackground"><Binding/><Binding Path="ItemsSource" RelativeSource="{RelativeSource AncestorType=ListBox}"/><Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/></MultiBinding></Border.Background>
                                <Border.BorderThickness><MultiBinding Converter="{StaticResource StepBlockVisualConverter}" ConverterParameter="frameBorder"><Binding/><Binding Path="ItemsSource" RelativeSource="{RelativeSource AncestorType=ListBox}"/><Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/></MultiBinding></Border.BorderThickness>
                                <Border.CornerRadius><MultiBinding Converter="{StaticResource StepBlockVisualConverter}" ConverterParameter="frameCorner"><Binding/><Binding Path="ItemsSource" RelativeSource="{RelativeSource AncestorType=ListBox}"/><Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/></MultiBinding></Border.CornerRadius>
                                <Border x:Name="Card" BorderBrush="{DynamicResource App.Brush.CardBorder}" Padding="0">
                                    <Border.Margin><MultiBinding Converter="{StaticResource StepBlockVisualConverter}" ConverterParameter="cardMargin"><Binding/><Binding Path="ItemsSource" RelativeSource="{RelativeSource AncestorType=ListBox}"/><Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/></MultiBinding></Border.Margin>
                                    <Border.Background><MultiBinding Converter="{StaticResource StepBlockVisualConverter}" ConverterParameter="cardBackground"><Binding/><Binding Path="ItemsSource" RelativeSource="{RelativeSource AncestorType=ListBox}"/><Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/></MultiBinding></Border.Background>
                                    <Border.BorderThickness><MultiBinding Converter="{StaticResource StepBlockVisualConverter}" ConverterParameter="cardBorder"><Binding/><Binding Path="ItemsSource" RelativeSource="{RelativeSource AncestorType=ListBox}"/><Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/></MultiBinding></Border.BorderThickness>
                                    <Border.CornerRadius><MultiBinding Converter="{StaticResource StepBlockVisualConverter}" ConverterParameter="cardCorner"><Binding/><Binding Path="ItemsSource" RelativeSource="{RelativeSource AncestorType=ListBox}"/><Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/></MultiBinding></Border.CornerRadius>
                                    <ContentPresenter/>
                                </Border>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/><Setter TargetName="Card" Property="Background" Value="{DynamicResource App.Brush.SurfaceHover}"/></Trigger>
                                <Trigger Property="IsSelected" Value="True"><Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/><Setter TargetName="Card" Property="Background" Value="{DynamicResource App.Brush.AccentSubtle}"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: Zurück + Titel + Add + Save + Cancel -->
        <DockPanel Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonPrimary}" Command="{Binding StartJobCommand}"
                        Visibility="{Binding IsJobRunning, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                        ToolTip="{loc:Translate Key=Ui.Job.Steps.StartJob}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{loc:Translate Common.Execute}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonDanger}" Command="{Binding StopJobCommand}"
                        Visibility="{Binding IsJobRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                        ToolTip="{loc:Translate Key=Ui.Job.Steps.StopJob}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Stop" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.Stop}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Border Style="{StaticResource ToolbarSeparator}"/>
                <Button Style="{StaticResource ButtonPrimary}" Command="{Binding SaveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.Save}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding CancelCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Cancel" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.Discard}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Border Style="{StaticResource ToolbarSeparator}"/>
                <Button Style="{StaticResource ButtonPrimary}"
                        Command="{Binding AddStepCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.NewStep}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonSecondary}"
                        Command="{Binding BackCommand}"
                        Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.Back}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}" Margin="0,0,12,0"/>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding RenameCommand}" ToolTip="{loc:Translate Key=Ui.Common.Rename}">
                    <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                </Button>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding OpenFileCommand}" Margin="8,0,0,0" ToolTip="{loc:Translate Key=Ui.Logs.OpenFile}">
                    <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14"/>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Drei Lebenszyklus-Bereiche des Jobs. -->
        <Border Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <Expander Style="{StaticResource JobStepSectionExpanderStyle}" AllowDrop="True"
                          Tag="{Binding StartSteps}"
                          DragEnter="StepSection_DragEnter" DragOver="StepSection_DragOver"
                          DragLeave="StepSection_DragLeave" Drop="StepSection_Drop"
                          IsExpanded="{Binding IsStartSectionExpanded, Mode=TwoWay}">
                    <Expander.Header>
                        <Border Style="{StaticResource JobStepSectionHeaderStyle}" Tag="{Binding HasStartStepErrors}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <iconPacks:PackIconMaterial Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <iconPacks:PackIconMaterial.Style><Style TargetType="iconPacks:PackIconMaterial"><Setter Property="Kind" Value="ChevronRight"/><Style.Triggers><DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=Expander}}" Value="True"><Setter Property="Kind" Value="ChevronDown"/></DataTrigger></Style.Triggers></Style></iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                                <TextBlock Grid.Column="1" Text="{loc:Translate Key=Ui.Job.Steps.Section.Start}" FontWeight="SemiBold" FontSize="15"/>
                                <TextBlock Grid.Column="2" Text="{Binding StartSteps.Count}" Opacity="0.7" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>
                    </Expander.Header>
                    <Border Margin="14,8">
                        <Grid>
                            <TextBlock Text="{loc:Translate Key=Ui.Job.Steps.Section.Start.Empty}"
                                       TextWrapping="Wrap" Opacity="0.65" Margin="12,8"
                                       Visibility="{Binding HasStartSteps, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                            <ListBox x:Name="StartStepsList" ItemsSource="{Binding StartSteps}"
                                     MinHeight="48" Background="Transparent" BorderThickness="0"
                                     SelectionMode="Extended"
                                     SelectionChanged="StepsList_SelectionChanged"
                                     MouseDoubleClick="StepsList_MouseDoubleClick"
                                     ItemContainerStyle="{StaticResource JobStepCardListBoxItemStyle}"
                                     ItemTemplate="{Binding ItemTemplate, ElementName=StepsList}"
                                    behaviors:StepDragDrop.MoveCommand="{Binding ReorderStepCommand}"/>
                        </Grid>
                    </Border>
                </Expander>

                <Expander Style="{StaticResource JobStepSectionExpanderStyle}" AllowDrop="True"
                          Tag="{Binding Steps}"
                          DragEnter="StepSection_DragEnter" DragOver="StepSection_DragOver"
                          DragLeave="StepSection_DragLeave" Drop="StepSection_Drop"
                          IsExpanded="{Binding IsRunSectionExpanded, Mode=TwoWay}">
                    <Expander.Header>
                        <Border Style="{StaticResource JobStepSectionHeaderStyle}" Tag="{Binding HasStepErrors}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <iconPacks:PackIconMaterial Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <iconPacks:PackIconMaterial.Style><Style TargetType="iconPacks:PackIconMaterial"><Setter Property="Kind" Value="ChevronRight"/><Style.Triggers><DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=Expander}}" Value="True"><Setter Property="Kind" Value="ChevronDown"/></DataTrigger></Style.Triggers></Style></iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                                <TextBlock Grid.Column="1" Text="{loc:Translate Key=Ui.Job.Steps.Section.Run}" FontWeight="SemiBold" FontSize="15"/>
                                <TextBlock Grid.Column="2" Text="{Binding Steps.Count}" Opacity="0.7" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>
                    </Expander.Header>
                    <StackPanel Margin="14,8">
                        <TextBlock Text="{loc:Translate Key=Ui.Job.Steps.Section.Run.Empty}"
                                   TextWrapping="Wrap" Opacity="0.65" Margin="12,8"
                                   Visibility="{Binding HasSteps, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                <!-- ListBox mit Hover-/Selected-Rahmen wie im Makro -->
                <ListBox x:Name="StepsList"
                         ItemsSource="{Binding Steps}"
                         SelectionMode="Extended"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingStackPanel.ScrollUnit="Pixel"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         SelectionChanged="StepsList_SelectionChanged"
                         MouseDoubleClick="StepsList_MouseDoubleClick"
                         Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{StaticResource JobStepCardListBoxItemStyle}"
                        behaviors:StepDragDrop.MoveCommand="{Binding ReorderStepCommand}">

                    <ListBox.InputBindings>
                        <KeyBinding Key="Delete"              Command="{Binding DeleteSelectedCommand}"/>
                        <KeyBinding Key="C" Modifiers="Ctrl"  Command="{Binding CopyCommand}"/>
                        <KeyBinding Key="V" Modifiers="Ctrl"  Command="{Binding PasteCommand}"/>
                        <KeyBinding Key="Z" Modifiers="Ctrl"  Command="{Binding UndoCommand}"/>
                        <KeyBinding Key="Y" Modifiers="Ctrl"  Command="{Binding RedoCommand}"/>
                    </ListBox.InputBindings>

                    <!-- Inhalt + Aktionsleiste rechts (Edit/Hoch/Runter/Delete exakt wie Makro) -->
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- Outer grid: coloured left bar | content -->
                            <Grid>
                                <Grid.ToolTip>
                                    <ToolTip Content="{Binding ValidationError}"/>
                                </Grid.ToolTip>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                <Setter Property="Background" Value="#30FF0000"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Compact card: overview first, full template only on demand. -->
                                <Grid Grid.Column="1" Grid.ColumnSpan="2" Margin="10,7,8,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="0"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   FontWeight="Bold"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource MahApps.Brushes.Accent}">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource StepNumberConverter}">
                                                    <Binding/>
                                                    <Binding Path="DataContext.AllJobSteps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Converter={StaticResource StepDisplayNameConverter}}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <iconPacks:PackIconMaterial Grid.Column="3" Kind="AlertCircleOutline"
                                                                    Width="16" Height="16" Margin="8,0,0,0"
                                                                    Foreground="{DynamicResource MahApps.Brushes.AccentBase}"
                                                                    ToolTip="{Binding ValidationError}"
                                                                    Visibility="{Binding IsValid, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0" ToolTip="{Binding ValidationError}"
                                                Visibility="{Binding Converter={StaticResource StepRegularSummaryVisibilityConverter}}">
                                        <TextBlock FontSize="11" Opacity="0.68" Text="{loc:Translate Key=Ui.Job.Steps.CompactInput}"/>
                                        <TextBlock FontSize="11" Opacity="0.68" Margin="3,0,12,0"
                                                   Text="{Binding Converter={StaticResource PipelineInfoConverter}, ConverterParameter=prereqs}"/>
                                        <TextBlock FontSize="11" Opacity="0.68" Text="{loc:Translate Key=Ui.Job.Steps.CompactOutput}"/>
                                        <TextBlock FontSize="11" Opacity="0.68" Margin="3,0,0,0" TextTrimming="CharacterEllipsis"
                                                   Text="{Binding Converter={StaticResource PipelineInfoConverter}, ConverterParameter=output}"/>
                                    </StackPanel>
                                    <TextBlock Margin="0,3,0,0" FontSize="11" Opacity="0.72"
                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource StepBranchSummaryConverter}">
                                                <Binding/>
                                                <Binding Path="DataContext.AllJobSteps" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Converter={StaticResource StepRegularSummaryVisibilityConverter}}" Value="Visible">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,7,0,0"
                                                Visibility="{Binding Converter={StaticResource StepCanAddBranchesConverter}}">
                                        <Button Content="{loc:Translate Key=Ui.Job.Steps.AddElseIf}"
                                                Command="{Binding DataContext.AddElseIfCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" Style="{StaticResource ButtonSecondary}"
                                                Padding="8,4" Margin="0,0,6,0" FontSize="11"/>
                                        <Button Content="{loc:Translate Key=Ui.Job.Steps.AddElse}"
                                                Command="{Binding DataContext.AddElseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" Style="{StaticResource ButtonSecondary}"
                                                Padding="8,4" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="8,0,0,0">
                                    <!-- Aktivieren / Deaktivieren -->
                                    <CheckBox
                                        IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                        Visibility="{Binding CanBeDisabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        ToolTip="{loc:Translate Key=Ui.Job.Steps.EnableDisableStep}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0"/>
                                    <!-- Bearbeiten -->
                                    <Button Style="{StaticResource ButtonIcon}"
                                            Margin="0,0,6,0"
                                            ToolTip="{loc:Translate Key=Ui.Common.EditStep}"
                                            Command="{Binding DataContext.EditStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="Pencil"/>
                                    </Button>
                                    <!-- Nach oben -->
                                    <Button Style="{StaticResource ButtonIcon}" Margin="0,0,2,0"
                                            ToolTip="{loc:Translate Key=Ui.Common.Ellipsis}"
                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Click="StepMoreButton_Click">
                                        <iconPacks:PackIconMaterial Kind="DotsVertical"/>
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{loc:Translate Key=Ui.Common.MoveStepUp}"
                                                          Command="{Binding PlacementTarget.Tag.MoveStepUpCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="{loc:Translate Key=Ui.Common.MoveStepDown}"
                                                          Command="{Binding PlacementTarget.Tag.MoveStepDownCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <Separator/>
                                                <MenuItem Header="{loc:Translate Key=Ui.Job.Steps.MoveToStart}"
                                                          Command="{Binding PlacementTarget.Tag.MoveToStartSectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="{loc:Translate Key=Ui.Job.Steps.MoveToRun}"
                                                          Command="{Binding PlacementTarget.Tag.MoveToRunSectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="{loc:Translate Key=Ui.Job.Steps.MoveToEnd}"
                                                          Command="{Binding PlacementTarget.Tag.MoveToEndSectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <Separator/>
                                                <MenuItem Header="{loc:Translate Key=Ui.Job.Steps.DeleteStep}"
                                                          Command="{Binding PlacementTarget.Tag.DeleteStepCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                    <!-- Nach unten -->
                                    <!-- Löschen -->
                                    <ToggleButton x:Name="DetailsToggle"
                                                  Margin="6,0,0,0" Padding="5,3"
                                                  ToolTip="{loc:Translate Key=Ui.Job.Steps.ShowDetails}"
                                                  IsEnabled="{Binding Converter={StaticResource StepDetailsEnabledConverter}}">
                                        <iconPacks:PackIconMaterial Width="18" Height="18">
                                            <iconPacks:PackIconMaterial.Style>
                                                <Style TargetType="iconPacks:PackIconMaterial">
                                                    <Setter Property="Kind" Value="ChevronLeft"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                            <Setter Property="Kind" Value="ChevronDown"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </iconPacks:PackIconMaterial.Style>
                                        </iconPacks:PackIconMaterial>
                                    </ToggleButton>
                                </StackPanel>

                                <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,1" Padding="10"
                                        BorderThickness="1,1,0,0"
                                        BorderBrush="{DynamicResource App.Brush.CardBorder}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsChecked, ElementName=DetailsToggle}" Value="True"/>
                                                        <Condition Binding="{Binding Converter={StaticResource StepHasDetailsConverter}}" Value="Visible"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                    <ContentControl>
                                        <ContentControl.Content>
                                            <MultiBinding Converter="{StaticResource JobStepDetailsConverter}">
                                                <Binding/>
                                                <Binding Path="DataContext.AllJobSteps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                                <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                            </MultiBinding>
                                        </ContentControl.Content>
                                        <ContentControl.ContentTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <ItemsControl ItemsSource="{Binding Groups}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="0,0,0,10">
                                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Margin="0,0,0,4"
                                                                               Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                                                                    <ItemsControl ItemsSource="{Binding Items}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Grid Margin="0,2">
                                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                                                    <TextBlock Text="{Binding Name}" Opacity="0.7" TextWrapping="Wrap"/>
                                                                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource App.Brush.CardBorder}"
                                                            Padding="0,10,0,0">
                                                        <StackPanel>
                                                            <TextBlock Text="{loc:Translate Key=Ui.Job.Steps.DetailsReturnValue}" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                                                            <TextBlock Text="{Binding Result.TypeName}" FontWeight="Bold" Margin="0,4,0,4"/>
                                                            <ItemsControl ItemsSource="{Binding Result.Properties}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid Margin="0,2">
                                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                                            <TextBlock Text="{Binding Name}" Opacity="0.7"/>
                                                                            <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold"/>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ContentControl.ContentTemplate>
                                    </ContentControl>
                                    </StackPanel>
                                </Border>
                                </Grid><!-- /inner Grid (content | buttons) -->
                            </Grid><!-- /outer Grid (bar | content) -->
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                    </StackPanel>
                </Expander>

                <Expander Style="{StaticResource JobStepSectionExpanderStyle}" AllowDrop="True"
                          Tag="{Binding EndSteps}"
                          DragEnter="StepSection_DragEnter" DragOver="StepSection_DragOver"
                          DragLeave="StepSection_DragLeave" Drop="StepSection_Drop"
                          IsExpanded="{Binding IsEndSectionExpanded, Mode=TwoWay}">
                    <Expander.Header>
                        <Border Style="{StaticResource JobStepSectionHeaderStyle}" Tag="{Binding HasEndStepErrors}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <iconPacks:PackIconMaterial Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <iconPacks:PackIconMaterial.Style><Style TargetType="iconPacks:PackIconMaterial"><Setter Property="Kind" Value="ChevronRight"/><Style.Triggers><DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=Expander}}" Value="True"><Setter Property="Kind" Value="ChevronDown"/></DataTrigger></Style.Triggers></Style></iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                                <TextBlock Grid.Column="1" Text="{loc:Translate Key=Ui.Job.Steps.Section.End}" FontWeight="SemiBold" FontSize="15"/>
                                <Button x:Name="EndSettingsButton" Grid.Column="2"
                                        Style="{StaticResource ButtonIcon}" Width="28" Height="28" Margin="8,-6,8,-6"
                                        ToolTip="{loc:Translate Key=Ui.Job.EndSettings.Tooltip}"
                                        PreviewMouseLeftButtonDown="EndSettingsButton_PreviewMouseLeftButtonDown">
                                    <iconPacks:PackIconMaterial Kind="CogOutline" Width="17" Height="17"/>
                                </Button>
                                <TextBlock Grid.Column="3" Text="{Binding EndSteps.Count}" Opacity="0.7" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Popup x:Name="EndSettingsPopup" Grid.Column="2"
                                       PlacementTarget="{Binding ElementName=EndSettingsButton}"
                                       Placement="Bottom" HorizontalOffset="-270" VerticalOffset="8"
                                       StaysOpen="False" AllowsTransparency="True">
                                    <Border Width="330" Padding="16" CornerRadius="8"
                                            Background="{DynamicResource App.Brush.Surface}"
                                            BorderBrush="{DynamicResource App.Brush.CardBorder}" BorderThickness="1"
                                            DataContext="{Binding DataContext, Source={x:Reference EndSettingsButton}}">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.28"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock Text="{loc:Translate Key=Ui.Job.EndSettings.Title}"
                                                       FontSize="15" FontWeight="SemiBold" Margin="0,0,0,14"/>
                                            <TextBlock Text="{loc:Translate Key=Ui.Job.EndSettings.Timeout}"
                                                       FontWeight="SemiBold" Margin="0,0,0,5"/>
                                            <DockPanel LastChildFill="False">
                                                <TextBox Width="90" HorizontalContentAlignment="Right"
                                                         Text="{Binding EndPhaseTimeoutSeconds, UpdateSourceTrigger=LostFocus,
                                                                        ValidatesOnExceptions=True, NotifyOnValidationError=True}"/>
                                                <TextBlock Text="{loc:Translate Key=Ui.Job.EndSettings.Timeout.Unit}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </DockPanel>
                                            <TextBlock Text="{loc:Translate Key=Ui.Job.EndSettings.Timeout.Description}"
                                                       Foreground="{DynamicResource App.Brush.TextSecondary}"
                                                       TextWrapping="Wrap" Margin="0,9,0,0" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </Expander.Header>
                    <Border Margin="14,8">
                        <Grid>
                            <TextBlock Text="{loc:Translate Key=Ui.Job.Steps.Section.End.Empty}"
                                       TextWrapping="Wrap" Opacity="0.65" Margin="12,8"
                                       Visibility="{Binding HasEndSteps, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                            <ListBox x:Name="EndStepsList" ItemsSource="{Binding EndSteps}"
                                     MinHeight="48" Background="Transparent" BorderThickness="0"
                                     SelectionMode="Extended"
                                     SelectionChanged="StepsList_SelectionChanged"
                                     MouseDoubleClick="StepsList_MouseDoubleClick"
                                     ItemContainerStyle="{StaticResource JobStepCardListBoxItemStyle}"
                                     ItemTemplate="{Binding ItemTemplate, ElementName=StepsList}"
                                    behaviors:StepDragDrop.MoveCommand="{Binding ReorderStepCommand}"/>
                        </Grid>
                    </Border>
                </Expander>
            </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
