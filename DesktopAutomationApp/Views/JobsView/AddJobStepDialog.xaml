                        <!-- Deckkraft -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.Opacity}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                                    Value="{Binding ShowTextStep_Opacity}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="6,0,0,0"
                                       Text="{Binding ShowTextStep_Opacity, StringFormat={}{0:P0}}"/>
                        </Grid>

                        <!-- Anzeigedauer -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.DisplayDurationMs}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowTextStep_DurationMs, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Step.Settings.Value0Permanent}"/>
                        </Grid>

                        <!-- Bei Job-Ende entfernen -->
                        <CheckBox Content="{loc:Translate Key=Ui.Step.Settings.RemoveWhenJobEnds}"
                                  IsChecked="{Binding ShowTextStep_ClearOnJobEnd}"
                                  Margin="0,0,0,8"/>

                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Position}" FontWeight="SemiBold" Margin="0,4,0,6"
                                   Foreground="{DynamicResource App.Brush.TextSecondary}"/>

                        <!-- X-Offset -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.XOffsetPixels}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowTextStep_OffsetX, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- Y-Offset -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.YOffsetPixels}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowTextStep_OffsetY, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                            </StackPanel>
                        </Expander>
                    </StackPanel>

                    <!-- ── ActiveWindow ── -->
                    <StackPanel Visibility="{Binding ShowActiveWindow, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Common.ProcessName}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                      ItemsSource="{Binding AvailableProcessNames}"
                                      Text="{Binding ActiveWindowStep_ProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      mah:TextBoxHelper.Watermark="{loc:Translate Key=Ui.Step.Settings.ProcessNamePlaceholder}"/>
                        </Grid>
                        <Expander Style="{StaticResource StepAdvancedExpander}">
                            <StackPanel Margin="0,10,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.CacheMs}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ActiveWindowStep_CacheMs, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <TextBlock Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="11" Margin="0,0,0,4"
                                   TextWrapping="Wrap"
                                   Text="{loc:Translate Key=Ui.Step.Settings.ActiveWindowResultHint}"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>

                    <!-- ── KeyPoint Matching ── -->
                    <StackPanel Visibility="{Binding ShowKeyPointMatching, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.CaptureStep}" Style="{StaticResource StepFieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding KeyPointMatchingStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.Template}" Style="{StaticResource StepFieldLabel}"/>
                            <StackPanel Grid.Column="1">
                                <TextBox Text="{Binding KeyPointMatchingStep_TemplatePath, UpdateSourceTrigger=PropertyChanged}"/>
                                <Border Style="{StaticResource TemplatePreviewBorder}"
                                        Visibility="{Binding KeyPointMatchingStep_HasTemplatePreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Image Source="{Binding KeyPointMatchingStep_TemplatePreview}" Stretch="Uniform"/>
                                </Border>
                            </StackPanel>
                            <Button Grid.Column="2" Content="{loc:Translate Key=Ui.Common.Ellipsis}" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseKeyPointMatchingTemplatePathCommand}"/>
                        </Grid>
                        <Expander Style="{StaticResource StepAdvancedExpander}">
                            <StackPanel Margin="0,10,0,0">
                        <roiControls:RoiEditor
                            IsRoiEnabled="{Binding KeyPointMatchingStep_EnableROI}"
                            X="{Binding KeyPointMatchingStep_RoiX}" Y="{Binding KeyPointMatchingStep_RoiY}"
                            RoiWidth="{Binding KeyPointMatchingStep_RoiW}" RoiHeight="{Binding KeyPointMatchingStep_RoiH}"
                            CaptureCommand="{Binding CaptureKeyPointMatchingRoiCommand}"/>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.MinMatches}" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepCompactTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding KeyPointMatchingStep_MinMatchCount, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.LoweSRatio01}" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepCompactTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding KeyPointMatchingStep_LowesRatioThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                            </StackPanel>
                        </Expander>
                    </StackPanel>

                    <!-- ── If ── -->
                    <StackPanel Visibility="{Binding ShowDynamicRoi, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{loc:Translate Key=Ui.Step.DynamicRoi.Description}"
                                   TextWrapping="Wrap" Margin="0,0,0,12" Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Step.DynamicRoi.Source}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding AvailableDetectionSteps}" DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding DynamicRoiStep_SourceDetectionStep}" Margin="0,0,0,10"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Step.DynamicRoi.Padding}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding DynamicRoiStep_Padding, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Step.DynamicRoi.MinimumConfidence}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding DynamicRoiStep_MinimumConfidence, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        <Expander Style="{StaticResource StepAdvancedExpander}">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="{loc:Translate Key=Ui.Step.DynamicRoi.FullSearchInterval}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding DynamicRoiStep_FullSearchInterval, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                                <TextBlock Text="{loc:Translate Key=Ui.Step.DynamicRoi.ResetAfterMisses}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding DynamicRoiStep_ResetAfterMisses, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>

                    <conditionControls:ConditionEditor Visibility="{Binding ShowIf, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                       Conditions="{Binding IfStep_Conditions}"
                                                       IsAll="{Binding IfStep_MatchModeIsAll}"
                                                       IsAny="{Binding IfStep_MatchModeIsAny}"
                                                       AddCommand="{Binding IfStep_AddConditionCommand}"/>
                    <!-- ── ElseIf ── -->
                    <conditionControls:ConditionEditor Visibility="{Binding ShowElseIf, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                       Conditions="{Binding ElseIfStep_Conditions}"
                                                       IsAll="{Binding ElseIfStep_MatchModeIsAll}"
                                                       IsAny="{Binding ElseIfStep_MatchModeIsAny}"
                                                       AddCommand="{Binding ElseIfStep_AddConditionCommand}"/>
                    <!-- ── Else ── -->
                    <StackPanel Visibility="{Binding ShowElse, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.ElseDescription}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.TextMuted}"
                                   FontStyle="Italic" FontSize="12"/>
                    </StackPanel>

                    <!-- ── EndIf ── -->
                    <StackPanel Visibility="{Binding ShowEndIf, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.EndIfDescription}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.TextMuted}"
                                   FontStyle="Italic" FontSize="12"/>
                    </StackPanel>

                    <!-- ── EndJob ── -->
                    <StackPanel Visibility="{Binding ShowEndJob, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.EndJobDescription}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.Brush.TextMuted}"
                                   FontStyle="Italic" FontSize="12"/>
                    </StackPanel>

                    <!-- ── Point Comparison ── -->
                    <StackPanel Visibility="{Binding ShowPointComparison, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Margin="0,0,0,4">

                        <!-- Grundeinstellungen -->
                        <Border Background="{DynamicResource App.Brush.Surface}"
                                BorderBrush="{DynamicResource App.Brush.CardBorder}"
                                BorderThickness="1" CornerRadius="6" Padding="10,10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.BasicSettings}" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource App.Brush.TextMuted}" Margin="0,0,0,8"/>

                                <!-- Vergleichsmodus als gleichmäßige 2-Spalten-Auswahl -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.Mode}" VerticalAlignment="Center"
                                               FontSize="12" Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" CornerRadius="4" Padding="8,5" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.CardBorder}"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PointComparisonStep_ModeIsOffset}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/>
                                                            <Setter Property="Background" Value="{DynamicResource App.Brush.AccentSubtle}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <RadioButton IsChecked="{Binding PointComparisonStep_ModeIsOffset}">
                                                <StackPanel>
                                                    <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.OffsetTolerance}" FontSize="11" FontWeight="Medium"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.NearReferencePoint}" FontSize="10"
                                                               Foreground="{DynamicResource App.Brush.TextMuted}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </RadioButton>
                                        </Border>
                                        <Border Grid.Column="2" CornerRadius="4" Padding="8,5" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.CardBorder}"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PointComparisonStep_ModeIsExpression}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/>
                                                            <Setter Property="Background" Value="{DynamicResource App.Brush.AccentSubtle}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <RadioButton IsChecked="{Binding PointComparisonStep_ModeIsExpression}">
                                                <StackPanel>
                                                    <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Expression}" FontSize="11" FontWeight="Medium"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.XYComparisonX100}" FontSize="10"
                                                               Foreground="{DynamicResource App.Brush.TextMuted}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </RadioButton>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <!-- Übereinstimmungsregel -->
                                <Rectangle Height="1" Fill="{DynamicResource App.Brush.CardBorder}" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.Evaluation}" VerticalAlignment="Center"
                                               FontSize="12" Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton Content="{loc:Translate Key=Ui.Step.Settings.AllAND}" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_MatchRequirementIsAll}" Margin="0,0,16,0"/>
                                        <RadioButton Content="{loc:Translate Key=Ui.Step.Settings.AtLeastOneOR}" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_MatchRequirementIsAny}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Offset-Einstellungen -->
                        <Border Visibility="{Binding PointComparisonStep_ModeIsOffset, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Background="{DynamicResource App.Brush.Surface}"
                                BorderBrush="{DynamicResource App.Brush.CardBorder}"
                                BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.ReferencePointTolerance}" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource App.Brush.TextMuted}" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.ReferenceSource}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource App.Brush.TextSecondary}" FontSize="12"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton Content="{loc:Translate Key=Ui.Step.Settings.EnterManually}" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_RefIsManual}" Margin="0,0,20,0"/>
                                        <RadioButton Content="{loc:Translate Key=Ui.Step.Settings.FromDetectionResult}" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_RefIsJobResult}"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Visibility="{Binding PointComparisonStep_RefIsManual, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.CoordinatesXY}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource App.Brush.TextSecondary}" FontSize="12"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.X}" VerticalAlignment="Center" Width="16"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource App.Brush.TextMuted}"/>
                                        <TextBox Width="80" Text="{Binding PointComparisonStep_RefX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,16,0"/>
                                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Y}" VerticalAlignment="Center" Width="16"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource App.Brush.TextMuted}"/>
                                        <TextBox Width="80" Text="{Binding PointComparisonStep_RefY, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Visibility="{Binding PointComparisonStep_RefIsJobResult, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.DetectionStep}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource App.Brush.TextSecondary}" FontSize="12"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableDetectionSteps}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedItem="{Binding PointComparisonStep_RefDetectionStep}"/>
                                </Grid>
                                <Rectangle Height="1" Fill="{DynamicResource App.Brush.CardBorder}" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.TolerancePixels}" FontSize="12"
                                                   Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.MaximumDeviation}" FontSize="10"
                                                   Foreground="{DynamicResource App.Brush.TextMuted}" Margin="0,1,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.X}" VerticalAlignment="Center" Width="16"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource App.Brush.TextMuted}"/>
                                        <TextBox Width="80" Text="{Binding PointComparisonStep_OffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,16,0"/>
                                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Y}" VerticalAlignment="Center" Width="16"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource App.Brush.TextMuted}"/>
                                        <TextBox Width="80" Text="{Binding PointComparisonStep_OffsetY, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Ausdrucks-Einstellungen -->
                        <Border Visibility="{Binding PointComparisonStep_ModeIsExpression, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Background="{DynamicResource App.Brush.Surface}"
                                BorderBrush="{DynamicResource App.Brush.CardBorder}"
                                BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.AxisExpressions}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource App.Brush.TextMuted}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.CombineWith}" FontSize="11"
                                                   Foreground="{DynamicResource App.Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <RadioButton Content="{loc:Translate Key=Ui.Step.Settings.ANDAll}" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_ExprCombineIsAnd}" Margin="0,0,12,0"/>
                                        <RadioButton Content="{loc:Translate Key=Ui.Step.Settings.ORAny}" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_ExprCombineIsOr}"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.Axis}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource App.Brush.TextMuted}"/>
                                    <TextBlock Grid.Column="1" Text="{loc:Translate Key=Ui.Step.Settings.Operator}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource App.Brush.TextMuted}"/>
                                    <TextBlock Grid.Column="2" Text="{loc:Translate Key=Ui.Step.Settings.ComparisonValue}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource App.Brush.TextMuted}"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding PointComparisonStep_Expressions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0" Margin="0,0,6,0"
                                                          ItemsSource="{Binding AvailableAxes}"
                                                          SelectedItem="{Binding Axis}"/>
                                                <ComboBox Grid.Column="1" Margin="0,0,6,0"
                                                          ItemsSource="{Binding AvailableOperators}"
                                                          SelectedItem="{Binding Operator}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource PointAxisOperatorConverter}}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBox Grid.Column="2" Margin="0,0,6,0"
                                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                         VerticalContentAlignment="Center"/>
                                                <Button Grid.Column="3" Content="{loc:Translate Key=Ui.Common.RemoveSymbol}"
                                                        Command="{Binding RemoveCommand}"
                                                        FontSize="13" Padding="4,2"
                                                        ToolTip="{loc:Translate Key=Ui.Step.Settings.RemoveExpression}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="{loc:Translate Key=Ui.Step.Settings.AddExpression}"
                                        Command="{Binding PointComparisonStep_AddExpressionCommand}"
                                        HorizontalAlignment="Left" Margin="0,8,0,0"
                                        Style="{StaticResource ButtonSecondary}"
                                        Padding="10,5" FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <!-- Zu prüfende Punkte -->
                        <Border Background="{DynamicResource App.Brush.Surface}"
                                BorderBrush="{DynamicResource App.Brush.CardBorder}"
                                BorderThickness="1" CornerRadius="6" Padding="14,12">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.PointsToCheck}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource App.Brush.TextMuted}"/>
                                        <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.ThesePointsAreCheckedAgainstTheCondition}" FontSize="11"
                                                   Foreground="{DynamicResource App.Brush.TextMuted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="{loc:Translate Key=Ui.Step.Settings.AddPoint}"
                                            Command="{Binding PointComparisonStep_AddPointCommand}"
                                            Style="{StaticResource ButtonSecondary}"
                                            Padding="10,5" FontSize="11" VerticalAlignment="Top"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding PointComparisonStep_Points}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource App.Brush.WindowBackground}"
                                                    BorderBrush="{DynamicResource App.Brush.CardBorder}"
                                                    BorderThickness="1" CornerRadius="5"
                                                    Padding="12,10" Margin="0,0,0,6">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="90"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.PointSource}" VerticalAlignment="Center"
                                                                   FontSize="11" Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <RadioButton Content="{loc:Translate Key=Ui.Step.Settings.Manual}" VerticalAlignment="Center"
                                                                         IsChecked="{Binding IsManual}" Margin="0,0,16,0"/>
                                                            <RadioButton Content="{loc:Translate Key=Ui.Step.Settings.FromDetectionResult}" VerticalAlignment="Center"
                                                                         IsChecked="{Binding IsJobResult}"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="2" Content="{loc:Translate Key=Ui.Step.Settings.RemovePoint}"
                                                                Command="{Binding RemoveCommand}"
                                                                FontSize="11" Padding="8,3"/>
                                                    </Grid>
                                                    <Grid Visibility="{Binding ShowManual, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="90"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.Coordinates}" VerticalAlignment="Center"
                                                                   FontSize="11" Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                            <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.X}" VerticalAlignment="Center" Width="16"
                                                                       FontWeight="SemiBold" Foreground="{DynamicResource App.Brush.TextMuted}"/>
                                                            <TextBox Width="90" Margin="0,0,16,0"
                                                                     Text="{Binding ManualX, UpdateSourceTrigger=PropertyChanged}"/>
                                                            <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.Y}" VerticalAlignment="Center" Width="16"
                                                                       FontWeight="SemiBold" Foreground="{DynamicResource App.Brush.TextMuted}"/>
                                                            <TextBox Width="90"
                                                                     Text="{Binding ManualY, UpdateSourceTrigger=PropertyChanged}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <StackPanel Visibility="{Binding ShowJobResult, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.DetectionStep}" VerticalAlignment="Center"
                                                                       FontSize="11" Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                                                            <ComboBox Grid.Column="1"
                                                                      ItemsSource="{Binding AvailableDetectionSteps}"
                                                                      DisplayMemberPath="DisplayName"
                                                                      SelectedItem="{Binding SelectedDetectionStep}"/>
                                                        </Grid>
                                                        <CheckBox Content="{loc:Translate Key=Ui.Step.Settings.UseAllPointsFoundByThisStep}"
                                                                  IsChecked="{Binding UseAllDetections}"
                                                                  Margin="90,0,0,0" FontSize="11"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Step-Beschreibung -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="{Binding ValidationError}" Foreground="#FFD13438" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <Border Background="{DynamicResource App.Brush.AccentSubtle}"
                    BorderBrush="{DynamicResource App.Brush.Accent}"
                    BorderThickness="1" CornerRadius="6" Padding="12,9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <iconPacks:PackIconMaterial Grid.Column="0" Kind="InformationOutline"
                                               Foreground="{DynamicResource App.Brush.Accent}"
                                               VerticalAlignment="Top" Margin="0,1,9,0"
                                               Width="14" Height="14"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding StepTypeDescription}"
                               Foreground="{DynamicResource App.Brush.TextSecondary}"
                               TextWrapping="Wrap" FontSize="12"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{loc:Translate Key=Ui.Common.Cancel}" IsCancel="True" Margin="0,0,8,0"
                    Click="Cancel_Click" Style="{StaticResource ButtonSecondary}"/>
            <Button Content="{Binding ConfirmButtonText}" IsDefault="True"
                    Command="{Binding ConfirmCommand}" Style="{StaticResource ButtonPrimary}"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
