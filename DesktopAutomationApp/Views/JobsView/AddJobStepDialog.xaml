<mah:MetroWindow x:Class="DesktopAutomationApp.Views.AddJobStepDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:loc="clr-namespace:DesktopAutomationApp.Localization"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:detection="clr-namespace:DesktopAutomationApp.Controls.Jobs.Editors.Detection"
                 xmlns:analysis="clr-namespace:DesktopAutomationApp.Controls.Jobs.Editors.Analysis"
                 xmlns:capture="clr-namespace:DesktopAutomationApp.Controls.Jobs.Editors.Capture"
                 xmlns:output="clr-namespace:DesktopAutomationApp.Controls.Jobs.Editors.Output"
                 xmlns:execution="clr-namespace:DesktopAutomationApp.Controls.Jobs.Editors.Execution"
                 xmlns:interaction="clr-namespace:DesktopAutomationApp.Controls.Jobs.Editors.Interaction"
                 xmlns:process="clr-namespace:DesktopAutomationApp.Controls.Jobs.Editors.Process"
                 xmlns:roi="clr-namespace:DesktopAutomationApp.Controls.Jobs.Editors.Roi"
                 xmlns:flow="clr-namespace:DesktopAutomationApp.Controls.Jobs.Editors.Flow"
                 xmlns:windowsEditors="clr-namespace:DesktopAutomationApp.Controls.Jobs.Editors.Windows"
                 WindowStartupLocation="CenterOwner"
                 Width="540" Height="560"
                 Title="{Binding DialogTitle}"
                 ResizeMode="CanResize" ShowInTaskbar="False"
                 Style="{StaticResource DialogWindowStyle}">
    <mah:MetroWindow.Resources>
        <DataTemplate x:Key="TemplateMatchingEditor"><detection:TemplateMatchingStepEditor/></DataTemplate>
        <DataTemplate x:Key="ColorDetectionEditor"><detection:ColorDetectionStepEditor/></DataTemplate>
        <DataTemplate x:Key="PredictMovementEditor"><analysis:PredictMovementStepEditor/></DataTemplate>
        <DataTemplate x:Key="DesktopDuplicationEditor"><capture:DesktopDuplicationStepEditor/></DataTemplate>
        <DataTemplate x:Key="CameraCaptureEditor"><capture:CameraCaptureStepEditor/></DataTemplate>
        <DataTemplate x:Key="ShowImageEditor"><output:ShowImageStepEditor/></DataTemplate>
        <DataTemplate x:Key="ShowOnDesktopEditor"><output:ShowOnDesktopStepEditor/></DataTemplate>
        <DataTemplate x:Key="VideoCreationEditor"><output:VideoCreationStepEditor/></DataTemplate>
        <DataTemplate x:Key="MakroExecutionEditor"><execution:MakroExecutionStepEditor/></DataTemplate>
        <DataTemplate x:Key="JobExecutionEditor"><execution:JobExecutionStepEditor/></DataTemplate>
        <DataTemplate x:Key="ScriptExecutionEditor"><execution:ScriptExecutionStepEditor/></DataTemplate>
        <DataTemplate x:Key="KlickOnPointEditor"><interaction:KlickOnPointStepEditor/></DataTemplate>
        <DataTemplate x:Key="KlickOnPoint3DEditor"><interaction:KlickOnPoint3DStepEditor/></DataTemplate>
        <DataTemplate x:Key="YoloDetectionEditor"><detection:YoloDetectionStepEditor/></DataTemplate>
        <DataTemplate x:Key="TimeoutEditor"><flow:TimeoutStepEditor/></DataTemplate>
        <DataTemplate x:Key="BlockInputEditor"><flow:BlockInputStepEditor/></DataTemplate>
        <DataTemplate x:Key="UnblockInputEditor"><flow:UnblockInputStepEditor/></DataTemplate>
        <DataTemplate x:Key="ActiveProcessEditor"><process:ActiveProcessStepEditor/></DataTemplate>
        <DataTemplate x:Key="GetProcessEditor"><process:GetProcessStepEditor/></DataTemplate>
        <DataTemplate x:Key="StartProcessEditor"><process:StartProcessStepEditor/></DataTemplate>
        <DataTemplate x:Key="TerminateProcessEditor"><process:TerminateProcessStepEditor/></DataTemplate>
        <DataTemplate x:Key="FocusProcessEditor"><process:FocusProcessStepEditor/></DataTemplate>
        <DataTemplate x:Key="ShowTextEditor"><output:ShowTextStepEditor/></DataTemplate>
        <DataTemplate x:Key="ActiveWindowEditor"><process:ActiveWindowStepEditor/></DataTemplate>
        <DataTemplate x:Key="KeyPointMatchingEditor"><detection:KeyPointMatchingStepEditor/></DataTemplate>
        <DataTemplate x:Key="DynamicRoiEditor"><roi:DynamicRoiStepEditor/></DataTemplate>
        <DataTemplate x:Key="IfEditor"><flow:IfStepEditor/></DataTemplate>
        <DataTemplate x:Key="ElseIfEditor"><flow:ElseIfStepEditor/></DataTemplate>
        <DataTemplate x:Key="ElseEditor"><flow:ElseStepEditor/></DataTemplate>
        <DataTemplate x:Key="EndIfEditor"><flow:EndIfStepEditor/></DataTemplate>
        <DataTemplate x:Key="EndJobEditor"><flow:EndJobStepEditor/></DataTemplate>
        <DataTemplate x:Key="ContinueJobEditor"><flow:ContinueJobStepEditor/></DataTemplate>
        <DataTemplate x:Key="PointComparisonEditor"><analysis:PointComparisonStepEditor/></DataTemplate>
        <DataTemplate x:Key="WindowsStateQueryEditor"><windowsEditors:WindowsStateQueryStepEditor/></DataTemplate>
    </mah:MetroWindow.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Visibility="{Binding ShowTypeSelector, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="{DynamicResource App.Brush.Surface}"
                CornerRadius="6" Padding="12,10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="{loc:Translate Key=Ui.Step.Settings.StepType}"
                           Foreground="{DynamicResource App.Brush.TextMuted}"
                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ComboBox Grid.Row="1"
                          ItemsSource="{Binding StepTypeItems}"
                          DisplayMemberPath="DisplayLabel"
                          SelectedValuePath="Name"
                          SelectedValue="{Binding SelectedType}"
                          FontSize="14" FontWeight="Medium"
                          MinHeight="38"
                          mah:ControlsHelper.CornerRadius="5">
                    <ComboBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource App.Brush.CardBorder}"
                                            BorderThickness="0,1,0,0" Margin="0,4,0,0" Padding="4,6,4,2">
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource App.Brush.Accent}"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ComboBox.GroupStyle>
                </ComboBox>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <Border Background="{DynamicResource App.Brush.Surface}" CornerRadius="6" Padding="14,12">
                <ContentControl Content="{Binding}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="ContentTemplate" Value="{StaticResource TemplateMatchingEditor}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedType}" Value="TemplateMatching"><Setter Property="ContentTemplate" Value="{StaticResource TemplateMatchingEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="ColorDetection"><Setter Property="ContentTemplate" Value="{StaticResource ColorDetectionEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="PredictMovement"><Setter Property="ContentTemplate" Value="{StaticResource PredictMovementEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="DesktopDuplication"><Setter Property="ContentTemplate" Value="{StaticResource DesktopDuplicationEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="CameraCapture"><Setter Property="ContentTemplate" Value="{StaticResource CameraCaptureEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="ShowImage"><Setter Property="ContentTemplate" Value="{StaticResource ShowImageEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="ShowOnDesktop"><Setter Property="ContentTemplate" Value="{StaticResource ShowOnDesktopEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="VideoCreation"><Setter Property="ContentTemplate" Value="{StaticResource VideoCreationEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="MakroExecution"><Setter Property="ContentTemplate" Value="{StaticResource MakroExecutionEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="JobExecution"><Setter Property="ContentTemplate" Value="{StaticResource JobExecutionEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="ScriptExecution"><Setter Property="ContentTemplate" Value="{StaticResource ScriptExecutionEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="KlickOnPoint"><Setter Property="ContentTemplate" Value="{StaticResource KlickOnPointEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="KlickOnPoint3D"><Setter Property="ContentTemplate" Value="{StaticResource KlickOnPoint3DEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="YoloDetection"><Setter Property="ContentTemplate" Value="{StaticResource YoloDetectionEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="Timeout"><Setter Property="ContentTemplate" Value="{StaticResource TimeoutEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="BlockInput"><Setter Property="ContentTemplate" Value="{StaticResource BlockInputEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="UnblockInput"><Setter Property="ContentTemplate" Value="{StaticResource UnblockInputEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="ActiveProcess"><Setter Property="ContentTemplate" Value="{StaticResource ActiveProcessEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="GetProcess"><Setter Property="ContentTemplate" Value="{StaticResource GetProcessEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="StartProcess"><Setter Property="ContentTemplate" Value="{StaticResource StartProcessEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="TerminateProcess"><Setter Property="ContentTemplate" Value="{StaticResource TerminateProcessEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="FocusProcess"><Setter Property="ContentTemplate" Value="{StaticResource FocusProcessEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="ShowText"><Setter Property="ContentTemplate" Value="{StaticResource ShowTextEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="ActiveWindow"><Setter Property="ContentTemplate" Value="{StaticResource ActiveWindowEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="KeyPointMatching"><Setter Property="ContentTemplate" Value="{StaticResource KeyPointMatchingEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="DynamicRoi"><Setter Property="ContentTemplate" Value="{StaticResource DynamicRoiEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="If"><Setter Property="ContentTemplate" Value="{StaticResource IfEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="ElseIf"><Setter Property="ContentTemplate" Value="{StaticResource ElseIfEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="Else"><Setter Property="ContentTemplate" Value="{StaticResource ElseEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="EndIf"><Setter Property="ContentTemplate" Value="{StaticResource EndIfEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="EndJob"><Setter Property="ContentTemplate" Value="{StaticResource EndJobEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="ContinueJob"><Setter Property="ContentTemplate" Value="{StaticResource ContinueJobEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="PointComparison"><Setter Property="ContentTemplate" Value="{StaticResource PointComparisonEditor}"/></DataTrigger>
                                <DataTrigger Binding="{Binding SelectedType}" Value="WindowsStateQuery"><Setter Property="ContentTemplate" Value="{StaticResource WindowsStateQueryEditor}"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Border>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="{Binding ValidationError}" Foreground="#FFD13438" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <Border Background="{DynamicResource App.Brush.AccentSubtle}"
                    BorderBrush="{DynamicResource App.Brush.Accent}"
                    BorderThickness="1" CornerRadius="6" Padding="12,9">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <iconPacks:PackIconMaterial Kind="InformationOutline"
                                               Foreground="{DynamicResource App.Brush.Accent}"
                                               VerticalAlignment="Top" Margin="0,1,9,0" Width="14" Height="14"/>
                    <TextBlock Grid.Column="1" Text="{Binding StepTypeDescription}"
                               Foreground="{DynamicResource App.Brush.TextSecondary}"
                               TextWrapping="Wrap" FontSize="12"/>
                </Grid>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{loc:Translate Key=Ui.Common.Cancel}" IsCancel="True" Margin="0,0,8,0"
                    Click="Cancel_Click" Style="{StaticResource ButtonSecondary}"/>
            <Button Content="{Binding ConfirmButtonText}" IsDefault="True"
                    Command="{Binding ConfirmCommand}" Style="{StaticResource ButtonPrimary}"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
