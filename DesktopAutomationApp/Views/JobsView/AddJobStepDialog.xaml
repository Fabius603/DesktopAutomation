<mah:MetroWindow xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" x:Class="DesktopAutomationApp.Views.AddJobStepDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:roiControls="clr-namespace:DesktopAutomationApp.Controls.Jobs.Roi"
                 xmlns:conditionControls="clr-namespace:DesktopAutomationApp.Controls.Jobs.Conditions"
                 WindowStartupLocation="CenterOwner"
                 Width="540" Height="560"
                 Title="{Binding DialogTitle}"
                 ResizeMode="CanResize" ShowInTaskbar="False"
                 Style="{StaticResource DialogWindowStyle}">

    <mah:MetroWindow.Resources>
        <Style x:Key="StepFieldGrid" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="StepFieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextSecondary}"/>
        </Style>
        <Style x:Key="StepAdvancedExpander" TargetType="Expander">
            <Setter Property="Header" Value="{loc:Translate Key=Ui.Step.Settings.Advanced}"/>
            <Setter Property="IsExpanded" Value="False"/>
            <Setter Property="Margin" Value="0,4,0,6"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextSecondary}"/>
        </Style>
        <Style x:Key="StepCompactTextBox" TargetType="TextBox">
            <Setter Property="Width" Value="42"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StepAxisLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextMuted}"/>
        </Style>
        <Style x:Key="StepGroupedFieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Brush.TextMuted}"/>
        </Style>
        <Style x:Key="StepGroupedTextBox" TargetType="TextBox" BasedOn="{StaticResource StepCompactTextBox}">
            <Setter Property="Width" Value="72"/>
        </Style>
        <Style x:Key="RoiFieldWrapPanel" TargetType="WrapPanel">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ItemHeight" Value="34"/>
        </Style>
        <Style x:Key="RoiFieldGroup" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,0,14,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StepInlineButton" TargetType="Button" BasedOn="{StaticResource ButtonSecondary}">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="TemplatePreviewBorder" TargetType="Border">
            <Setter Property="Width" Value="96"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Background" Value="{DynamicResource App.Brush.WindowBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Typauswahl -->
        <Border Grid.Row="0"
                Visibility="{Binding ShowTypeSelector, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="{DynamicResource App.Brush.Surface}"
                CornerRadius="6" Padding="12,10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{loc:Translate Key=Ui.Step.Settings.StepType}"
                           Foreground="{DynamicResource App.Brush.TextMuted}"
                           FontSize="11" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <ComboBox Grid.Row="1"
                          ItemsSource="{Binding StepTypeItems}"
                          DisplayMemberPath="DisplayLabel"
                          SelectedValuePath="Name"
                          SelectedValue="{Binding SelectedType}"
                          FontSize="14" FontWeight="Medium"
                          MinHeight="38"
                          mah:ControlsHelper.CornerRadius="5">
                    <ComboBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource App.Brush.CardBorder}"
                                            BorderThickness="0,1,0,0"
                                            Margin="0,4,0,0" Padding="4,6,4,2">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource App.Brush.Accent}"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ComboBox.GroupStyle>
                </ComboBox>
            </Grid>
        </Border>

        <!-- Dynamische Felder -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <Border Background="{DynamicResource App.Brush.Surface}" CornerRadius="6" Padding="14,12">
                <StackPanel>

                    <!-- ── Template Matching ── -->
                    <StackPanel Visibility="{Binding ShowTemplateMatching, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.CaptureStep}" Style="{StaticResource StepFieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding TemplateMatchingStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.Template}" Style="{StaticResource StepFieldLabel}"/>
                            <StackPanel Grid.Column="1">
                                <TextBox Text="{Binding TemplateMatchingStep_TemplatePath, UpdateSourceTrigger=PropertyChanged}"/>
                                <Border Style="{StaticResource TemplatePreviewBorder}"
                                        Visibility="{Binding TemplateMatchingStep_HasTemplatePreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Image Source="{Binding TemplateMatchingStep_TemplatePreview}" Stretch="Uniform"/>
                                </Border>
                            </StackPanel>
                            <Button Grid.Column="2" Content="{loc:Translate Key=Ui.Common.Ellipsis}" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseTemplatePathCommand}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.Confidence01}" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepCompactTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding TemplateMatchingStep_ConfidenceThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                        <Expander Style="{StaticResource StepAdvancedExpander}">
                            <StackPanel Margin="0,10,0,0">
                        <roiControls:RoiEditor
                            IsRoiEnabled="{Binding TemplateMatchingStep_EnableROI}"
                            X="{Binding TemplateMatchingStep_RoiX}" Y="{Binding TemplateMatchingStep_RoiY}"
                            RoiWidth="{Binding TemplateMatchingStep_RoiW}" RoiHeight="{Binding TemplateMatchingStep_RoiH}"
                            CaptureCommand="{Binding CaptureTemplateMatchingRoiCommand}"/>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.MatchMode}" Style="{StaticResource StepFieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding TemplateMatchModesAll}"
                                      SelectedItem="{Binding TemplateMatchingStep_TemplateMatchMode}"/>
                        </Grid>
                            </StackPanel>
                        </Expander>
                    </StackPanel>

                    <!-- ── Color Detection ── -->
                    <StackPanel Visibility="{Binding ShowColorDetection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.CaptureStep}" Style="{StaticResource StepFieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding ColorDetectionStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.Color}" Style="{StaticResource StepFieldLabel}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <mah:ColorPicker SelectedColor="{Binding ColorDetectionStep_Color}"
                                                 HorizontalAlignment="Left"/>
                                <Border Width="28" Height="28" Margin="8,0,0,0"
                                        Background="{Binding ColorDetectionStep_ColorBrush}"
                                        BorderBrush="{DynamicResource App.Brush.CardBorder}"
                                        BorderThickness="1"
                                        CornerRadius="4"/>
                                <TextBlock Text="{Binding ColorDetectionStep_ColorHex}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            </StackPanel>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.Confidence01}" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepCompactTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding ColorDetectionStep_ConfidenceThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                        <Expander Style="{StaticResource StepAdvancedExpander}">
                            <StackPanel Margin="0,10,0,0">
                        <roiControls:RoiEditor
                            IsRoiEnabled="{Binding ColorDetectionStep_EnableROI}"
                            X="{Binding ColorDetectionStep_RoiX}" Y="{Binding ColorDetectionStep_RoiY}"
                            RoiWidth="{Binding ColorDetectionStep_RoiW}" RoiHeight="{Binding ColorDetectionStep_RoiH}"
                            CaptureCommand="{Binding CaptureColorDetectionRoiCommand}"/>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.MinSize}" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding ColorDetectionStep_MinSize, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.MaxSize}" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding ColorDetectionStep_MaxSize, Converter={StaticResource MaxSizeDisplayConverter}, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.MinWidth}" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding ColorDetectionStep_MinWidth, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.MinHeight}" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding ColorDetectionStep_MinHeight, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.Downscale}" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding ColorDetectionStep_DownscaleFactor, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                            </StackPanel>
                        </Expander>
                    </StackPanel>

                    <!-- ── Predict Movement ── -->
                    <StackPanel Visibility="{Binding ShowPredictMovement, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.DetectionStep}" Style="{StaticResource StepFieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableDetectionSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding PredictMovementStep_SourceDetectionStep}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.PredictionModel}" Style="{StaticResource StepFieldLabel}"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding PredictMovementModels}" SelectedItem="{Binding PredictMovementStep_PredictionModel}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.MinimumConfidence}" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left" Text="{Binding PredictMovementStep_MinimumConfidence, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Expander Style="{StaticResource StepAdvancedExpander}">
                            <StackPanel Margin="0,10,0,0">
                                <Grid Style="{StaticResource StepFieldGrid}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.MinValues}" Style="{StaticResource StepFieldLabel}"/>
                                    <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left" Text="{Binding PredictMovementStep_MinSamples, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                                <Grid Style="{StaticResource StepFieldGrid}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.ResetAtDistance}" Style="{StaticResource StepFieldLabel}"/>
                                    <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left" Text="{Binding PredictMovementStep_ResetDistanceThreshold, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                                <Grid Style="{StaticResource StepFieldGrid}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.MaxAgeMs}" Style="{StaticResource StepFieldLabel}"/>
                                    <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left" Text="{Binding PredictMovementStep_MaxSampleAgeMs, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                                <Grid Style="{StaticResource StepFieldGrid}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.MaxPredictionDistance}" Style="{StaticResource StepFieldLabel}"/>
                                    <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left" Text="{Binding PredictMovementStep_MaxPredictionDistance, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                                <Grid Style="{StaticResource StepFieldGrid}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.MaxFitError}" Style="{StaticResource StepFieldLabel}"/>
                                    <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left" Text="{Binding PredictMovementStep_MaxFitError, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </StackPanel>
                        </Expander>
                    </StackPanel>

                    <!-- ── Desktop Duplication ── -->
                    <StackPanel Visibility="{Binding ShowDesktopDuplication, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.DesktopIndex}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="60" IsReadOnly="True"
                                     Text="{Binding DesktopDuplicationStep_DesktopIdx}"/>
                            <Button Grid.Column="2" Content="{loc:Translate Key=Ui.Step.Settings.SelectMonitor}" Margin="8,0,0,0" Padding="10,5"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ChooseMonitorCommand}"/>
                        </Grid>
                        <CheckBox Margin="0,6,0,0"
                                  Content="{loc:Translate Key=Ui.Step.Settings.CaptureMousePointer}"
                                  IsChecked="{Binding DesktopDuplicationStep_CaptureCursor}"/>
                    </StackPanel>

                    <!-- ── Show Image ── -->
                    <StackPanel Visibility="{Binding ShowShowImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.CaptureStep}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding ShowImageStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.DetectionStepOpt}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableOptionalDetectionSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding ShowImageStep_SourceDetectionStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.WindowName}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowImageStep_WindowName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Show On Desktop ── -->
                    <StackPanel Visibility="{Binding ShowShowOnDesktop, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.DetectionStep}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableDetectionSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding ShowOnDesktopStep_SourceDetectionStep}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Video Creation ── -->
                    <StackPanel Visibility="{Binding ShowVideoCreation, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.CaptureStep}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding VideoCreationStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.DetectionStepOpt}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableOptionalDetectionSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding VideoCreationStep_SourceDetectionStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.SavePath}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Text="{Binding VideoCreationStep_SavePath}" IsReadOnly="True"/>
                            <Button Grid.Column="2" Content="{loc:Translate Key=Ui.Common.Ellipsis}" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseVideoSavePathCommand}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.FileName}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding VideoCreationStep_FileName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Makro Execution ── -->
                    <StackPanel Visibility="{Binding ShowMakroExecution, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.Macro}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableMakros}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding MakroExecutionStep_SelectedMakro}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Job Execution ── -->
                    <StackPanel Visibility="{Binding ShowJobExecution, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.Job}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableJobs}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding JobExecutionStep_SelectedJob}"/>
                        </Grid>
                        <CheckBox Content="{loc:Translate Key=Ui.Step.Settings.WaitForCompletion}" IsChecked="{Binding JobExecutionStep_WaitForCompletion}"/>
                    </StackPanel>

                    <!-- ── Script Execution ── -->
                    <StackPanel Visibility="{Binding ShowScriptExecution, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Translate Key=Ui.Step.Settings.ScriptPath}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ScriptExecutionStep_ScriptPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="{loc:Translate Key=Ui.Common.Ellipsis}" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseScriptPathCommand}"/>
                        </Grid>
                        <Expander Style="{StaticResource StepAdvancedExpander}">
                            <StackPanel Margin="0,10,0,0">
