<UserControl x:Class="DesktopAutomationApp.Views.YoloDownloadsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DesktopAutomationApp.ViewModels"
             xmlns:conv="clr-namespace:DesktopAutomationApp.Converters"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Style="{StaticResource ContentViewBase}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonSecondary}"
                        Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Aktualisieren" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <TextBlock Text="YOLO Downloads" Style="{StaticResource PageTitle}" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Modelliste -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Models}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ItemCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Titel und Status -->
                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Style="{StaticResource Subtitle}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding StatusText}"
                                                   Style="{StaticResource CaptionText}"
                                                   Foreground="{DynamicResource App.Brush.Accent}"/>
                                    </StackPanel>

                                    <!-- Beschreibung -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding Description}"
                                               Style="{StaticResource BodyText}"
                                               Margin="0,8,0,8"
                                               Foreground="{DynamicResource App.Brush.TextSecondary}"/>

                                    <!-- Detailinfos -->
                                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                Orientation="Horizontal"
                                                Margin="0,0,0,8">
                                        <TextBlock Text="Model Key:"
                                                   Style="{StaticResource CaptionText}"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding ModelKey}"
                                                   FontSize="12"
                                                   FontFamily="Consolas"
                                                   Margin="0,0,16,0"/>

                                        <TextBlock Text="Size:"
                                                   Style="{StaticResource CaptionText}"
                                                   Margin="0,0,8,0"
                                                   Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding FileSizeDisplay}"
                                                   FontSize="12"
                                                   Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>

                                    <!-- Buttons -->
                                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                                Orientation="Horizontal"
                                                Margin="0,4,0,0">
                                        <Button Style="{StaticResource ButtonPrimary}"
                                                Command="{Binding DataContext.DownloadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,8,0"
                                                Visibility="{Binding IsInstalled, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial Kind="Download" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Download" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Style="{StaticResource ButtonDanger}"
                                                Command="{Binding DataContext.UninstallCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Deinstallieren" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <!-- Progress Bar -->
                                    <ProgressBar Grid.Row="0" Grid.Column="1"
                                                 Value="{Binding DownloadProgress}"
                                                 Minimum="0" Maximum="100"
                                                 Width="120" Height="8"
                                                 VerticalAlignment="Center"
                                                 Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
