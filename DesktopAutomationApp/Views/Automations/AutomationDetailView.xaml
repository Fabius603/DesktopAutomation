<UserControl xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" x:Class="DesktopAutomationApp.Views.AutomationDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Style="{StaticResource ContentViewBase}">
    <UserControl.Resources>
        <Style x:Key="AutomationExpanderToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="HeaderBorder" Background="Transparent" CornerRadius="4" Padding="6,5">
                            <DockPanel>
                                <TextBlock x:Name="Arrow" Text="{loc:Translate Key=Ui.7BB37DF5CB36}" FontSize="20" Margin="0,0,8,0"
                                           VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform><RotateTransform Angle="0"/></TextBlock.RenderTransform>
                                </TextBlock>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform"><Setter.Value><RotateTransform Angle="90"/></Setter.Value></Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource App.Brush.SurfaceHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AutomationExpanderStyle" TargetType="Expander">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <ToggleButton Grid.Row="0" Style="{StaticResource AutomationExpanderToggleStyle}"
                                          Content="{TemplateBinding Header}"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>
                            <ContentPresenter x:Name="ContentSite" Grid.Row="1" ContentSource="Content" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True"><Setter TargetName="ContentSite" Property="Visibility" Value="Visible"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonPrimary}" Command="{Binding SaveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.548611CE58F7}"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding CancelCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Cancel" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.F6B2FF39F540}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding BackCommand}" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.594CA889C442}"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}" Margin="0,0,12,0"/>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding RenameCommand}" ToolTip="{loc:Translate Key=Ui.83E07ED1F359}">
                    <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                </Button>
            </StackPanel>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Text="{loc:Translate Key=Ui.E9262F007DFB}" VerticalAlignment="Top"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditedAutomation.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="54" TextWrapping="Wrap" AcceptsReturn="True"/>
                        <TextBlock Grid.Row="1" Text="{loc:Translate Key=Ui.8163454F378F}" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding EditedAutomation.Active, Mode=TwoWay}"
                                  Margin="0,10,0,0" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Expander Style="{StaticResource AutomationExpanderStyle}" IsExpanded="True" Margin="0,0,0,12">
                    <Expander.Header>
                        <TextBlock Text="{loc:Translate Key=Ui.8B9C643731C9}" Style="{StaticResource Heading2}" Margin="4,6"/>
                    </Expander.Header>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Text="{loc:Translate Key=Ui.15CE2119C2DA}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding TriggerKinds}"
                                      SelectedItem="{Binding EditedAutomation.TriggerKind, Mode=TwoWay}" MinWidth="240">
                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource LocalizedEnumConverter}}"/></DataTemplate></ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Text="{loc:Translate Key=Ui.6A6485AF02CA}" VerticalAlignment="Center" Margin="0,10,0,0"
                                       Visibility="{Binding EditedAutomation.IsHotkeyTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0"
                                        Visibility="{Binding EditedAutomation.IsHotkeyTrigger, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBox IsReadOnly="True" Width="240" Text="{Binding EditedAutomation.DisplayTrigger, Mode=OneWay}"/>
                                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding CaptureHotkeyCommand}" Margin="8,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Keyboard" Width="14" Height="14" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Translate Key=Ui.D0F2D9E1CC3B}"/>
                                    </StackPanel>
                                </Button>
                                <mah:ProgressRing IsActive="{Binding IsCapturingHotkey}" Width="20" Height="20" Margin="10,0,0,0"
                                                  Visibility="{Binding IsCapturingHotkey, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <TextBlock Text="{Binding HotkeyCaptureStatus}" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{DynamicResource App.Brush.Accent}"
                                           Visibility="{Binding IsCapturingHotkey, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Text="{loc:Translate Key=Ui.63D6160302C5}" VerticalAlignment="Center" Margin="0,10,0,0"
                                       Visibility="{Binding EditedAutomation.IsOnceAtTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <mah:DateTimePicker Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Width="230" HorizontalAlignment="Left"
                                                SelectedDateFormat="Short" SelectedTimeFormat="Short" IsClockVisible="False"
                                                PreviewKeyDown="Picker_PreviewKeyDown" SelectedDateTime="{Binding EditedAutomation.RunAt, Mode=TwoWay}"
                                                Visibility="{Binding EditedAutomation.IsOnceAtTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <TextBlock Grid.Row="2" Text="{loc:Translate Key=Ui.619BE40DDBBF}" VerticalAlignment="Top" Margin="0,16,0,0"
                                       Visibility="{Binding EditedAutomation.IsScheduleTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,10,0,0"
                                        Visibility="{Binding EditedAutomation.IsScheduleTrigger, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <mah:TimePicker PreviewKeyDown="Picker_PreviewKeyDown" SelectedTimeFormat="Short" IsClockVisible="False"
                                                SelectedDateTime="{Binding EditedAutomation.ScheduleTime, Mode=TwoWay}"
                                                Width="150" HorizontalAlignment="Left"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <CheckBox Content="{loc:Translate Key=Ui.D23E867E38E8}" IsChecked="{Binding EditedAutomation.Monday}" Margin="0,0,10,0"/>
                                    <CheckBox Content="{loc:Translate Key=Ui.16AB72874809}" IsChecked="{Binding EditedAutomation.Tuesday}" Margin="0,0,10,0"/>
                                    <CheckBox Content="{loc:Translate Key=Ui.D8F33A13AE6E}" IsChecked="{Binding EditedAutomation.Wednesday}" Margin="0,0,10,0"/>
                                    <CheckBox Content="{loc:Translate Key=Ui.30094E0BEC00}" IsChecked="{Binding EditedAutomation.Thursday}" Margin="0,0,10,0"/>
                                    <CheckBox Content="{loc:Translate Key=Ui.EED8F901692D}" IsChecked="{Binding EditedAutomation.Friday}" Margin="0,0,10,0"/>
                                    <CheckBox Content="{loc:Translate Key=Ui.A951EFC79DEB}" IsChecked="{Binding EditedAutomation.Saturday}" Margin="0,0,10,0"/>
                                    <CheckBox Content="{loc:Translate Key=Ui.FB1DF1A24E3F}" IsChecked="{Binding EditedAutomation.Sunday}"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Grid.Row="3" Text="{loc:Translate Key=Ui.21FBABA024F7}" VerticalAlignment="Center" Margin="0,10,0,0"
                                       Visibility="{Binding EditedAutomation.IsIntervalTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0"
                                        Visibility="{Binding EditedAutomation.IsIntervalTrigger, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBox Text="{Binding EditedAutomation.IntervalValue, Mode=TwoWay}" Width="70"/>
                                <ComboBox ItemsSource="{Binding IntervalUnits}" SelectedItem="{Binding EditedAutomation.IntervalUnit, Mode=TwoWay}"
                                          Width="140" Margin="8,0,0,0">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource LocalizedEnumConverter}}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>
                                <CheckBox Content="{loc:Translate Key=Ui.778A744FBFB5}" IsChecked="{Binding EditedAutomation.StartImmediately, Mode=TwoWay}"
                                          Margin="14,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Row="4" Text="{loc:Translate Key=Ui.CD9BB3B40997}" VerticalAlignment="Top" Margin="0,16,0,0"
                                       Visibility="{Binding EditedAutomation.IsProcessTrigger, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <Grid Grid.Row="4" Grid.Column="1" Margin="0,10,0,0"
                                  Visibility="{Binding EditedAutomation.IsProcessTrigger, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Translate Key=Ui.C2C6BC77B873}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditedAutomation.ProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="{loc:Translate Key=Ui.19C114F5BB77}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Translate Key=Ui.68C6E91706D3}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditedAutomation.WindowTitleContains, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="{loc:Translate Key=Ui.2B5AAA3CF344}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditedAutomation.DelayAfterEventSeconds, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Expander>

                <Expander Style="{StaticResource AutomationExpanderStyle}" IsExpanded="True" Margin="0,0,0,12">
                    <Expander.Header>
                        <TextBlock Text="{loc:Translate Key=Ui.A4AD259E71CB}" Style="{StaticResource Heading2}" Margin="4,6"/>
                    </Expander.Header>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid Margin="12">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="{loc:Translate Key=Ui.66036A4014DD}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding ActionsView}" DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedAction, Mode=TwoWay}" MinWidth="280">
                                <ComboBox.GroupStyle>
                                    <GroupStyle><GroupStyle.HeaderTemplate><DataTemplate>
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource App.Brush.Accent}" FontWeight="SemiBold" Margin="4"/>
                                    </DataTemplate></GroupStyle.HeaderTemplate></GroupStyle>
                                </ComboBox.GroupStyle>
                            </ComboBox>
                        </Grid>
                    </Border>
                </Expander>

                <Expander Style="{StaticResource AutomationExpanderStyle}" IsExpanded="True">
                    <Expander.Header>
                        <TextBlock Text="{loc:Translate Key=Ui.B3ECF7CD4BE6}" Style="{StaticResource Heading2}" Margin="4,6"/>
                    </Expander.Header>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid Margin="12">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="{loc:Translate Key=Ui.A3E13215000C}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding RunningBehaviors}"
                                      SelectedItem="{Binding EditedAutomation.AlreadyRunningBehavior, Mode=TwoWay}"
                                      Width="200" HorizontalAlignment="Left">
                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource LocalizedEnumConverter}}"/></DataTemplate></ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Text="{loc:Translate Key=Ui.0924A671165F}" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBox Text="{Binding EditedAutomation.CooldownSeconds, Mode=TwoWay}" Width="80"/>
                                <TextBlock Text="{loc:Translate Key=Ui.137B664AD5FB}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Row="2" Text="{loc:Translate Key=Ui.FB5DEA1268EA}" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <mah:TimePicker Grid.Row="2" Grid.Column="1" PreviewKeyDown="Picker_PreviewKeyDown" SelectedTimeFormat="Short" IsClockVisible="False"
                                            SelectedDateTime="{Binding EditedAutomation.EnabledFrom, Mode=TwoWay}"
                                            Width="150" HorizontalAlignment="Left" Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="3" Text="{loc:Translate Key=Ui.A1C8E14A1EEE}" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <mah:TimePicker Grid.Row="3" Grid.Column="1" PreviewKeyDown="Picker_PreviewKeyDown" SelectedTimeFormat="Short" IsClockVisible="False"
                                            SelectedDateTime="{Binding EditedAutomation.EnabledUntil, Mode=TwoWay}"
                                            Width="150" HorizontalAlignment="Left" Margin="0,10,0,0"
                                            ToolTip="{loc:Translate Key=Ui.A0D222667945}"/>
                        </Grid>
                    </Border>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
