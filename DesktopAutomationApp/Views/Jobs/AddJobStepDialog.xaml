                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Model" Style="{StaticResource StepFieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding YoloDetectionStep_AvailableModels}"
                                      SelectedItem="{Binding YoloDetectionStep_Model}"
                                      IsEditable="True"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Klassenname" Style="{StaticResource StepFieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding YoloDetectionStep_AvailableClasses}"
                                      SelectedItem="{Binding YoloDetectionStep_ClassName}"
                                      IsEditable="True"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ROI" Style="{StaticResource StepFieldLabel}"/>
                            <WrapPanel Grid.Column="1" Style="{StaticResource RoiFieldWrapPanel}">
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="X" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
                                    <TextBox Style="{StaticResource StepGroupedTextBox}" Text="{Binding YoloDetectionStep_RoiX, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="Y" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
                                    <TextBox Style="{StaticResource StepGroupedTextBox}" Text="{Binding YoloDetectionStep_RoiY, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="Breite" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
