                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Confidence (0…1)" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepCompactTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding YoloDetectionStep_ConfidenceThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Timeout ── -->
                    <StackPanel Visibility="{Binding ShowTimeout, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Wartezeit (ms)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="120" HorizontalAlignment="Left"
                                     Text="{Binding TimeoutStep_DelayMs, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── ActiveProcess ── -->
                    <StackPanel Visibility="{Binding ShowActiveProcess, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Prozessname" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ActiveProcessStep_ProcessName, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="z. B. notepad oder notepad.exe"/>
                        </Grid>
                        <TextBlock Foreground="{StaticResource App.Brush.TextMuted}" FontSize="11" Margin="0,0,0,4"
                                   TextWrapping="Wrap"
                                   Text="Ergebnis (Erfolgreich = Prozess läuft) kann in If-Bedingungen ausgewertet werden."/>
                    </StackPanel>

                    <!-- ── StartProcess ── -->
                    <StackPanel Visibility="{Binding ShowStartProcess, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pfad / Programm" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding StartProcessStep_ExecutablePath, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="Pfad zur .exe oder Programmname"/>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseExecutablePathCommand}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Argumente" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding StartProcessStep_Arguments, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="optional"/>
                        </Grid>
                        <CheckBox Content="Auf Beendigung warten"
                                  IsChecked="{Binding StartProcessStep_WaitForExit}"
                                  Margin="0,0,0,4"/>
                    </StackPanel>

                    <!-- ── FocusProcess ── -->
                    <StackPanel Visibility="{Binding ShowFocusProcess, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pfad / Programm" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding FocusProcessStep_ExecutablePath, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="Pfad zur .exe oder Programmname"/>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseFocusProcessPathCommand}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Fenstermodus" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1" Width="160" HorizontalAlignment="Left"
                                      ItemsSource="{Binding FocusProcessWindowModes}"
                                      SelectedItem="{Binding FocusProcessStep_WindowMode}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── ShowText ── -->
                    <StackPanel Visibility="{Binding ShowShowText, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <!-- Text -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Text" VerticalAlignment="Top" Margin="0,4,0,0"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" AcceptsReturn="True" MinHeight="60" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding ShowTextStep_Text, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="Anzuzeigender Text (leer = entfernen)"/>
                        </Grid>

                        <!-- Schriftgröße -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Schriftgröße (pt)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowTextStep_FontSize, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- Schriftfarbe -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Schriftfarbe" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <mah:ColorPicker Grid.Column="1"
                                             SelectedColor="{Binding ShowTextStep_FontColorWpf}"
                                             HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- Deckkraft -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Deckkraft" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                                    Value="{Binding ShowTextStep_Opacity}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="6,0,0,0"
                                       Text="{Binding ShowTextStep_Opacity, StringFormat={}{0:P0}}"/>
                        </Grid>

                        <!-- Anzeigedauer -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Anzeigedauer (ms)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowTextStep_DurationMs, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="0 = dauerhaft"/>
                        </Grid>

                        <!-- Bei Job-Ende entfernen -->
                        <CheckBox Content="Bei Job-Ende entfernen"
                                  IsChecked="{Binding ShowTextStep_ClearOnJobEnd}"
                                  Margin="0,0,0,8"/>

                        <TextBlock Text="Position" FontWeight="SemiBold" Margin="0,4,0,6"
                                   Foreground="{StaticResource App.Brush.TextSecondary}"/>

                        <!-- Monitor wählen (wie DesktopDuplication) -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Desktop Index" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="60" IsReadOnly="True"
                                     Text="{Binding ShowTextStep_DesktopIndex}"/>
                            <Button Grid.Column="2" Content="Monitor wählen" Margin="8,0,0,0" Padding="10,5"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ChooseMonitorForShowTextCommand}"/>
                        </Grid>

                        <!-- X-Offset -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X-Offset (Pixel)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowTextStep_OffsetX, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- Y-Offset -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Y-Offset (Pixel)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowTextStep_OffsetY, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── ActiveWindow ── -->
                    <StackPanel Visibility="{Binding ShowActiveWindow, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Prozessname" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ActiveWindowStep_ProcessName, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="z. B. notepad oder notepad.exe"/>
                        </Grid>
                        <TextBlock Foreground="{StaticResource App.Brush.TextMuted}" FontSize="11" Margin="0,0,0,4"
                                   TextWrapping="Wrap"
                                   Text="Ergebnis (Fenster aktiv) kann in If-Bedingungen ausgewertet werden."/>
                    </StackPanel>

                    <!-- ── KeyPoint Matching ── -->
                    <StackPanel Visibility="{Binding ShowKeyPointMatching, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Capture-Step" Style="{StaticResource StepFieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding KeyPointMatchingStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Template" Style="{StaticResource StepFieldLabel}"/>
                            <StackPanel Grid.Column="1">
                                <TextBox Text="{Binding KeyPointMatchingStep_TemplatePath, UpdateSourceTrigger=PropertyChanged}"/>
                                <Border Style="{StaticResource TemplatePreviewBorder}"
                                        Visibility="{Binding KeyPointMatchingStep_HasTemplatePreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Image Source="{Binding KeyPointMatchingStep_TemplatePreview}" Stretch="Uniform"/>
                                </Border>
                            </StackPanel>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseKeyPointMatchingTemplatePathCommand}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ROI" Style="{StaticResource StepFieldLabel}"/>
                            <WrapPanel Grid.Column="1" Style="{StaticResource RoiFieldWrapPanel}">
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="X" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
                                    <TextBox Style="{StaticResource StepGroupedTextBox}" Text="{Binding KeyPointMatchingStep_RoiX, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="Y" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
                                    <TextBox Style="{StaticResource StepGroupedTextBox}" Text="{Binding KeyPointMatchingStep_RoiY, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="Breite" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
                                    <TextBox Style="{StaticResource StepGroupedTextBox}" Text="{Binding KeyPointMatchingStep_RoiW, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="Höhe" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
                                    <TextBox Style="{StaticResource StepGroupedTextBox}" Text="{Binding KeyPointMatchingStep_RoiH, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <Button Content="Aufnehmen" Style="{StaticResource StepInlineButton}"
                                        Command="{Binding CaptureKeyPointMatchingRoiCommand}"/>
                            </WrapPanel>
                        </Grid>
                        <CheckBox Content="ROI aktivieren" IsChecked="{Binding KeyPointMatchingStep_EnableROI}" Margin="140,0,0,10"/>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Min. Matches" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepCompactTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding KeyPointMatchingStep_MinMatchCount, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Lowe's Ratio (0…1)" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepCompactTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding KeyPointMatchingStep_LowesRatioThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── If ── -->
                    <StackPanel Visibility="{Binding ShowIf, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <!-- MatchMode -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Verknüpfung:" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <RadioButton Content="Alle (AND)" VerticalAlignment="Center"
                                         IsChecked="{Binding IfStep_MatchModeIsAll}" Margin="0,0,12,0"/>
                            <RadioButton Content="Eine (OR)" VerticalAlignment="Center"
                                         IsChecked="{Binding IfStep_MatchModeIsAny}"/>
                        </StackPanel>
                        <!-- Condition rows -->
                        <ItemsControl ItemsSource="{Binding IfStep_Conditions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="26"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                            <TextBlock Text="Quell-Step" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <ComboBox ItemsSource="{Binding AvailableSourceSteps}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedItem="{Binding SelectedSourceStep}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,4,0">
                                            <TextBlock Text="Eigenschaft" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <ComboBox ItemsSource="{Binding AvailableProperties}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedItem="{Binding SelectedProperty}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,4,0">
                                            <TextBlock Text="Operator" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <ComboBox MinWidth="90"
                                                      ItemsSource="{Binding AvailableOperators}"
                                                      SelectedItem="{Binding SelectedOperator}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource ConditionOperatorConverter}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Margin="0,0,4,0"
                                                    Visibility="{Binding ShowComparisonValue, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Wert" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding ComparisonValue, UpdateSourceTrigger=PropertyChanged}"
                                                     VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        <Button Grid.Column="4" Content="×" VerticalAlignment="Bottom"
                                                Command="{Binding RemoveCommand}"
                                                FontSize="14" Padding="4,2" Margin="0,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Bedingung hinzufügen"
                                Command="{Binding IfStep_AddConditionCommand}"
                                HorizontalAlignment="Left" Margin="0,6,0,0"
                                Style="{StaticResource ButtonSecondary}"
                                Padding="8,4" FontSize="11"/>
                    </StackPanel>

                    <!-- ── ElseIf ── -->
                    <StackPanel Visibility="{Binding ShowElseIf, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <!-- MatchMode -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Verknüpfung:" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <RadioButton Content="Alle (AND)" VerticalAlignment="Center"
                                         IsChecked="{Binding ElseIfStep_MatchModeIsAll}" Margin="0,0,12,0"/>
                            <RadioButton Content="Eine (OR)" VerticalAlignment="Center"
                                         IsChecked="{Binding ElseIfStep_MatchModeIsAny}"/>
                        </StackPanel>
                        <!-- Condition rows -->
                        <ItemsControl ItemsSource="{Binding ElseIfStep_Conditions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="26"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                            <TextBlock Text="Quell-Step" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <ComboBox ItemsSource="{Binding AvailableSourceSteps}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedItem="{Binding SelectedSourceStep}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,4,0">
                                            <TextBlock Text="Eigenschaft" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <ComboBox ItemsSource="{Binding AvailableProperties}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedItem="{Binding SelectedProperty}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,4,0">
                                            <TextBlock Text="Operator" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <ComboBox MinWidth="90"
                                                      ItemsSource="{Binding AvailableOperators}"
                                                      SelectedItem="{Binding SelectedOperator}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource ConditionOperatorConverter}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Margin="0,0,4,0"
                                                    Visibility="{Binding ShowComparisonValue, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Wert" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding ComparisonValue, UpdateSourceTrigger=PropertyChanged}"
                                                     VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        <Button Grid.Column="4" Content="×" VerticalAlignment="Bottom"
                                                Command="{Binding RemoveCommand}"
                                                FontSize="14" Padding="4,2" Margin="0,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Bedingung hinzufügen"
                                Command="{Binding ElseIfStep_AddConditionCommand}"
                                HorizontalAlignment="Left" Margin="0,6,0,0"
                                Style="{StaticResource ButtonSecondary}"
                                Padding="8,4" FontSize="11"/>
                    </StackPanel>

                    <!-- ── Else ── -->
                    <StackPanel Visibility="{Binding ShowElse, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Keine Konfiguration erforderlich. Dieser Block wird ausgeführt, wenn keine vorherige Bedingung zutraf."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource App.Brush.TextMuted}"
                                   FontStyle="Italic" FontSize="12"/>
                    </StackPanel>

                    <!-- ── EndIf ── -->
                    <StackPanel Visibility="{Binding ShowEndIf, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Keine Konfiguration erforderlich. Beendet den vorherigen If/ElseIf/Else-Block."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource App.Brush.TextMuted}"
                                   FontStyle="Italic" FontSize="12"/>
                    </StackPanel>

                    <!-- ── EndJob ── -->
                    <StackPanel Visibility="{Binding ShowEndJob, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Keine Konfiguration erforderlich. Beendet den Job sofort – nachfolgende Steps werden nicht mehr ausgeführt."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource App.Brush.TextMuted}"
                                   FontStyle="Italic" FontSize="12"/>
                    </StackPanel>

                    <!-- ── Point Comparison ── -->
                    <StackPanel Visibility="{Binding ShowPointComparison, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Margin="0,0,0,4">

                        <!-- Grundeinstellungen -->
                        <Border Background="{StaticResource App.Brush.Surface}"
                                BorderBrush="{StaticResource App.Brush.CardBorder}"
                                BorderThickness="1" CornerRadius="6" Padding="10,10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="GRUNDEINSTELLUNGEN" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource App.Brush.TextMuted}" Margin="0,0,0,8"/>

                                <!-- Vergleichsmodus als gleichmäßige 2-Spalten-Auswahl -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Modus" VerticalAlignment="Center"
                                               FontSize="12" Foreground="{StaticResource App.Brush.TextSecondary}"/>
                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" CornerRadius="4" Padding="8,5" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{StaticResource App.Brush.CardBorder}"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PointComparisonStep_ModeIsOffset}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource App.Brush.Accent}"/>
                                                            <Setter Property="Background" Value="{StaticResource App.Brush.AccentSubtle}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <RadioButton IsChecked="{Binding PointComparisonStep_ModeIsOffset}">
                                                <StackPanel>
                                                    <TextBlock Text="Offset / Toleranz" FontSize="11" FontWeight="Medium"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="Nah an Referenzpunkt" FontSize="10"
                                                               Foreground="{StaticResource App.Brush.TextMuted}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </RadioButton>
                                        </Border>
                                        <Border Grid.Column="2" CornerRadius="4" Padding="8,5" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{StaticResource App.Brush.CardBorder}"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PointComparisonStep_ModeIsExpression}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource App.Brush.Accent}"/>
                                                            <Setter Property="Background" Value="{StaticResource App.Brush.AccentSubtle}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <RadioButton IsChecked="{Binding PointComparisonStep_ModeIsExpression}">
                                                <StackPanel>
                                                    <TextBlock Text="Ausdruck" FontSize="11" FontWeight="Medium"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="X/Y-Vergleich (X &gt; 100)" FontSize="10"
                                                               Foreground="{StaticResource App.Brush.TextMuted}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </RadioButton>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <!-- Übereinstimmungsregel -->
                                <Rectangle Height="1" Fill="{StaticResource App.Brush.CardBorder}" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Auswertung" VerticalAlignment="Center"
                                               FontSize="12" Foreground="{StaticResource App.Brush.TextSecondary}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton Content="Alle (AND)" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_MatchRequirementIsAll}" Margin="0,0,16,0"/>
                                        <RadioButton Content="Mindestens einer (OR)" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_MatchRequirementIsAny}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Offset-Einstellungen -->
                        <Border Visibility="{Binding PointComparisonStep_ModeIsOffset, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Background="{StaticResource App.Brush.Surface}"
                                BorderBrush="{StaticResource App.Brush.CardBorder}"
                                BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="REFERENZPUNKT &amp; TOLERANZ" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource App.Brush.TextMuted}" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Referenzquelle" VerticalAlignment="Center"
                                               Foreground="{StaticResource App.Brush.TextSecondary}" FontSize="12"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton Content="Manuell eingeben" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_RefIsManual}" Margin="0,0,20,0"/>
                                        <RadioButton Content="Aus Detection-Ergebnis" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_RefIsJobResult}"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Visibility="{Binding PointComparisonStep_RefIsManual, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Koordinaten (X / Y)" VerticalAlignment="Center"
                                               Foreground="{StaticResource App.Brush.TextSecondary}" FontSize="12"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="X" VerticalAlignment="Center" Width="16"
                                                   FontWeight="SemiBold" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                        <TextBox Width="80" Text="{Binding PointComparisonStep_RefX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,16,0"/>
                                        <TextBlock Text="Y" VerticalAlignment="Center" Width="16"
                                                   FontWeight="SemiBold" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                        <TextBox Width="80" Text="{Binding PointComparisonStep_RefY, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Visibility="{Binding PointComparisonStep_RefIsJobResult, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Detection-Step" VerticalAlignment="Center"
                                               Foreground="{StaticResource App.Brush.TextSecondary}" FontSize="12"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableDetectionSteps}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedItem="{Binding PointComparisonStep_RefDetectionStep}"/>
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource App.Brush.CardBorder}" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Toleranz (Pixel)" FontSize="12"
                                                   Foreground="{StaticResource App.Brush.TextSecondary}"/>
                                        <TextBlock Text="Maximale Abweichung" FontSize="10"
                                                   Foreground="{StaticResource App.Brush.TextMuted}" Margin="0,1,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="X" VerticalAlignment="Center" Width="16"
                                                   FontWeight="SemiBold" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                        <TextBox Width="80" Text="{Binding PointComparisonStep_OffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,16,0"/>
                                        <TextBlock Text="Y" VerticalAlignment="Center" Width="16"
                                                   FontWeight="SemiBold" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                        <TextBox Width="80" Text="{Binding PointComparisonStep_OffsetY, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Ausdrucks-Einstellungen -->
                        <Border Visibility="{Binding PointComparisonStep_ModeIsExpression, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Background="{StaticResource App.Brush.Surface}"
                                BorderBrush="{StaticResource App.Brush.CardBorder}"
                                BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="ACHSEN-AUSDRÜCKE" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource App.Brush.TextMuted}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Verknüpfen mit:" FontSize="11"
                                                   Foreground="{StaticResource App.Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <RadioButton Content="AND (alle)" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_ExprCombineIsAnd}" Margin="0,0,12,0"/>
                                        <RadioButton Content="OR (einer)" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_ExprCombineIsOr}"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Achse" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource App.Brush.TextMuted}"/>
                                    <TextBlock Grid.Column="1" Text="Operator" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource App.Brush.TextMuted}"/>
                                    <TextBlock Grid.Column="2" Text="Vergleichswert" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource App.Brush.TextMuted}"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding PointComparisonStep_Expressions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0" Margin="0,0,6,0"
                                                          ItemsSource="{Binding AvailableAxes}"
                                                          SelectedItem="{Binding Axis}"/>
                                                <ComboBox Grid.Column="1" Margin="0,0,6,0"
                                                          ItemsSource="{Binding AvailableOperators}"
                                                          SelectedItem="{Binding Operator}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource PointAxisOperatorConverter}}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBox Grid.Column="2" Margin="0,0,6,0"
                                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                         VerticalContentAlignment="Center"/>
                                                <Button Grid.Column="3" Content="×"
                                                        Command="{Binding RemoveCommand}"
                                                        FontSize="13" Padding="4,2"
                                                        ToolTip="Ausdruck entfernen"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="+ Ausdruck hinzufügen"
                                        Command="{Binding PointComparisonStep_AddExpressionCommand}"
                                        HorizontalAlignment="Left" Margin="0,8,0,0"
                                        Style="{StaticResource ButtonSecondary}"
                                        Padding="10,5" FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <!-- Zu prüfende Punkte -->
                        <Border Background="{StaticResource App.Brush.Surface}"
                                BorderBrush="{StaticResource App.Brush.CardBorder}"
                                BorderThickness="1" CornerRadius="6" Padding="14,12">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="ZU PRÜFENDE PUNKTE" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource App.Brush.TextMuted}"/>
                                        <TextBlock Text="Diese Punkte werden gegen die Bedingung geprüft" FontSize="11"
                                                   Foreground="{StaticResource App.Brush.TextMuted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="+ Punkt hinzufügen"
                                            Command="{Binding PointComparisonStep_AddPointCommand}"
                                            Style="{StaticResource ButtonSecondary}"
                                            Padding="10,5" FontSize="11" VerticalAlignment="Top"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding PointComparisonStep_Points}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource App.Brush.WindowBackground}"
                                                    BorderBrush="{StaticResource App.Brush.CardBorder}"
                                                    BorderThickness="1" CornerRadius="5"
                                                    Padding="12,10" Margin="0,0,0,6">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="90"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Punktquelle" VerticalAlignment="Center"
                                                                   FontSize="11" Foreground="{StaticResource App.Brush.TextSecondary}"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <RadioButton Content="Manuell" VerticalAlignment="Center"
                                                                         IsChecked="{Binding IsManual}" Margin="0,0,16,0"/>
                                                            <RadioButton Content="Aus Detection-Ergebnis" VerticalAlignment="Center"
                                                                         IsChecked="{Binding IsJobResult}"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="2" Content="× Entfernen"
                                                                Command="{Binding RemoveCommand}"
                                                                FontSize="11" Padding="8,3"/>
                                                    </Grid>
                                                    <Grid Visibility="{Binding ShowManual, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="90"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Koordinaten" VerticalAlignment="Center"
                                                                   FontSize="11" Foreground="{StaticResource App.Brush.TextSecondary}"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                            <TextBlock Text="X" VerticalAlignment="Center" Width="16"
                                                                       FontWeight="SemiBold" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                                            <TextBox Width="90" Margin="0,0,16,0"
                                                                     Text="{Binding ManualX, UpdateSourceTrigger=PropertyChanged}"/>
                                                            <TextBlock Text="Y" VerticalAlignment="Center" Width="16"
                                                                       FontWeight="SemiBold" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                                            <TextBox Width="90"
                                                                     Text="{Binding ManualY, UpdateSourceTrigger=PropertyChanged}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <StackPanel Visibility="{Binding ShowJobResult, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="Detection-Step" VerticalAlignment="Center"
                                                                       FontSize="11" Foreground="{StaticResource App.Brush.TextSecondary}"/>
                                                            <ComboBox Grid.Column="1"
                                                                      ItemsSource="{Binding AvailableDetectionSteps}"
                                                                      DisplayMemberPath="DisplayName"
                                                                      SelectedItem="{Binding SelectedDetectionStep}"/>
                                                        </Grid>
                                                        <CheckBox Content="Alle gefundenen Punkte dieses Steps verwenden"
                                                                  IsChecked="{Binding UseAllDetections}"
                                                                  Margin="90,0,0,0" FontSize="11"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Step-Beschreibung -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <Border Background="{StaticResource App.Brush.AccentSubtle}"
                    BorderBrush="{StaticResource App.Brush.Accent}"
                    BorderThickness="1" CornerRadius="6" Padding="12,9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <iconPacks:PackIconMaterial Grid.Column="0" Kind="InformationOutline"
                                               Foreground="{StaticResource App.Brush.Accent}"
                                               VerticalAlignment="Top" Margin="0,1,9,0"
                                               Width="14" Height="14"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding StepTypeDescription}"
                               Foreground="{StaticResource App.Brush.TextSecondary}"
                               TextWrapping="Wrap" FontSize="12"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Abbrechen" IsCancel="True" Margin="0,0,8,0"
                    Click="Cancel_Click" Style="{StaticResource ButtonSecondary}"/>
            <Button Content="{Binding ConfirmButtonText}" IsDefault="True"
                    Command="{Binding ConfirmCommand}" Style="{StaticResource ButtonPrimary}"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
