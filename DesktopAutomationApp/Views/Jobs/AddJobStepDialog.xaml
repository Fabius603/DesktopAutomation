                                <TextBlock Text="Y" Style="{StaticResource StepAxisLabel}"/>
                                <TextBox Style="{StaticResource StepCompactTextBox}" Text="{Binding KlickOnPoint3DStep_OriginY, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Aufnehmen" Style="{StaticResource StepInlineButton}"
                                    Command="{Binding CaptureKlickOnPoint3DOriginCommand}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Offset" Style="{StaticResource StepFieldLabel}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="X" Style="{StaticResource StepAxisLabel}"/>
                                <TextBox Style="{StaticResource StepCompactTextBox}" Text="{Binding KlickOnPoint3DStep_OffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                <TextBlock Text="Y" Style="{StaticResource StepAxisLabel}"/>
                                <TextBox Style="{StaticResource StepCompactTextBox}" Text="{Binding KlickOnPoint3DStep_OffsetY, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
