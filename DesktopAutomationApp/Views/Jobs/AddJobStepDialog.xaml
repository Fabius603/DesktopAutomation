<mah:MetroWindow x:Class="DesktopAutomationApp.Views.AddJobStepDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 WindowStartupLocation="CenterOwner"
                 Width="540" Height="560"
                 Title="{Binding DialogTitle}"
                 ResizeMode="CanResize" ShowInTaskbar="False"
                 Style="{StaticResource DialogWindowStyle}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Typauswahl -->
        <Border Grid.Row="0"
                Visibility="{Binding ShowTypeSelector, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="{StaticResource App.Brush.Surface}"
                CornerRadius="6" Padding="12,10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="STEP-TYP"
                           Foreground="{StaticResource App.Brush.TextMuted}"
                           FontSize="11" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <ComboBox Grid.Row="1"
                          ItemsSource="{Binding StepTypeItems}"
                          DisplayMemberPath="DisplayLabel"
                          SelectedValuePath="Name"
                          SelectedValue="{Binding SelectedType}"
                          FontSize="14" FontWeight="Medium"
                          MinHeight="38"
                          mah:ControlsHelper.CornerRadius="5">
                    <ComboBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource App.Brush.CardBorder}"
                                            BorderThickness="0,1,0,0"
                                            Margin="0,4,0,0" Padding="4,6,4,2">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource App.Brush.Accent}"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ComboBox.GroupStyle>
                </ComboBox>
            </Grid>
        </Border>

        <!-- Dynamische Felder -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <Border Background="{StaticResource App.Brush.Surface}" CornerRadius="6" Padding="14,12">
                <StackPanel>

                    <!-- ── Template Matching ── -->
                    <StackPanel Visibility="{Binding ShowTemplateMatching, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Capture-Step" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding TemplateMatchingStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Template-Pfad" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding TemplateMatchingStep_TemplatePath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseTemplatePathCommand}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Confidence (0…1)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding TemplateMatchingStep_ConfidenceThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Match Mode" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding TemplateMatchModesAll}"
                                      SelectedItem="{Binding TemplateMatchingStep_TemplateMatchMode}"/>
                        </Grid>
                        <CheckBox Content="Ergebnisse zeichnen" IsChecked="{Binding TemplateMatchingStep_DrawResults}" Margin="0,0,0,8"/>
                        <CheckBox Content="ROI aktivieren" IsChecked="{Binding TemplateMatchingStep_EnableROI}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ROI" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding TemplateMatchingStep_RoiX}" Margin="0,0,8,0"/>
                                <TextBlock Text="Y" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding TemplateMatchingStep_RoiY}" Margin="0,0,8,0"/>
                                <TextBlock Text="B" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding TemplateMatchingStep_RoiW}" Margin="0,0,8,0"/>
                                <TextBlock Text="H" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding TemplateMatchingStep_RoiH}"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="ROI erfassen" HorizontalAlignment="Left" Padding="10,5"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding CaptureTemplateMatchingRoiCommand}"/>
                    </StackPanel>

                    <!-- ── Desktop Duplication ── -->
                    <StackPanel Visibility="{Binding ShowDesktopDuplication, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Desktop Index" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="60" IsReadOnly="True"
                                     Text="{Binding DesktopDuplicationStep_DesktopIdx}"/>
                            <Button Grid.Column="2" Content="Monitor wählen" Margin="8,0,0,0" Padding="10,5"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ChooseMonitorCommand}"/>
                        </Grid>
                        <CheckBox Margin="0,6,0,0"
                                  Content="Mauszeiger aufnehmen"
                                  IsChecked="{Binding DesktopDuplicationStep_CaptureCursor}"/>
                    </StackPanel>

                    <!-- ── Show Image ── -->
                    <StackPanel Visibility="{Binding ShowShowImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Capture-Step" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding ShowImageStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Detection-Step (opt.)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableDetectionSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding ShowImageStep_SourceDetectionStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Fenstername" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowImageStep_WindowName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Bildquelle" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1" Width="180" HorizontalAlignment="Left"
                                      ItemsSource="{Binding ImageModeOptions}"
                                      SelectedItem="{Binding ShowImageStep_ImageMode}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Show On Desktop ── -->
                    <StackPanel Visibility="{Binding ShowShowOnDesktop, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Detection-Step" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableDetectionSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding ShowOnDesktopStep_SourceDetectionStep}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Video Creation ── -->
                    <StackPanel Visibility="{Binding ShowVideoCreation, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Capture-Step" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding VideoCreationStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Detection-Step (opt.)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableDetectionSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding VideoCreationStep_SourceDetectionStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Speicherpfad" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Text="{Binding VideoCreationStep_SavePath}" IsReadOnly="True"/>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseVideoSavePathCommand}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Dateiname" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding VideoCreationStep_FileName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Bildquelle" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1" Width="180" HorizontalAlignment="Left"
                                      ItemsSource="{Binding ImageModeOptions}"
                                      SelectedItem="{Binding VideoCreationStep_ImageMode}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Makro Execution ── -->
                    <StackPanel Visibility="{Binding ShowMakroExecution, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Makro" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableMakros}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding MakroExecutionStep_SelectedMakro}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Job Execution ── -->
                    <StackPanel Visibility="{Binding ShowJobExecution, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Job" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableJobs}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding JobExecutionStep_SelectedJob}"/>
                        </Grid>
                        <CheckBox Content="Auf Beendigung warten" IsChecked="{Binding JobExecutionStep_WaitForCompletion}"/>
                    </StackPanel>

                    <!-- ── Script Execution ── -->
                    <StackPanel Visibility="{Binding ShowScriptExecution, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Script-Pfad" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ScriptExecutionStep_ScriptPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseScriptPathCommand}"/>
                        </Grid>
                        <CheckBox Content="Auf Beendigung warten"
                                  IsChecked="{Binding ScriptExecutionStep_WaitForExit}"/>
                    </StackPanel>

                    <!-- ── KlickOnPoint ── -->
                    <StackPanel Visibility="{Binding ShowKlickOnPoint, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Detection-Step" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableDetectionSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding KlickOnPointStep_SourceDetectionStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Klick-Typ" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1" Width="120" HorizontalAlignment="Left"
                                      SelectedItem="{Binding KlickOnPointStep_ClickType}">
                                <ComboBox.Items>
                                    <sys:String>left</sys:String>
                                    <sys:String>right</sys:String>
                                    <sys:String>middle</sys:String>
                                    <sys:String>none</sys:String>
                                </ComboBox.Items>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Timeout (ms)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding KlickOnPointStep_TimeoutMs}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Offset X" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding KlickOnPointStep_OffsetX}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Offset Y" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding KlickOnPointStep_OffsetY}"/>
                        </Grid>
                        <CheckBox Content="Doppelklick" IsChecked="{Binding KlickOnPointStep_DoubleClick}"/>
                    </StackPanel>

                    <!-- ── KlickOnPoint3D ── -->
                    <StackPanel Visibility="{Binding ShowKlickOnPoint3D, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Detection-Step" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableDetectionSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding KlickOnPoint3DStep_SourceDetectionStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Capture-Step" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding KlickOnPoint3DStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Klick-Typ" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1" Width="120" HorizontalAlignment="Left"
                                      SelectedItem="{Binding KlickOnPoint3DStep_ClickType}">
                                <ComboBox.Items>
                                    <sys:String>left</sys:String>
                                    <sys:String>right</sys:String>
                                    <sys:String>middle</sys:String>
                                    <sys:String>none</sys:String>
                                </ComboBox.Items>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Timeout (ms)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding KlickOnPoint3DStep_Timeout}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="FOV" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding KlickOnPoint3DStep_FOV, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sensitivity X" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding KlickOnPoint3DStep_MausSensitivityX, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sensitivity Y" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding KlickOnPoint3DStep_MausSensitivityY, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                        <CheckBox Content="Doppelklick" IsChecked="{Binding KlickOnPoint3DStep_DoubleClick}" Margin="0,0,0,6"/>
                        <CheckBox Content="Mausbewegung Y invertieren" IsChecked="{Binding KlickOnPoint3DStep_InvertMouseMovementY}" Margin="0,0,0,6"/>
                        <CheckBox Content="Mausbewegung X invertieren" IsChecked="{Binding KlickOnPoint3DStep_InvertMouseMovementX}"/>
                    </StackPanel>

                    <!-- ── YOLO Detection ── -->
                    <StackPanel Visibility="{Binding ShowYoloDetection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Capture-Step" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding YoloDetectionStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Model" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding YoloDetectionStep_AvailableModels}"
                                      SelectedItem="{Binding YoloDetectionStep_Model}"
                                      IsEditable="True"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Klassenname" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding YoloDetectionStep_AvailableClasses}"
                                      SelectedItem="{Binding YoloDetectionStep_ClassName}"
                                      IsEditable="True"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Confidence (0…1)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding YoloDetectionStep_ConfidenceThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                        <CheckBox Content="Ergebnisse zeichnen" IsChecked="{Binding YoloDetectionStep_DrawResults}" Margin="0,0,0,8"/>
                        <CheckBox Content="ROI aktivieren" IsChecked="{Binding YoloDetectionStep_EnableROI}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ROI" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding YoloDetectionStep_RoiX}" Margin="0,0,8,0"/>
                                <TextBlock Text="Y" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding YoloDetectionStep_RoiY}" Margin="0,0,8,0"/>
                                <TextBlock Text="B" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding YoloDetectionStep_RoiW}" Margin="0,0,8,0"/>
                                <TextBlock Text="H" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding YoloDetectionStep_RoiH}"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="ROI erfassen" HorizontalAlignment="Left" Padding="10,5"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding CaptureYoloDetectionRoiCommand}"/>
                    </StackPanel>

                    <!-- ── Timeout ── -->
                    <StackPanel Visibility="{Binding ShowTimeout, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Wartezeit (ms)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="120" HorizontalAlignment="Left"
                                     Text="{Binding TimeoutStep_DelayMs, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── ActiveProcess ── -->
                    <StackPanel Visibility="{Binding ShowActiveProcess, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Prozessname" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ActiveProcessStep_ProcessName, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="z. B. notepad oder notepad.exe"/>
                        </Grid>
                        <TextBlock Foreground="{StaticResource App.Brush.TextMuted}" FontSize="11" Margin="0,0,0,4"
                                   TextWrapping="Wrap"
                                   Text="Ergebnis (Erfolgreich = Prozess läuft) kann in If-Bedingungen ausgewertet werden."/>
                    </StackPanel>

                    <!-- ── StartProcess ── -->
                    <StackPanel Visibility="{Binding ShowStartProcess, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pfad / Programm" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding StartProcessStep_ExecutablePath, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="Pfad zur .exe oder Programmname"/>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseExecutablePathCommand}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Argumente" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding StartProcessStep_Arguments, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="optional"/>
                        </Grid>
                        <CheckBox Content="Auf Beendigung warten"
                                  IsChecked="{Binding StartProcessStep_WaitForExit}"
                                  Margin="0,0,0,4"/>
                    </StackPanel>

                    <!-- ── FocusProcess ── -->
                    <StackPanel Visibility="{Binding ShowFocusProcess, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pfad / Programm" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding FocusProcessStep_ExecutablePath, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="Pfad zur .exe oder Programmname"/>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseFocusProcessPathCommand}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Fenstermodus" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1" Width="160" HorizontalAlignment="Left"
                                      ItemsSource="{Binding FocusProcessWindowModes}"
                                      SelectedItem="{Binding FocusProcessStep_WindowMode}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── ShowText ── -->
                    <StackPanel Visibility="{Binding ShowShowText, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <!-- Text -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Text" VerticalAlignment="Top" Margin="0,4,0,0"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" AcceptsReturn="True" MinHeight="60" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding ShowTextStep_Text, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="Anzuzeigender Text (leer = entfernen)"/>
                        </Grid>

                        <!-- Schriftgröße -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Schriftgröße (pt)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowTextStep_FontSize, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- Schriftfarbe -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Schriftfarbe" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <mah:ColorPicker Grid.Column="1"
                                             SelectedColor="{Binding ShowTextStep_FontColorWpf}"
                                             HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- Deckkraft -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Deckkraft" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                                    Value="{Binding ShowTextStep_Opacity}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="6,0,0,0"
                                       Text="{Binding ShowTextStep_Opacity, StringFormat={}{0:P0}}"/>
                        </Grid>

                        <!-- Anzeigedauer -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Anzeigedauer (ms)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowTextStep_DurationMs, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="0 = dauerhaft"/>
                        </Grid>

                        <!-- Bei Job-Ende entfernen -->
                        <CheckBox Content="Bei Job-Ende entfernen"
                                  IsChecked="{Binding ShowTextStep_ClearOnJobEnd}"
                                  Margin="0,0,0,8"/>

                        <TextBlock Text="Position" FontWeight="SemiBold" Margin="0,4,0,6"
                                   Foreground="{StaticResource App.Brush.TextSecondary}"/>

                        <!-- Monitor wählen (wie DesktopDuplication) -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Desktop Index" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="60" IsReadOnly="True"
                                     Text="{Binding ShowTextStep_DesktopIndex}"/>
                            <Button Grid.Column="2" Content="Monitor wählen" Margin="8,0,0,0" Padding="10,5"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ChooseMonitorForShowTextCommand}"/>
                        </Grid>

                        <!-- X-Offset -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X-Offset (Pixel)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowTextStep_OffsetX, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- Y-Offset -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Y-Offset (Pixel)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowTextStep_OffsetY, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── ActiveWindow ── -->
                    <StackPanel Visibility="{Binding ShowActiveWindow, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Prozessname" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ActiveWindowStep_ProcessName, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="z. B. notepad oder notepad.exe"/>
                        </Grid>
                        <TextBlock Foreground="{StaticResource App.Brush.TextMuted}" FontSize="11" Margin="0,0,0,4"
                                   TextWrapping="Wrap"
                                   Text="Ergebnis (Fenster aktiv) kann in If-Bedingungen ausgewertet werden."/>
                    </StackPanel>

                    <!-- ── KeyPoint Matching ── -->
                    <StackPanel Visibility="{Binding ShowKeyPointMatching, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Capture-Step" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding KeyPointMatchingStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Template-Pfad" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding KeyPointMatchingStep_TemplatePath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseKeyPointMatchingTemplatePathCommand}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Min. Matches" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="80" HorizontalAlignment="Left"
                                     Text="{Binding KeyPointMatchingStep_MinMatchCount, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Lowe's Ratio (0…1)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding KeyPointMatchingStep_LowesRatioThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                        <CheckBox Content="Ergebnisse zeichnen" IsChecked="{Binding KeyPointMatchingStep_DrawResults}" Margin="0,0,0,8"/>
                        <CheckBox Content="ROI aktivieren" IsChecked="{Binding KeyPointMatchingStep_EnableROI}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ROI" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding KeyPointMatchingStep_RoiX}" Margin="0,0,8,0"/>
                                <TextBlock Text="Y" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding KeyPointMatchingStep_RoiY}" Margin="0,0,8,0"/>
                                <TextBlock Text="B" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding KeyPointMatchingStep_RoiW}" Margin="0,0,8,0"/>
                                <TextBlock Text="H" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding KeyPointMatchingStep_RoiH}"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="ROI erfassen" HorizontalAlignment="Left" Padding="10,5"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding CaptureKeyPointMatchingRoiCommand}"/>
                    </StackPanel>

                    <!-- ── If ── -->
                    <StackPanel Visibility="{Binding ShowIf, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <!-- MatchMode -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Verknüpfung:" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <RadioButton Content="Alle (AND)" VerticalAlignment="Center"
                                         IsChecked="{Binding IfStep_MatchModeIsAll}" Margin="0,0,12,0"/>
                            <RadioButton Content="Eine (OR)" VerticalAlignment="Center"
                                         IsChecked="{Binding IfStep_MatchModeIsAny}"/>
                        </StackPanel>
                        <!-- Condition rows -->
                        <ItemsControl ItemsSource="{Binding IfStep_Conditions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="26"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                            <TextBlock Text="Quell-Step" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <ComboBox ItemsSource="{Binding AvailableSourceSteps}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedItem="{Binding SelectedSourceStep}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,4,0">
                                            <TextBlock Text="Eigenschaft" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <ComboBox ItemsSource="{Binding AvailableProperties}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedItem="{Binding SelectedProperty}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,4,0">
                                            <TextBlock Text="Operator" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <ComboBox MinWidth="90"
                                                      ItemsSource="{Binding AvailableOperators}"
                                                      SelectedItem="{Binding SelectedOperator}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource ConditionOperatorConverter}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Margin="0,0,4,0"
                                                    Visibility="{Binding ShowComparisonValue, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Wert" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding ComparisonValue, UpdateSourceTrigger=PropertyChanged}"
                                                     VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        <Button Grid.Column="4" Content="×" VerticalAlignment="Bottom"
                                                Command="{Binding RemoveCommand}"
                                                FontSize="14" Padding="4,2" Margin="0,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Bedingung hinzufügen"
                                Command="{Binding IfStep_AddConditionCommand}"
                                HorizontalAlignment="Left" Margin="0,6,0,0"
                                Style="{StaticResource ButtonSecondary}"
                                Padding="8,4" FontSize="11"/>
                    </StackPanel>

                    <!-- ── ElseIf ── -->
                    <StackPanel Visibility="{Binding ShowElseIf, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <!-- MatchMode -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Verknüpfung:" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <RadioButton Content="Alle (AND)" VerticalAlignment="Center"
                                         IsChecked="{Binding ElseIfStep_MatchModeIsAll}" Margin="0,0,12,0"/>
                            <RadioButton Content="Eine (OR)" VerticalAlignment="Center"
                                         IsChecked="{Binding ElseIfStep_MatchModeIsAny}"/>
                        </StackPanel>
                        <!-- Condition rows -->
                        <ItemsControl ItemsSource="{Binding ElseIfStep_Conditions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="26"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                            <TextBlock Text="Quell-Step" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <ComboBox ItemsSource="{Binding AvailableSourceSteps}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedItem="{Binding SelectedSourceStep}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,4,0">
                                            <TextBlock Text="Eigenschaft" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <ComboBox ItemsSource="{Binding AvailableProperties}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedItem="{Binding SelectedProperty}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,4,0">
                                            <TextBlock Text="Operator" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <ComboBox MinWidth="90"
                                                      ItemsSource="{Binding AvailableOperators}"
                                                      SelectedItem="{Binding SelectedOperator}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource ConditionOperatorConverter}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Margin="0,0,4,0"
                                                    Visibility="{Binding ShowComparisonValue, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Wert" FontSize="10"
                                                       Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding ComparisonValue, UpdateSourceTrigger=PropertyChanged}"
                                                     VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        <Button Grid.Column="4" Content="×" VerticalAlignment="Bottom"
                                                Command="{Binding RemoveCommand}"
                                                FontSize="14" Padding="4,2" Margin="0,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Bedingung hinzufügen"
                                Command="{Binding ElseIfStep_AddConditionCommand}"
                                HorizontalAlignment="Left" Margin="0,6,0,0"
                                Style="{StaticResource ButtonSecondary}"
                                Padding="8,4" FontSize="11"/>
                    </StackPanel>

                    <!-- ── Else ── -->
                    <StackPanel Visibility="{Binding ShowElse, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Keine Konfiguration erforderlich. Dieser Block wird ausgeführt, wenn keine vorherige Bedingung zutraf."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource App.Brush.TextMuted}"
                                   FontStyle="Italic" FontSize="12"/>
                    </StackPanel>

                    <!-- ── EndIf ── -->
                    <StackPanel Visibility="{Binding ShowEndIf, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Keine Konfiguration erforderlich. Beendet den vorherigen If/ElseIf/Else-Block."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource App.Brush.TextMuted}"
                                   FontStyle="Italic" FontSize="12"/>
                    </StackPanel>

                    <!-- ── EndJob ── -->
                    <StackPanel Visibility="{Binding ShowEndJob, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Keine Konfiguration erforderlich. Beendet den Job sofort – nachfolgende Steps werden nicht mehr ausgeführt."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource App.Brush.TextMuted}"
                                   FontStyle="Italic" FontSize="12"/>
                    </StackPanel>

                    <!-- ── Point Comparison ── -->
                    <StackPanel Visibility="{Binding ShowPointComparison, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <!-- Match Requirement -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Übereinstimmung:" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <RadioButton Content="Alle Punkte (AND)" VerticalAlignment="Center"
                                         IsChecked="{Binding PointComparisonStep_MatchRequirementIsAll}" Margin="0,0,12,0"/>
                            <RadioButton Content="Mindestens ein Punkt (OR)" VerticalAlignment="Center"
                                         IsChecked="{Binding PointComparisonStep_MatchRequirementIsAny}"/>
                        </StackPanel>

                        <!-- Mode -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Vergleichsmodus:" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <RadioButton Content="Offset" VerticalAlignment="Center"
                                         IsChecked="{Binding PointComparisonStep_ModeIsOffset}" Margin="0,0,12,0"/>
                            <RadioButton Content="Ausdruck" VerticalAlignment="Center"
                                         IsChecked="{Binding PointComparisonStep_ModeIsExpression}"/>
                        </StackPanel>

                        <!-- ── Offset Settings ── -->
                        <StackPanel Visibility="{Binding PointComparisonStep_ModeIsOffset, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Margin="0,0,0,12">
                            <Border Background="{StaticResource App.Brush.Surface}" CornerRadius="4" Padding="10,8" Margin="0,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Referenzpunkt" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource App.Brush.TextSecondary}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <RadioButton Content="Manuell" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_RefIsManual}" Margin="0,0,12,0"/>
                                        <RadioButton Content="Aus Job-Ergebnis" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_RefIsJobResult}"/>
                                    </StackPanel>
                                    <!-- Manual reference coords -->
                                    <StackPanel Visibility="{Binding PointComparisonStep_RefIsManual, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,4,0"
                                                   Foreground="{StaticResource App.Brush.TextMuted}"/>
                                        <TextBox Width="70" Text="{Binding PointComparisonStep_RefX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                        <TextBlock Text="Y" VerticalAlignment="Center" Margin="0,0,4,0"
                                                   Foreground="{StaticResource App.Brush.TextMuted}"/>
                                        <TextBox Width="70" Text="{Binding PointComparisonStep_RefY, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <!-- JobResult reference -->
                                    <Grid Visibility="{Binding PointComparisonStep_RefIsJobResult, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Detection-Step" VerticalAlignment="Center"
                                                   Foreground="{StaticResource App.Brush.TextSecondary}"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding AvailableDetectionSteps}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedItem="{Binding PointComparisonStep_RefDetectionStep}"/>
                                    </Grid>
                                    <!-- Offset X/Y -->
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Toleranz X" VerticalAlignment="Center" Margin="0,0,4,0"
                                                   Foreground="{StaticResource App.Brush.TextMuted}"/>
                                        <TextBox Width="70" Text="{Binding PointComparisonStep_OffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                        <TextBlock Text="Toleranz Y" VerticalAlignment="Center" Margin="0,0,4,0"
                                                   Foreground="{StaticResource App.Brush.TextMuted}"/>
                                        <TextBox Width="70" Text="{Binding PointComparisonStep_OffsetY, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ── Expression Settings ── -->
                        <StackPanel Visibility="{Binding PointComparisonStep_ModeIsExpression, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Margin="0,0,0,12">
                            <Border Background="{StaticResource App.Brush.Surface}" CornerRadius="4" Padding="10,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Ausdrücke verknüpfen mit:" VerticalAlignment="Center"
                                                   Margin="0,0,8,0" Foreground="{StaticResource App.Brush.TextSecondary}"/>
                                        <RadioButton Content="AND (alle)" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_ExprCombineIsAnd}" Margin="0,0,12,0"/>
                                        <RadioButton Content="OR (mindestens einer)" VerticalAlignment="Center"
                                                     IsChecked="{Binding PointComparisonStep_ExprCombineIsOr}"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding PointComparisonStep_Expressions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="56"/>
                                                        <ColumnDefinition Width="52"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="26"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox Grid.Column="0" Margin="0,0,4,0"
                                                              ItemsSource="{Binding AvailableAxes}"
                                                              SelectedItem="{Binding Axis}"/>
                                                    <ComboBox Grid.Column="1" Margin="0,0,4,0"
                                                              ItemsSource="{Binding AvailableOperators}"
                                                              SelectedItem="{Binding Operator}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Converter={StaticResource PointAxisOperatorConverter}}"/>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBox Grid.Column="2" Margin="0,0,4,0"
                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                             VerticalContentAlignment="Center"/>
                                                    <Button Grid.Column="3" Content="×"
                                                            Command="{Binding RemoveCommand}"
                                                            FontSize="14" Padding="4,2"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Content="+ Ausdruck hinzufügen"
                                            Command="{Binding PointComparisonStep_AddExpressionCommand}"
                                            HorizontalAlignment="Left" Margin="0,6,0,0"
                                            Style="{StaticResource ButtonSecondary}"
                                            Padding="8,4" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ── Points list ── -->
                        <TextBlock Text="ZU PRÜFENDE PUNKTE" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource App.Brush.TextMuted}" Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding PointComparisonStep_Points}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource App.Brush.Surface}"
                                            CornerRadius="4" Padding="8,6" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- Source toggle + Remove -->
                                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <RadioButton Content="Manuell" VerticalAlignment="Center"
                                                                 IsChecked="{Binding IsManual}" Margin="0,0,12,0"/>
                                                    <RadioButton Content="Aus Job-Ergebnis" VerticalAlignment="Center"
                                                                 IsChecked="{Binding IsJobResult}"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="×"
                                                        Command="{Binding RemoveCommand}"
                                                        FontSize="14" Padding="4,2"/>
                                            </Grid>
                                            <!-- Manual fields -->
                                            <StackPanel Grid.Row="1"
                                                        Visibility="{Binding ShowManual, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        Orientation="Horizontal">
                                                <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,4,0"
                                                           Foreground="{StaticResource App.Brush.TextMuted}"/>
                                                <TextBox Width="70" Margin="0,0,12,0"
                                                         Text="{Binding ManualX, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="Y" VerticalAlignment="Center" Margin="0,0,4,0"
                                                           Foreground="{StaticResource App.Brush.TextMuted}"/>
                                                <TextBox Width="70"
                                                         Text="{Binding ManualY, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <!-- JobResult fields -->
                                            <StackPanel Grid.Row="1"
                                                        Visibility="{Binding ShowJobResult, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <ComboBox ItemsSource="{Binding AvailableDetectionSteps}"
                                                          DisplayMemberPath="DisplayName"
                                                          SelectedItem="{Binding SelectedDetectionStep}"
                                                          Margin="0,0,0,4"/>
                                                <CheckBox Content="Alle Fundpunkte verwenden"
                                                          IsChecked="{Binding UseAllDetections}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Punkt hinzufügen"
                                Command="{Binding PointComparisonStep_AddPointCommand}"
                                HorizontalAlignment="Left" Margin="0,2,0,0"
                                Style="{StaticResource ButtonSecondary}"
                                Padding="8,4" FontSize="11"/>

                    </StackPanel>

                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Step-Beschreibung -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <Border Background="{StaticResource App.Brush.AccentSubtle}"
                    BorderBrush="{StaticResource App.Brush.Accent}"
                    BorderThickness="1" CornerRadius="6" Padding="12,9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <iconPacks:PackIconMaterial Grid.Column="0" Kind="InformationOutline"
                                               Foreground="{StaticResource App.Brush.Accent}"
                                               VerticalAlignment="Top" Margin="0,1,9,0"
                                               Width="14" Height="14"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding StepTypeDescription}"
                               Foreground="{StaticResource App.Brush.TextSecondary}"
                               TextWrapping="Wrap" FontSize="12"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Abbrechen" IsCancel="True" Margin="0,0,8,0"
                    Click="Cancel_Click" Style="{StaticResource ButtonSecondary}"/>
            <Button Content="{Binding ConfirmButtonText}" IsDefault="True"
                    Command="{Binding ConfirmCommand}" Style="{StaticResource ButtonPrimary}"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
