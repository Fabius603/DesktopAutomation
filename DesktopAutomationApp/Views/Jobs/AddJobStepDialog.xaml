                                <ComboBox.Items>
                                    <sys:String>left</sys:String>
                                    <sys:String>right</sys:String>
                                    <sys:String>middle</sys:String>
                                    <sys:String>none</sys:String>
                                </ComboBox.Items>
                            </ComboBox>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Timeout (ms)" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepCompactTextBox}" HorizontalAlignment="Left"
