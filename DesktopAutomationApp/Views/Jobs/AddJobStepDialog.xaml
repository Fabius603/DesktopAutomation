<mah:MetroWindow x:Class="DesktopAutomationApp.Views.AddJobStepDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 WindowStartupLocation="CenterOwner"
                 Width="540" Height="560"
                 Title="{Binding DialogTitle}"
                 ResizeMode="CanResize" ShowInTaskbar="False"
                 Style="{StaticResource DialogWindowStyle}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Typauswahl -->
        <Border Grid.Row="0"
                Background="{StaticResource App.Brush.Surface}"
                CornerRadius="6" Padding="12,10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="STEP-TYP"
                           Foreground="{StaticResource App.Brush.TextMuted}"
                           FontSize="11" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <ComboBox Grid.Row="1"
                          ItemsSource="{Binding StepTypeItems}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Name"
                          SelectedValue="{Binding SelectedType}"
                          FontSize="14" FontWeight="Medium"
                          MinHeight="38"
                          mah:ControlsHelper.CornerRadius="5">
                    <ComboBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource App.Brush.CardBorder}"
                                            BorderThickness="0,1,0,0"
                                            Margin="0,4,0,0" Padding="4,6,4,2">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource App.Brush.Accent}"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ComboBox.GroupStyle>
                </ComboBox>
            </Grid>
        </Border>

        <!-- Dynamische Felder -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <Border Background="{StaticResource App.Brush.Surface}" CornerRadius="6" Padding="14,12">
                <StackPanel>

                    <!-- ── Template Matching ── -->
                    <StackPanel Visibility="{Binding ShowTemplateMatching, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Template-Pfad" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding TemplateMatchingStep_TemplatePath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseTemplatePathCommand}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Match Mode" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding TemplateMatchModesAll}"
                                      SelectedItem="{Binding TemplateMatchingStep_TemplateMatchMode}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Confidence (0…1)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding TemplateMatchingStep_ConfidenceThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                        <CheckBox Content="Ergebnisse zeichnen" IsChecked="{Binding TemplateMatchingStep_DrawResults}" Margin="0,0,0,8"/>
                        <CheckBox Content="ROI aktivieren" IsChecked="{Binding TemplateMatchingStep_EnableROI}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ROI" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding TemplateMatchingStep_RoiX}" Margin="0,0,8,0"/>
                                <TextBlock Text="Y" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding TemplateMatchingStep_RoiY}" Margin="0,0,8,0"/>
                                <TextBlock Text="B" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding TemplateMatchingStep_RoiW}" Margin="0,0,8,0"/>
                                <TextBlock Text="H" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding TemplateMatchingStep_RoiH}"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="ROI erfassen" HorizontalAlignment="Left" Padding="10,5"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding CaptureTemplateMatchingRoiCommand}"/>
                    </StackPanel>

                    <!-- ── Desktop Duplication ── -->
                    <StackPanel Visibility="{Binding ShowDesktopDuplication, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Desktop Index" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="60" IsReadOnly="True"
                                     Text="{Binding DesktopDuplicationStep_DesktopIdx}"/>
                            <Button Grid.Column="2" Content="Monitor wählen" Margin="8,0,0,0" Padding="10,5"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ChooseMonitorCommand}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Show Image ── -->
                    <StackPanel Visibility="{Binding ShowShowImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Fenstername" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowImageStep_WindowName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Bildquelle" VerticalAlignment="Top" Margin="0,4,0,0"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <StackPanel Grid.Column="1">
                                <RadioButton Content="Rohbild anzeigen" IsChecked="{Binding ShowImageStep_ShowRawImage}"
                                             GroupName="ShowImageSource" Margin="0,0,0,5"/>
                                <RadioButton Content="Verarbeitetes Bild anzeigen" IsChecked="{Binding ShowImageStep_ShowProcessedImage}"
                                             GroupName="ShowImageSource"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- ── Video Creation ── -->
                    <StackPanel Visibility="{Binding ShowVideoCreation, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Speicherpfad" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Text="{Binding VideoCreationStep_SavePath}" IsReadOnly="True"/>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseVideoSavePathCommand}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Dateiname" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding VideoCreationStep_FileName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Bildquelle" VerticalAlignment="Top" Margin="0,4,0,0"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <StackPanel Grid.Column="1">
                                <RadioButton Content="Rohbild verwenden" IsChecked="{Binding VideoCreationStep_UseRawImage}"
                                             GroupName="VideoImageSource" Margin="0,0,0,5"/>
                                <RadioButton Content="Verarbeitetes Bild verwenden" IsChecked="{Binding VideoCreationStep_UseProcessedImage}"
                                             GroupName="VideoImageSource"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- ── Makro Execution ── -->
                    <StackPanel Visibility="{Binding ShowMakroExecution, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Makro" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableMakros}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding MakroExecutionStep_SelectedMakro}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Job Execution ── -->
                    <StackPanel Visibility="{Binding ShowJobExecution, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Job" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableJobs}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding JobExecutionStep_SelectedJob}"/>
                        </Grid>
                        <CheckBox Content="Auf Beendigung warten" IsChecked="{Binding JobExecutionStep_WaitForCompletion}"/>
                    </StackPanel>

                    <!-- ── Script Execution ── -->
                    <StackPanel Visibility="{Binding ShowScriptExecution, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Script-Pfad" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ScriptExecutionStep_ScriptPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseScriptPathCommand}"/>
                        </Grid>
                        <CheckBox Content="Fire and Forget (nicht auf Abschluss warten)"
                                  IsChecked="{Binding ScriptExecutionStep_FireAndForget}"/>
                    </StackPanel>

                    <!-- ── KlickOnPoint ── -->
                    <StackPanel Visibility="{Binding ShowKlickOnPoint, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Klick-Typ" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1" Width="120" HorizontalAlignment="Left"
                                      SelectedItem="{Binding KlickOnPointStep_ClickType}">
                                <ComboBox.Items>
                                    <sys:String>left</sys:String>
                                    <sys:String>right</sys:String>
                                    <sys:String>middle</sys:String>
                                    <sys:String>none</sys:String>
                                </ComboBox.Items>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Timeout (ms)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding KlickOnPointStep_TimeoutMs}"/>
                        </Grid>
                        <CheckBox Content="Doppelklick" IsChecked="{Binding KlickOnPointStep_DoubleClick}"/>
                    </StackPanel>

                    <!-- ── KlickOnPoint3D ── -->
                    <StackPanel Visibility="{Binding ShowKlickOnPoint3D, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="FOV" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding KlickOnPoint3DStep_FOV, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sensitivity X" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding KlickOnPoint3DStep_MausSensitivityX, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sensitivity Y" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding KlickOnPoint3DStep_MausSensitivityY, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Klick-Typ" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1" Width="120" HorizontalAlignment="Left"
                                      SelectedItem="{Binding KlickOnPoint3DStep_ClickType}">
                                <ComboBox.Items>
                                    <sys:String>left</sys:String>
                                    <sys:String>right</sys:String>
                                    <sys:String>middle</sys:String>
                                    <sys:String>none</sys:String>
                                </ComboBox.Items>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Timeout (ms)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding KlickOnPoint3DStep_Timeout}"/>
                        </Grid>
                        <CheckBox Content="Doppelklick" IsChecked="{Binding KlickOnPoint3DStep_DoubleClick}" Margin="0,0,0,6"/>
                        <CheckBox Content="Mausbewegung Y invertieren" IsChecked="{Binding KlickOnPoint3DStep_InvertMouseMovementY}" Margin="0,0,0,6"/>
                        <CheckBox Content="Mausbewegung X invertieren" IsChecked="{Binding KlickOnPoint3DStep_InvertMouseMovementX}"/>
                    </StackPanel>

                    <!-- ── YOLO Detection ── -->
                    <StackPanel Visibility="{Binding ShowYoloDetection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Model" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding YoloDetectionStep_AvailableModels}"
                                      SelectedItem="{Binding YoloDetectionStep_Model}"
                                      IsEditable="True"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Klassenname" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding YoloDetectionStep_AvailableClasses}"
                                      SelectedItem="{Binding YoloDetectionStep_ClassName}"
                                      IsEditable="True"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Confidence (0…1)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="100" HorizontalAlignment="Left"
                                     Text="{Binding YoloDetectionStep_ConfidenceThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                        <CheckBox Content="Ergebnisse zeichnen" IsChecked="{Binding YoloDetectionStep_DrawResults}" Margin="0,0,0,8"/>
                        <CheckBox Content="ROI aktivieren" IsChecked="{Binding YoloDetectionStep_EnableROI}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ROI" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding YoloDetectionStep_RoiX}" Margin="0,0,8,0"/>
                                <TextBlock Text="Y" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding YoloDetectionStep_RoiY}" Margin="0,0,8,0"/>
                                <TextBlock Text="B" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding YoloDetectionStep_RoiW}" Margin="0,0,8,0"/>
                                <TextBlock Text="H" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource App.Brush.TextMuted}"/>
                                <TextBox Width="54" Text="{Binding YoloDetectionStep_RoiH}"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="ROI erfassen" HorizontalAlignment="Left" Padding="10,5"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding CaptureYoloDetectionRoiCommand}"/>
                    </StackPanel>

                    <!-- ── Timeout ── -->
                    <StackPanel Visibility="{Binding ShowTimeout, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Wartezeit (ms)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="120" HorizontalAlignment="Left"
                                     Text="{Binding TimeoutStep_DelayMs, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Step-Beschreibung + Pipeline-Info -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">

            <!-- Voraussetzungen / Ausgabe -->
            <Border Background="{StaticResource App.Brush.Surface}"
                    BorderBrush="{StaticResource App.Brush.CardBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Benötigt -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="BENÖTIGT"
                               Foreground="{StaticResource App.Brush.TextMuted}"
                               FontSize="10" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <ItemsControl Grid.Row="0" Grid.Column="1"
                                  ItemsSource="{Binding StepPrerequisites}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="1" CornerRadius="3"
                                        Padding="6,2" Margin="0,1,5,1"
                                        Background="{Binding IsSatisfied, Converter={StaticResource PrerequisiteStateConverter}, ConverterParameter=background, TargetNullValue={StaticResource App.Brush.AccentSubtle}}"
                                        BorderBrush="{Binding IsSatisfied, Converter={StaticResource PrerequisiteStateConverter}, ConverterParameter=border, TargetNullValue={StaticResource App.Brush.Accent}}">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="11" FontWeight="Medium"
                                               Foreground="{Binding IsSatisfied, Converter={StaticResource PrerequisiteStateConverter}, TargetNullValue={StaticResource App.Brush.Accent}}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Liefert -->
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="LIEFERT"
                               Foreground="{StaticResource App.Brush.TextMuted}"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="0,5,0,0"
                               VerticalAlignment="Center"/>
                    <Border Grid.Row="1" Grid.Column="1"
                            Margin="0,5,0,0" HorizontalAlignment="Left">
                        <Border Background="{StaticResource App.Brush.Surface}"
                                BorderBrush="{StaticResource App.Brush.CardBorder}"
                                BorderThickness="1" CornerRadius="3"
                                Padding="6,2">
                            <TextBlock Text="{Binding StepOutput}"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"
                                       FontSize="11" FontWeight="Medium"/>
                        </Border>
                    </Border>
                </Grid>
            </Border>

            <!-- Beschreibung -->
            <Border Background="{StaticResource App.Brush.AccentSubtle}"
                    BorderBrush="{StaticResource App.Brush.Accent}"
                    BorderThickness="1" CornerRadius="6" Padding="12,9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <iconPacks:PackIconMaterial Grid.Column="0" Kind="InformationOutline"
                                               Foreground="{StaticResource App.Brush.Accent}"
                                               VerticalAlignment="Top" Margin="0,1,9,0"
                                               Width="14" Height="14"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding StepTypeDescription}"
                               Foreground="{StaticResource App.Brush.TextSecondary}"
                               TextWrapping="Wrap" FontSize="12"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Abbrechen" IsCancel="True" Margin="0,0,8,0"
                    Click="Cancel_Click" Style="{StaticResource ButtonSecondary}"/>
            <Button Content="{Binding ConfirmButtonText}" IsDefault="True"
                    Command="{Binding ConfirmCommand}" Style="{StaticResource ButtonPrimary}"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
