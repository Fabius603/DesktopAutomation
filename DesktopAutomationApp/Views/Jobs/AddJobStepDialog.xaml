<mah:MetroWindow x:Class="DesktopAutomationApp.Views.AddJobStepDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 WindowStartupLocation="CenterOwner"
                 Width="540" Height="560"
                 Title="{Binding DialogTitle}"
                 ResizeMode="CanResize" ShowInTaskbar="False"
                 Style="{StaticResource DialogWindowStyle}">

    <mah:MetroWindow.Resources>
        <Style x:Key="StepFieldGrid" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="StepFieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource App.Brush.TextSecondary}"/>
        </Style>
        <Style x:Key="StepCompactTextBox" TargetType="TextBox">
            <Setter Property="Width" Value="42"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StepAxisLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource App.Brush.TextMuted}"/>
        </Style>
        <Style x:Key="StepGroupedFieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource App.Brush.TextMuted}"/>
        </Style>
        <Style x:Key="StepGroupedTextBox" TargetType="TextBox" BasedOn="{StaticResource StepCompactTextBox}">
            <Setter Property="Width" Value="72"/>
        </Style>
        <Style x:Key="RoiFieldWrapPanel" TargetType="WrapPanel">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ItemHeight" Value="34"/>
        </Style>
        <Style x:Key="RoiFieldGroup" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,0,14,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StepInlineButton" TargetType="Button" BasedOn="{StaticResource ButtonSecondary}">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="TemplatePreviewBorder" TargetType="Border">
            <Setter Property="Width" Value="96"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Background" Value="{StaticResource App.Brush.WindowBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource App.Brush.CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Typauswahl -->
        <Border Grid.Row="0"
                Visibility="{Binding ShowTypeSelector, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="{StaticResource App.Brush.Surface}"
                CornerRadius="6" Padding="12,10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="STEP-TYP"
                           Foreground="{StaticResource App.Brush.TextMuted}"
                           FontSize="11" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <ComboBox Grid.Row="1"
                          ItemsSource="{Binding StepTypeItems}"
                          DisplayMemberPath="DisplayLabel"
                          SelectedValuePath="Name"
                          SelectedValue="{Binding SelectedType}"
                          FontSize="14" FontWeight="Medium"
                          MinHeight="38"
                          mah:ControlsHelper.CornerRadius="5">
                    <ComboBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource App.Brush.CardBorder}"
                                            BorderThickness="0,1,0,0"
                                            Margin="0,4,0,0" Padding="4,6,4,2">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource App.Brush.Accent}"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ComboBox.GroupStyle>
                </ComboBox>
            </Grid>
        </Border>

        <!-- Dynamische Felder -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <Border Background="{StaticResource App.Brush.Surface}" CornerRadius="6" Padding="14,12">
                <StackPanel>

                    <!-- ── Template Matching ── -->
                    <StackPanel Visibility="{Binding ShowTemplateMatching, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Capture-Step" Style="{StaticResource StepFieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding TemplateMatchingStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Template" Style="{StaticResource StepFieldLabel}"/>
                            <StackPanel Grid.Column="1">
                                <TextBox Text="{Binding TemplateMatchingStep_TemplatePath, UpdateSourceTrigger=PropertyChanged}"/>
                                <Border Style="{StaticResource TemplatePreviewBorder}"
                                        Visibility="{Binding TemplateMatchingStep_HasTemplatePreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Image Source="{Binding TemplateMatchingStep_TemplatePreview}" Stretch="Uniform"/>
                                </Border>
                            </StackPanel>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseTemplatePathCommand}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ROI" Style="{StaticResource StepFieldLabel}"/>
                            <WrapPanel Grid.Column="1" Style="{StaticResource RoiFieldWrapPanel}">
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="X" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
                                    <TextBox Style="{StaticResource StepGroupedTextBox}" Text="{Binding TemplateMatchingStep_RoiX, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="Y" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
                                    <TextBox Style="{StaticResource StepGroupedTextBox}" Text="{Binding TemplateMatchingStep_RoiY, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="Breite" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
                                    <TextBox Style="{StaticResource StepGroupedTextBox}" Text="{Binding TemplateMatchingStep_RoiW, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="Höhe" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
                                    <TextBox Style="{StaticResource StepGroupedTextBox}" Text="{Binding TemplateMatchingStep_RoiH, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <Button Content="Aufnehmen" Style="{StaticResource StepInlineButton}"
                                        Command="{Binding CaptureTemplateMatchingRoiCommand}"/>
                            </WrapPanel>
                        </Grid>
                        <CheckBox Content="ROI aktivieren" IsChecked="{Binding TemplateMatchingStep_EnableROI}" Margin="140,0,0,10"/>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Confidence (0…1)" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepCompactTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding TemplateMatchingStep_ConfidenceThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Match Mode" Style="{StaticResource StepFieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding TemplateMatchModesAll}"
                                      SelectedItem="{Binding TemplateMatchingStep_TemplateMatchMode}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Color Detection ── -->
                    <StackPanel Visibility="{Binding ShowColorDetection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Capture-Step" Style="{StaticResource StepFieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding ColorDetectionStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Farbe" Style="{StaticResource StepFieldLabel}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <mah:ColorPicker SelectedColor="{Binding ColorDetectionStep_Color}"
                                                 HorizontalAlignment="Left"/>
                                <Border Width="28" Height="28" Margin="8,0,0,0"
                                        Background="{Binding ColorDetectionStep_ColorBrush}"
                                        BorderBrush="{StaticResource App.Brush.CardBorder}"
                                        BorderThickness="1"
                                        CornerRadius="4"/>
                                <TextBlock Text="{Binding ColorDetectionStep_ColorHex}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            </StackPanel>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ROI" Style="{StaticResource StepFieldLabel}"/>
                            <WrapPanel Grid.Column="1" Style="{StaticResource RoiFieldWrapPanel}">
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="X" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
                                    <TextBox Style="{StaticResource StepGroupedTextBox}" Text="{Binding ColorDetectionStep_RoiX, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="Y" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
                                    <TextBox Style="{StaticResource StepGroupedTextBox}" Text="{Binding ColorDetectionStep_RoiY, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="Breite" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
                                    <TextBox Style="{StaticResource StepGroupedTextBox}" Text="{Binding ColorDetectionStep_RoiW, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Style="{StaticResource RoiFieldGroup}">
                                    <TextBlock Text="Höhe" Width="52" Style="{StaticResource StepGroupedFieldLabel}"/>
                                    <TextBox Style="{StaticResource StepGroupedTextBox}" Text="{Binding ColorDetectionStep_RoiH, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <Button Content="Aufnehmen" Style="{StaticResource StepInlineButton}"
                                        Command="{Binding CaptureColorDetectionRoiCommand}"/>
                            </WrapPanel>
                        </Grid>
                        <CheckBox Content="ROI aktivieren" IsChecked="{Binding ColorDetectionStep_EnableROI}" Margin="140,0,0,10"/>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Confidence (0…1)" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepCompactTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding ColorDetectionStep_ConfidenceThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Min. Größe" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding ColorDetectionStep_MinSize, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Max. Größe" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding ColorDetectionStep_MaxSize, Converter={StaticResource MaxSizeDisplayConverter}, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Min. Breite" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding ColorDetectionStep_MinWidth, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Min. Höhe" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepGroupedTextBox}" HorizontalAlignment="Left"
                                     Text="{Binding ColorDetectionStep_MinHeight, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Desktop Duplication ── -->
                    <StackPanel Visibility="{Binding ShowDesktopDuplication, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Desktop Index" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Width="60" IsReadOnly="True"
                                     Text="{Binding DesktopDuplicationStep_DesktopIdx}"/>
                            <Button Grid.Column="2" Content="Monitor wählen" Margin="8,0,0,0" Padding="10,5"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ChooseMonitorCommand}"/>
                        </Grid>
                        <CheckBox Margin="0,6,0,0"
                                  Content="Mauszeiger aufnehmen"
                                  IsChecked="{Binding DesktopDuplicationStep_CaptureCursor}"/>
                    </StackPanel>

                    <!-- ── Show Image ── -->
                    <StackPanel Visibility="{Binding ShowShowImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Capture-Step" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding ShowImageStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Detection-Step (opt.)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableDetectionSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding ShowImageStep_SourceDetectionStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Fenstername" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ShowImageStep_WindowName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Bildquelle" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1" Width="180" HorizontalAlignment="Left"
                                      ItemsSource="{Binding ImageModeOptions}"
                                      SelectedItem="{Binding ShowImageStep_ImageMode}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Show On Desktop ── -->
                    <StackPanel Visibility="{Binding ShowShowOnDesktop, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Detection-Step" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableDetectionSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding ShowOnDesktopStep_SourceDetectionStep}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Video Creation ── -->
                    <StackPanel Visibility="{Binding ShowVideoCreation, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Capture-Step" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCaptureSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding VideoCreationStep_SourceCaptureStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Detection-Step (opt.)" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableDetectionSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding VideoCreationStep_SourceDetectionStep}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Speicherpfad" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1" Text="{Binding VideoCreationStep_SavePath}" IsReadOnly="True"/>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseVideoSavePathCommand}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Dateiname" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding VideoCreationStep_FileName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Bildquelle" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1" Width="180" HorizontalAlignment="Left"
                                      ItemsSource="{Binding ImageModeOptions}"
                                      SelectedItem="{Binding VideoCreationStep_ImageMode}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Makro Execution ── -->
                    <StackPanel Visibility="{Binding ShowMakroExecution, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Makro" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableMakros}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding MakroExecutionStep_SelectedMakro}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Job Execution ── -->
                    <StackPanel Visibility="{Binding ShowJobExecution, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Job" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableJobs}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding JobExecutionStep_SelectedJob}"/>
                        </Grid>
                        <CheckBox Content="Auf Beendigung warten" IsChecked="{Binding JobExecutionStep_WaitForCompletion}"/>
                    </StackPanel>

                    <!-- ── Script Execution ── -->
                    <StackPanel Visibility="{Binding ShowScriptExecution, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Script-Pfad" VerticalAlignment="Center"
                                       Foreground="{StaticResource App.Brush.TextSecondary}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ScriptExecutionStep_ScriptPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="…" Width="32" Height="28" Margin="6,0,0,0"
                                    Command="{Binding BrowseScriptPathCommand}"/>
                        </Grid>
                        <CheckBox Content="Auf Beendigung warten"
                                  IsChecked="{Binding ScriptExecutionStep_WaitForExit}"/>
                    </StackPanel>

                    <!-- ── KlickOnPoint ── -->
                    <StackPanel Visibility="{Binding ShowKlickOnPoint, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Detection-Step" Style="{StaticResource StepFieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableDetectionSteps}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding KlickOnPointStep_SourceDetectionStep}"/>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Offset" Style="{StaticResource StepFieldLabel}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="X" Style="{StaticResource StepAxisLabel}"/>
                                <TextBox Style="{StaticResource StepCompactTextBox}" Text="{Binding KlickOnPointStep_OffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                <TextBlock Text="Y" Style="{StaticResource StepAxisLabel}"/>
                                <TextBox Style="{StaticResource StepCompactTextBox}" Text="{Binding KlickOnPointStep_OffsetY, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Klick-Typ" Style="{StaticResource StepFieldLabel}"/>
                            <ComboBox Grid.Column="1" Width="120" HorizontalAlignment="Left"
                                      SelectedItem="{Binding KlickOnPointStep_ClickType}">
                                <ComboBox.Items>
                                    <sys:String>left</sys:String>
                                    <sys:String>right</sys:String>
                                    <sys:String>middle</sys:String>
                                    <sys:String>none</sys:String>
                                </ComboBox.Items>
                            </ComboBox>
                        </Grid>
                        <Grid Style="{StaticResource StepFieldGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Timeout (ms)" Style="{StaticResource StepFieldLabel}"/>
                            <TextBox Grid.Column="1" Style="{StaticResource StepCompactTextBox}" HorizontalAlignment="Left"
