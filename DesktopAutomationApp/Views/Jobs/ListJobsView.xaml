<UserControl xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" x:Class="DesktopAutomationApp.Views.ListJobsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DesktopAutomationApp.ViewModels"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Style="{StaticResource ContentViewBase}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <DockPanel Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonPrimary}" Command="{Binding CreateNewJobCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Job.List.NewJob}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonDanger}" Command="{Binding DeleteJobCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Job.List.DeleteJob}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Border Style="{StaticResource ToolbarSeparator}"/>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.Refresh}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding OpenFolderCommand}" Margin="8,0,0,0" ToolTip="{loc:Translate Key=Ui.Common.OpenFolderInExplorer}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{loc:Translate Key=Ui.Job.List.Jobs}" Style="{StaticResource PageTitle}" Margin="0,0,12,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Tabelle -->
        <Border Grid.Row="1" Style="{StaticResource TableCardStyle}">
            <DataGrid x:Name="JobGrid"
                      ItemsSource="{Binding Items}"
                AutoGenerateColumns="False"
                IsReadOnly="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                SelectionMode="Extended"
                SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                ScrollViewer.CanContentScroll="True"
                SelectionChanged="JobGrid_SelectionChanged"
                PreviewMouseLeftButtonDown="JobGrid_PreviewMouseDown">

                <DataGrid.InputBindings>
                    <KeyBinding Key="Delete" Command="{Binding DeleteJobCommand}"/>
                </DataGrid.InputBindings>

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Header="{loc:Translate Key=Ui.Common.Name}"
                        Binding="{Binding Name}"
                        IsReadOnly="True"
                        Width="3*"/>
                    <DataGridTemplateColumn Header="{loc:Translate Key=Ui.Job.List.Recurring}" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox
                                    IsChecked="{Binding Repeating, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Command="{Binding DataContext.SaveAllCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn
                        Header="{loc:Translate Key=Ui.Job.List.CountSteps}"
                        Binding="{Binding ActiveStepCount}"
                        IsReadOnly="True"
                        Width="*"/>
                    <DataGridTemplateColumn Header="" IsReadOnly="True" Width="230" CanUserResize="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Grid Margin="0,0,8,0">
                                    <!-- Play Button: sichtbar wenn Job NICHT läuft -->
                                    <Button Style="{StaticResource ButtonTablePrimary}"
                                            Command="{Binding DataContext.StartJobCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}"
                                            ToolTip="{loc:Translate Key=Ui.Job.Steps.StartJob}">
                                        <Button.Visibility>
                                            <MultiBinding Converter="{StaticResource CollectionContainsConverter}" ConverterParameter="Invert">
                                                <Binding Path="Id"/>
                                                <Binding Path="DataContext.RunningJobIds" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                                <Binding Path="DataContext.RunningJobIds.Count" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Kind="Play" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="{loc:Translate Common.Execute}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <!-- Stop Button: sichtbar wenn Job läuft -->
                                    <Button Style="{StaticResource ButtonTableDanger}"
                                            Command="{Binding DataContext.StopJobCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}"
                                            ToolTip="{loc:Translate Key=Ui.Job.Steps.StopJob}">
                                        <Button.Visibility>
                                            <MultiBinding Converter="{StaticResource CollectionContainsConverter}">
                                                <Binding Path="Id"/>
                                                <Binding Path="DataContext.RunningJobIds" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                                <Binding Path="DataContext.RunningJobIds.Count" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Kind="Stop" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="{loc:Translate Key=Ui.Common.Stop}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <Button Style="{StaticResource ButtonTableSecondary}"
                                        Command="{Binding DataContext.OpenJobCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ArrowRight" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="{loc:Translate Key=Ui.Common.Open}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
