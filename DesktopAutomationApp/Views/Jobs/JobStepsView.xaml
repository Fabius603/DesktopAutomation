<UserControl x:Class="DesktopAutomationApp.Views.JobStepsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DesktopAutomationApp.ViewModels"
             xmlns:jobs="clr-namespace:TaskAutomation.Jobs;assembly=TaskAutomation"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:DesktopAutomationApp.Converters"
             xmlns:behaviors="clr-namespace:DesktopAutomationApp.Behaviors"
             mc:Ignorable="d"
             Style="{StaticResource ContentViewBase}">

    <UserControl.Resources>
        <conv:RectToStringConverter x:Key="RectToStringConverter"/>
        <conv:StepPipelineInfoConverter x:Key="PipelineInfoConverter"/>
        <conv:StepBlockBorderConverter x:Key="StepBlockBorderConverter"/>
        <conv:StepNumberConverter x:Key="StepNumberConverter"/>
        <conv:SourceStepNameConverter x:Key="SourceStepNameConverter"/>

        <!-- Gemeinsame Parameterzeile -->
        <Style x:Key="ParamText" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- === Deine Step-DataTemplates (unverändert) === -->
        <!-- TemplateMatchingStep -->
        <DataTemplate DataType="{x:Type jobs:TemplateMatchingStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Template Matching" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Bildquelle: "/>
                        <Run>
                            <Run.Text>
                                <MultiBinding Converter="{StaticResource SourceStepNameConverter}">
                                    <Binding Path="Settings.SourceCaptureStepId"/>
                                    <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                </MultiBinding>
                            </Run.Text>
                        </Run>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="TemplatePath: "/><Run Text="{Binding Settings.TemplatePath}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="MatchMode: "/><Run Text="{Binding Settings.TemplateMatchMode}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Mehrere Treffer: "/>
                        <Run Text="{Binding Settings.MultiplePoints, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="ConfidenceThreshold: "/><Run Text="{Binding Settings.ConfidenceThreshold, StringFormat=F2}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="EnableROI: "/>
                        <Run Text="{Binding Settings.EnableROI, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="ROI (X,Y,Breite,Höhe): "/>
                        <Run Text="{Binding Settings.ROI, Converter={StaticResource RectToStringConverter}}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="DrawResults: "/>
                        <Run Text="{Binding Settings.DrawResults, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- DesktopDuplicationStep -->
        <DataTemplate DataType="{x:Type jobs:DesktopDuplicationStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Desktop Duplication" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Desktop Index: "/><Run Text="{Binding Settings.DesktopIdx}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- ProcessDuplicationStep -->
        <DataTemplate DataType="{x:Type jobs:ProcessDuplicationStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Process Duplication" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="ProcessName: "/><Run Text="{Binding Settings.ProcessName}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- ShowImageStep -->
        <DataTemplate DataType="{x:Type jobs:ShowImageStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Show Image" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Bildquelle: "/>
                        <Run>
                            <Run.Text>
                                <MultiBinding Converter="{StaticResource SourceStepNameConverter}">
                                    <Binding Path="Settings.SourceCaptureStepId"/>
                                    <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                </MultiBinding>
                            </Run.Text>
                        </Run>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Erkennungsquelle: "/>
                        <Run>
                            <Run.Text>
                                <MultiBinding Converter="{StaticResource SourceStepNameConverter}">
                                    <Binding Path="Settings.SourceDetectionStepId"/>
                                    <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                </MultiBinding>
                            </Run.Text>
                        </Run>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="WindowName: "/><Run Text="{Binding Settings.WindowName}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="ShowRawImage: "/>
                        <Run Text="{Binding Settings.ShowRawImage, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="ShowProcessedImage: "/>
                        <Run Text="{Binding Settings.ShowProcessedImage, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- VideoCreationStep -->
        <DataTemplate DataType="{x:Type jobs:VideoCreationStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Video Creation" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Bildquelle: "/>
                        <Run>
                            <Run.Text>
                                <MultiBinding Converter="{StaticResource SourceStepNameConverter}">
                                    <Binding Path="Settings.SourceCaptureStepId"/>
                                    <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                </MultiBinding>
                            </Run.Text>
                        </Run>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Erkennungsquelle: "/>
                        <Run>
                            <Run.Text>
                                <MultiBinding Converter="{StaticResource SourceStepNameConverter}">
                                    <Binding Path="Settings.SourceDetectionStepId"/>
                                    <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                </MultiBinding>
                            </Run.Text>
                        </Run>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="SavePath: "/><Run Text="{Binding Settings.SavePath}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="FileName: "/><Run Text="{Binding Settings.FileName}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="UseRawImage: "/>
                        <Run Text="{Binding Settings.UseRawImage, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="UseProcessedImage: "/>
                        <Run Text="{Binding Settings.UseProcessedImage, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- MakroExecutionStep -->
        <DataTemplate DataType="{x:Type jobs:MakroExecutionStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Makro Execution" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="MakroName: "/><Run Text="{Binding Settings.MakroName}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type jobs:KlickOnPointStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Klick auf Punkt" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Erkennungsquelle: "/>
                        <Run>
                            <Run.Text>
                                <MultiBinding Converter="{StaticResource SourceStepNameConverter}">
                                    <Binding Path="Settings.SourceDetectionStepId"/>
                                    <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                </MultiBinding>
                            </Run.Text>
                        </Run>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Doppelklick: "/>
                        <Run Text="{Binding Settings.DoubleClick, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Klick-Typ: "/><Run Text="{Binding Settings.ClickType}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Timeout (ms): "/><Run Text="{Binding Settings.TimeoutMs}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type jobs:KlickOnPoint3DStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Klick auf Punkt 3D" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Erkennungsquelle: "/>
                        <Run>
                            <Run.Text>
                                <MultiBinding Converter="{StaticResource SourceStepNameConverter}">
                                    <Binding Path="Settings.SourceDetectionStepId"/>
                                    <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                </MultiBinding>
                            </Run.Text>
                        </Run>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Bildquelle: "/>
                        <Run>
                            <Run.Text>
                                <MultiBinding Converter="{StaticResource SourceStepNameConverter}">
                                    <Binding Path="Settings.SourceCaptureStepId"/>
                                    <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                </MultiBinding>
                            </Run.Text>
                        </Run>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="FOV: "/><Run Text="{Binding Settings.FOV, StringFormat=F1}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Maus Sensitivity X: "/><Run Text="{Binding Settings.MausSensitivityX, StringFormat=F2}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Maus Sensitivity Y: "/><Run Text="{Binding Settings.MausSensitivityY, StringFormat=F2}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Doppelklick: "/>
                        <Run Text="{Binding Settings.DoubleClick, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Klick-Typ: "/><Run Text="{Binding Settings.ClickType}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Timeout (ms): "/><Run Text="{Binding Settings.TimeoutMs}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Invert MouseMovement Y: "/>
                        <Run Text="{Binding Settings.InvertMouseMovementY, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Invert MouseMovement X: "/>
                        <Run Text="{Binding Settings.InvertMouseMovementX, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type jobs:ScriptExecutionStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Script Ausführung" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Script-Pfad: "/><Run Text="{Binding Settings.ScriptPath}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Fire and Forget: "/>
                        <Run Text="{Binding Settings.FireAndForget, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type jobs:JobExecutionStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Job Ausführung" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Job-Name: "/><Run Text="{Binding Settings.JobName}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Auf Beendigung warten: "/>
                        <Run Text="{Binding Settings.WaitForCompletion, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- YOLODetectionStep -->
        <DataTemplate DataType="{x:Type jobs:YOLODetectionStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="YOLO Detection" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Bildquelle: "/>
                        <Run>
                            <Run.Text>
                                <MultiBinding Converter="{StaticResource SourceStepNameConverter}">
                                    <Binding Path="Settings.SourceCaptureStepId"/>
                                    <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                </MultiBinding>
                            </Run.Text>
                        </Run>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Model: "/><Run Text="{Binding Settings.Model}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Klassenname: "/><Run Text="{Binding Settings.ClassName}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="ConfidenceThreshold: "/><Run Text="{Binding Settings.ConfidenceThreshold, StringFormat=F2}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="EnableROI: "/>
                        <Run Text="{Binding Settings.EnableROI, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="ROI (X,Y,Breite,Höhe): "/>
                        <Run Text="{Binding Settings.ROI, Converter={StaticResource RectToStringConverter}}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="DrawResults: "/>
                        <Run Text="{Binding Settings.DrawResults, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- TimeoutStep -->
        <DataTemplate DataType="{x:Type jobs:TimeoutStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Timeout" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="Wartezeit (ms): "/><Run Text="{Binding Settings.DelayMs}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- IfStep -->
        <DataTemplate DataType="{x:Type jobs:IfStep}">
            <StackPanel>
                <TextBlock Text="If" FontWeight="Bold" Foreground="{StaticResource App.Brush.Accent}"/>
                <ItemsControl ItemsSource="{Binding Settings.Conditions}" Margin="0,4,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource ParamText}" TextWrapping="Wrap">
                                <Run Text="{Binding SourceStepDisplayName, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text="."/>
                                <Run Text="{Binding PropertyDisplayName, Mode=OneWay}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding Operator, Mode=OneWay, Converter={StaticResource ConditionOperatorConverter}}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding ComparisonValue, Mode=OneWay}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Style="{StaticResource ParamText}" Margin="0,3,0,0" FontStyle="Italic">
                    <Run Text="("/><Run Text="{Binding Settings.MatchMode, Mode=OneWay, Converter={StaticResource ConditionMatchModeConverter}}"/><Run Text=")"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="+ Else If"
                            Command="{Binding DataContext.AddElseIfCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource ButtonSecondary}"
                            Padding="8,4" Margin="0,0,6,0" FontSize="11"/>
                    <Button Content="+ Else"
                            Command="{Binding DataContext.AddElseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource ButtonSecondary}"
                            Padding="8,4" FontSize="11"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- ElseIfStep -->
        <DataTemplate DataType="{x:Type jobs:ElseIfStep}">
            <StackPanel>
                <TextBlock Text="Else If" FontWeight="Bold" Foreground="{StaticResource App.Brush.Accent}"/>
                <ItemsControl ItemsSource="{Binding Settings.Conditions}" Margin="0,4,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource ParamText}" TextWrapping="Wrap">
                                <Run Text="{Binding SourceStepDisplayName, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text="."/>
                                <Run Text="{Binding PropertyDisplayName, Mode=OneWay}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding Operator, Mode=OneWay, Converter={StaticResource ConditionOperatorConverter}}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding ComparisonValue, Mode=OneWay}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Style="{StaticResource ParamText}" Margin="0,3,0,0" FontStyle="Italic">
                    <Run Text="("/><Run Text="{Binding Settings.MatchMode, Mode=OneWay, Converter={StaticResource ConditionMatchModeConverter}}"/><Run Text=")"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="+ Else If"
                            Command="{Binding DataContext.AddElseIfCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource ButtonSecondary}"
                            Padding="8,4" Margin="0,0,6,0" FontSize="11"/>
                    <Button Content="+ Else"
                            Command="{Binding DataContext.AddElseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource ButtonSecondary}"
                            Padding="8,4" FontSize="11"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- ElseStep -->
        <DataTemplate DataType="{x:Type jobs:ElseStep}">
            <TextBlock Text="Else" FontWeight="Bold" Foreground="{StaticResource App.Brush.Accent}"/>
        </DataTemplate>

        <!-- EndIfStep -->
        <DataTemplate DataType="{x:Type jobs:EndIfStep}">
            <TextBlock Text="End If" FontWeight="Bold" Foreground="{StaticResource App.Brush.Accent}"/>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: Zurück + Titel + Add + Save + Cancel -->
        <DockPanel Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonPrimary}" Command="{Binding StartJobCommand}"
                        Visibility="{Binding IsJobRunning, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                        ToolTip="Job starten">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Start" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonDanger}" Command="{Binding StopJobCommand}"
                        Visibility="{Binding IsJobRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                        ToolTip="Job stoppen">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Stop" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Stop" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Border Style="{StaticResource ToolbarSeparator}"/>
                <Button Style="{StaticResource ButtonPrimary}" Command="{Binding SaveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Speichern" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding CancelCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Cancel" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Abbrechen" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Border Style="{StaticResource ToolbarSeparator}"/>
                <Button Style="{StaticResource ButtonPrimary}"
                        Command="{Binding AddStepCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Neuer Step" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonSecondary}"
                        Command="{Binding BackCommand}"
                        Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Zurück" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}" Margin="0,0,12,0"/>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding RenameCommand}" ToolTip="Umbenennen">
                    <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Unterer Bereich: wie Makro-Ansicht (DockPanel + ListBox mit Hover/Selected) -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <DockPanel>

                <!-- ListBox mit Hover-/Selected-Rahmen wie im Makro -->
                <ListBox x:Name="StepsList"
                         ItemsSource="{Binding Steps}"
                         SelectionMode="Extended"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingStackPanel.ScrollUnit="Pixel"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         SelectionChanged="StepsList_SelectionChanged"
                         ItemContainerStyle="{StaticResource StepCardListBoxItemStyle}"
                         behaviors:SimpleReorderDragDrop.MoveCommand="{Binding ReorderStepCommand}">

                    <ListBox.InputBindings>
                        <KeyBinding Key="Delete"              Command="{Binding DeleteSelectedCommand}"/>
                        <KeyBinding Key="C" Modifiers="Ctrl"  Command="{Binding CopyCommand}"/>
                        <KeyBinding Key="V" Modifiers="Ctrl"  Command="{Binding PasteCommand}"/>
                        <KeyBinding Key="Z" Modifiers="Ctrl"  Command="{Binding UndoCommand}"/>
                        <KeyBinding Key="Y" Modifiers="Ctrl"  Command="{Binding RedoCommand}"/>
                    </ListBox.InputBindings>

                    <!-- Inhalt + Aktionsleiste rechts (Edit/Hoch/Runter/Delete exakt wie Makro) -->
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- Outer grid: coloured left bar | content -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Coloured left bar -->
                                <Border Grid.Column="0" CornerRadius="2,0,0,2">
                                    <Border.Background>
                                        <MultiBinding Converter="{StaticResource StepBlockBorderConverter}">
                                            <Binding />
                                            <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                            <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                        </MultiBinding>
                                    </Border.Background>
                                </Border>

                                <!-- Subtle background tint over the whole row -->
                                <Border Grid.Column="1" Grid.ColumnSpan="2">
                                    <Border.Background>
                                        <MultiBinding Converter="{StaticResource StepBlockBorderConverter}" ConverterParameter="background">
                                            <Binding />
                                            <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                            <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                        </MultiBinding>
                                    </Border.Background>
                                </Border>

                                <!-- Inner grid: content | action buttons -->
                                <Grid Grid.Column="1" Grid.ColumnSpan="2" Margin="8,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                <!-- Links: Step-Details via implizite DataTemplates -->
                                <StackPanel Grid.Column="0">
                                    <!-- Schrittnummer + Step-Inhalt nebeneinander -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   VerticalAlignment="Top"
                                                   Foreground="{DynamicResource MahApps.Brushes.Accent}">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource StepNumberConverter}">
                                                    <Binding/>
                                                    <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <ContentPresenter Grid.Column="2" Content="{Binding}"/>
                                    </Grid>


                                </StackPanel>

                                <!-- Rechts: Buttons identisch zur Makro-Ansicht -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="8,0,0,0">
                                    <!-- Bearbeiten -->
                                    <Button Style="{StaticResource ButtonIcon}"
                                            Margin="0,0,6,0"
                                            ToolTip="Step bearbeiten"
                                            Command="{Binding DataContext.EditStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="Pencil"/>
                                    </Button>
                                    <!-- Nach oben -->
                                    <Button Style="{StaticResource ButtonIcon}"
                                            Margin="0,0,6,0"
                                            ToolTip="Schritt nach oben"
                                            Command="{Binding DataContext.MoveStepUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="ArrowUp"/>
                                    </Button>
                                    <!-- Nach unten -->
                                    <Button Style="{StaticResource ButtonIcon}"
                                            Margin="0,0,6,0"
                                            ToolTip="Schritt nach unten"
                                            Command="{Binding DataContext.MoveStepDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="ArrowDown"/>
                                    </Button>
                                    <!-- Löschen -->
                                    <Button Style="{StaticResource ButtonIconDanger}"
                                            ToolTip="Step löschen"
                                            Command="{Binding DataContext.DeleteStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="Delete"/>
                                    </Button>
                                </StackPanel>
                                </Grid><!-- /inner Grid (content | buttons) -->
                            </Grid><!-- /outer Grid (bar | content) -->
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>
    </Grid>
</UserControl>
