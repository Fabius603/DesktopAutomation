                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                </MultiBinding>
                            </Run.Text>
                        </Run>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                        <TextBlock Text="{loc:Translate Key=Ui.2A335761AAB2}" VerticalAlignment="Center"/>
                        <Border Width="18" Height="18"
                                Background="{Binding Settings.ColorHex}"
                                BorderBrush="{DynamicResource App.Brush.CardBorder}"
