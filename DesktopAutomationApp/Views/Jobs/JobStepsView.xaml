                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.38262E5E41A2}"/><Run Text="{Binding Settings.ConfidenceThreshold, StringFormat=F2}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.7FA9DD08AA11}"/><Run Text="{Binding Settings.MinSize}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
