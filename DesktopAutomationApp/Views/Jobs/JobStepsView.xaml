                        <Run Text="{loc:Translate Key=Ui.C3155FB48A52}"/><Run Text="{Binding Settings.DelayMs}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- ActiveProcessStep -->
        <DataTemplate DataType="{x:Type jobs:ActiveProcessStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.02025AAAE68D}"/><Run Text="{Binding Settings.ProcessName}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.306CE48C326B}"/><Run Text="{Binding Settings.CacheMs}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- StartProcessStep -->
        <DataTemplate DataType="{x:Type jobs:StartProcessStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.A254BBEC8D3E}"/><Run Text="{Binding Settings.ExecutablePath}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.3326CB784823}"/><Run Text="{Binding Settings.Arguments}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.F4ED7B6FCD39}"/>
                        <Run Text="{Binding Settings.WaitForExit, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- FocusProcessStep -->
        <DataTemplate DataType="{x:Type jobs:FocusProcessStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.A254BBEC8D3E}"/><Run Text="{Binding Settings.ExecutablePath}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.A8711FB9ABFC}"/><Run Text="{Binding Settings.WindowMode}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- ShowTextStep -->
        <DataTemplate DataType="{x:Type jobs:ShowTextStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.21784F40B344}"/><Run Text="{Binding Settings.Text}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.4D63C26749CD}"/><Run Text="{Binding Settings.FontSize}"/>
                        <Run Text="{loc:Translate Key=Ui.5246B589AE29}"/><Run Text="{Binding Settings.FontColor}"/>
                        <Run Text="{loc:Translate Key=Ui.97AE949B3516}"/><Run Text="{Binding Settings.Opacity, StringFormat={}{0:P0}}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.B3B162C81455}"/><Run Text="{Binding Settings.DesktopIndex}"/>
                        <Run Text="{loc:Translate Key=Ui.B56E76FF5BCD}"/><Run Text="{Binding Settings.OffsetX}"/>
                        <Run Text="{loc:Translate Key=Ui.0A07F6594619}"/><Run Text="{Binding Settings.OffsetY}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- ActiveWindowStep -->
        <DataTemplate DataType="{x:Type jobs:ActiveWindowStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.02025AAAE68D}"/><Run Text="{Binding Settings.ProcessName}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- KeyPointMatchingStep -->
        <DataTemplate DataType="{x:Type jobs:KeyPointMatchingStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.93ADA26B51D5}"/>
                        <Run>
                            <Run.Text>
                                <MultiBinding Converter="{StaticResource SourceStepNameConverter}">
                                    <Binding Path="Settings.SourceCaptureStepId"/>
                                    <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                </MultiBinding>
                            </Run.Text>
                        </Run>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.3CD82F1C6B83}"/><Run Text="{Binding Settings.TemplatePath}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.620FA885F4DE}"/><Run Text="{Binding Settings.MinMatchCount}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.1A5BC61D15A9}"/><Run Text="{Binding Settings.LowesRatioThreshold, StringFormat=F2}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.47A9974F5B0F}"/>
                        <Run Text="{Binding Settings.EnableROI, Converter={StaticResource InverseBooleanToContentConverter}, ConverterParameter='Nein,Ja'}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- PointComparisonStep -->
        <DataTemplate DataType="{x:Type jobs:PointComparisonStep}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Grid.Column="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.6184930C0027}"/>
                        <Run Text="{Binding Settings.Mode, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.58211F265E02}"/>
                        <Run Text="{Binding Settings.MatchRequirement, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource ParamText}">
                        <Run Text="{loc:Translate Key=Ui.8A281BB051BC}"/><Run Text="{Binding Settings.Points.Count, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- EndJobStep -->
        <DataTemplate DataType="{x:Type jobs:EndJobStep}">
            <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" Foreground="{DynamicResource App.Brush.Accent}"/>
        </DataTemplate>

        <!-- IfStep -->
        <DataTemplate DataType="{x:Type jobs:IfStep}">
            <StackPanel>
                <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" Foreground="{DynamicResource App.Brush.Accent}"/>
                <ItemsControl ItemsSource="{Binding Settings.Conditions}" Margin="0,4,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource ParamText}"
                                       TextWrapping="Wrap">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource StepConditionDisplayConverter}">
                                        <Binding Mode="OneWay"/>
                                        <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                        <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Style="{StaticResource ParamText}" Margin="0,3,0,0" FontStyle="Italic">
                    <Run Text="{loc:Translate Key=Ui.32EBB1ABCC1C}"/><Run Text="{Binding Settings.MatchMode, Mode=OneWay, Converter={StaticResource ConditionMatchModeConverter}}"/><Run Text="{loc:Translate Key=Ui.BA5EC51D07A4}"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="{loc:Translate Key=Ui.D6EDAD2578E6}"
                            Command="{Binding DataContext.AddElseIfCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource ButtonSecondary}"
                            Padding="8,4" Margin="0,0,6,0" FontSize="11"/>
                    <Button Content="{loc:Translate Key=Ui.D8EB27E75875}"
                            Command="{Binding DataContext.AddElseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource ButtonSecondary}"
                            Padding="8,4" FontSize="11"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- ElseIfStep -->
        <DataTemplate DataType="{x:Type jobs:ElseIfStep}">
            <StackPanel>
                <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" Foreground="{DynamicResource App.Brush.Accent}"/>
                <ItemsControl ItemsSource="{Binding Settings.Conditions}" Margin="0,4,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource ParamText}"
                                       TextWrapping="Wrap">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource StepConditionDisplayConverter}">
                                        <Binding Mode="OneWay"/>
                                        <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                        <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Style="{StaticResource ParamText}" Margin="0,3,0,0" FontStyle="Italic">
                    <Run Text="{loc:Translate Key=Ui.32EBB1ABCC1C}"/><Run Text="{Binding Settings.MatchMode, Mode=OneWay, Converter={StaticResource ConditionMatchModeConverter}}"/><Run Text="{loc:Translate Key=Ui.BA5EC51D07A4}"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="{loc:Translate Key=Ui.D6EDAD2578E6}"
                            Command="{Binding DataContext.AddElseIfCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource ButtonSecondary}"
                            Padding="8,4" Margin="0,0,6,0" FontSize="11"/>
                    <Button Content="{loc:Translate Key=Ui.D8EB27E75875}"
                            Command="{Binding DataContext.AddElseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource ButtonSecondary}"
                            Padding="8,4" FontSize="11"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- ElseStep -->
        <DataTemplate DataType="{x:Type jobs:ElseStep}">
            <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" Foreground="{DynamicResource App.Brush.Accent}"/>
        </DataTemplate>

        <!-- EndIfStep -->
        <DataTemplate DataType="{x:Type jobs:EndIfStep}">
            <TextBlock Text="{Binding Converter={StaticResource StepDisplayNameConverter}}" FontWeight="Bold" Foreground="{DynamicResource App.Brush.Accent}"/>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: Zurück + Titel + Add + Save + Cancel -->
        <DockPanel Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonPrimary}" Command="{Binding StartJobCommand}"
                        Visibility="{Binding IsJobRunning, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                        ToolTip="{loc:Translate Key=Ui.0350F3D0CCA2}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.E4BB9F1ECE9A}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonDanger}" Command="{Binding StopJobCommand}"
                        Visibility="{Binding IsJobRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                        ToolTip="{loc:Translate Key=Ui.19DE6A8914E1}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Stop" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.CAE7D57BC067}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Border Style="{StaticResource ToolbarSeparator}"/>
                <Button Style="{StaticResource ButtonPrimary}" Command="{Binding SaveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.F6B2FF39F540}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding CancelCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Cancel" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.F7FF1178AF20}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Border Style="{StaticResource ToolbarSeparator}"/>
                <Button Style="{StaticResource ButtonPrimary}"
                        Command="{Binding AddStepCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.BCE6416D5166}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ButtonSecondary}"
                        Command="{Binding BackCommand}"
                        Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.548611CE58F7}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}" Margin="0,0,12,0"/>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding RenameCommand}" ToolTip="{loc:Translate Key=Ui.83E07ED1F359}">
                    <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Unterer Bereich: wie Makro-Ansicht (DockPanel + ListBox mit Hover/Selected) -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <DockPanel>

                <!-- ListBox mit Hover-/Selected-Rahmen wie im Makro -->
                <ListBox x:Name="StepsList"
                         ItemsSource="{Binding Steps}"
                         SelectionMode="Extended"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingStackPanel.ScrollUnit="Pixel"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         SelectionChanged="StepsList_SelectionChanged"
                         ItemContainerStyle="{StaticResource StepCardListBoxItemStyle}"
                         behaviors:SimpleReorderDragDrop.MoveCommand="{Binding ReorderStepCommand}">

                    <ListBox.InputBindings>
                        <KeyBinding Key="Delete"              Command="{Binding DeleteSelectedCommand}"/>
                        <KeyBinding Key="C" Modifiers="Ctrl"  Command="{Binding CopyCommand}"/>
                        <KeyBinding Key="V" Modifiers="Ctrl"  Command="{Binding PasteCommand}"/>
                        <KeyBinding Key="Z" Modifiers="Ctrl"  Command="{Binding UndoCommand}"/>
                        <KeyBinding Key="Y" Modifiers="Ctrl"  Command="{Binding RedoCommand}"/>
                    </ListBox.InputBindings>

                    <!-- Inhalt + Aktionsleiste rechts (Edit/Hoch/Runter/Delete exakt wie Makro) -->
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- Outer grid: coloured left bar | content -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Coloured left bar -->
                                <Border Grid.Column="0" CornerRadius="2,0,0,2">
                                    <Border.Background>
                                        <MultiBinding Converter="{StaticResource StepBlockBorderConverter}">
                                            <Binding />
                                            <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                            <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                        </MultiBinding>
                                    </Border.Background>
                                </Border>

                                <!-- Subtle background tint over the whole row -->
                                <Border Grid.Column="1" Grid.ColumnSpan="2">
                                    <Border.Background>
                                        <MultiBinding Converter="{StaticResource StepBlockBorderConverter}" ConverterParameter="background">
                                            <Binding />
                                            <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                            <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                        </MultiBinding>
                                    </Border.Background>
                                </Border>

                                <!-- Inner grid: content | action buttons -->
                                <Grid Grid.Column="1" Grid.ColumnSpan="2" Margin="8,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                <!-- Links: Step-Details via implizite DataTemplates -->
                                <StackPanel Grid.Column="0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <!-- Schrittnummer + Step-Inhalt nebeneinander -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   VerticalAlignment="Top"
                                                   Foreground="{DynamicResource MahApps.Brushes.Accent}">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource StepNumberConverter}">
                                                    <Binding/>
                                                    <Binding Path="DataContext.Steps" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                                    <Binding Path="DataContext.StepsVersion" RelativeSource="{RelativeSource AncestorType=UserControl}" Mode="OneWay"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <ContentPresenter Grid.Column="2" Content="{Binding}"/>
                                    </Grid>


                                </StackPanel>

                                <!-- Rechts: Buttons identisch zur Makro-Ansicht -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="8,0,0,0">
                                    <!-- Aktivieren / Deaktivieren -->
                                    <CheckBox
                                        IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                        Visibility="{Binding CanBeDisabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        ToolTip="{loc:Translate Key=Ui.1EB53A3CD78C}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0"/>
                                    <!-- Bearbeiten -->
                                    <Button Style="{StaticResource ButtonIcon}"
                                            Margin="0,0,6,0"
                                            ToolTip="{loc:Translate Key=Ui.7EF60356A568}"
                                            Command="{Binding DataContext.EditStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="Pencil"/>
                                    </Button>
                                    <!-- Nach oben -->
                                    <Button Style="{StaticResource ButtonIcon}"
                                            Margin="0,0,6,0"
                                            ToolTip="{loc:Translate Key=Ui.A1F3260D6E77}"
                                            Command="{Binding DataContext.MoveStepUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="ArrowUp"/>
                                    </Button>
                                    <!-- Nach unten -->
                                    <Button Style="{StaticResource ButtonIcon}"
                                            Margin="0,0,6,0"
                                            ToolTip="{loc:Translate Key=Ui.85C50F7FB3AD}"
                                            Command="{Binding DataContext.MoveStepDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="ArrowDown"/>
                                    </Button>
                                    <!-- Löschen -->
                                    <Button Style="{StaticResource ButtonIconDanger}"
                                            ToolTip="{loc:Translate Key=Ui.EE13D7722C34}"
                                            Command="{Binding DataContext.DeleteStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="Delete"/>
                                    </Button>
                                </StackPanel>
                                </Grid><!-- /inner Grid (content | buttons) -->
                            </Grid><!-- /outer Grid (bar | content) -->
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>
    </Grid>
</UserControl>
