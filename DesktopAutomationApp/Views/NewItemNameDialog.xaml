<mah:MetroWindow x:Class="DesktopAutomationApp.Views.NewItemNameDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 WindowStartupLocation="CenterOwner"
                 SizeToContent="WidthAndHeight"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 MinWidth="340"
                 Style="{StaticResource DialogWindowStyle}">

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="PromptText"
                   Text="Name:"
                   FontSize="13"
                   Foreground="{DynamicResource App.Brush.TextSecondary}"/>

        <TextBox Grid.Row="2"
                 x:Name="NameBox"
                 MinWidth="280"
                 FontSize="14"
                 Padding="8,6"
                 KeyDown="NameBox_KeyDown"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton"
                    Style="{StaticResource ButtonPrimary}"
                    Click="Ok_Click"
                    IsDefault="True"
                    MinWidth="90">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial x:Name="OkIcon" Kind="Plus" Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="OkText" Text="Erstellen" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource ButtonSecondary}"
                    Click="Cancel_Click"
                    IsCancel="True"
                    Margin="8,0,0,0"
                    MinWidth="80">
                <TextBlock Text="Abbrechen"/>
            </Button>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
