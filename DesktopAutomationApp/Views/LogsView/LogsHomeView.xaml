<UserControl x:Class="DesktopAutomationApp.Views.LogsHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:DesktopAutomationApp.Localization"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Style="{StaticResource ContentViewBase}">
    <StackPanel>
        <DockPanel>
            <Button DockPanel.Dock="Right" Command="{Binding OpenLogFolderCommand}" Style="{StaticResource ButtonSecondary}" ToolTip="{loc:Translate Key=Ui.Common.OpenFolderInExplorer}"><iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14"/></Button>
            <TextBlock Text="{loc:Translate Key=Logs.Title}" Style="{StaticResource PageTitle}"/>
        </DockPanel>
        <TextBlock Text="{loc:Translate Key=Logs.ChooseDescription}" Foreground="{DynamicResource App.Brush.TextMuted}" Margin="0,6,0,22"/>
        <UniformGrid Columns="3">
            <Button Command="{Binding OpenJobLogsCommand}" Style="{StaticResource ButtonSecondary}" Padding="20" Margin="0,0,12,0" HorizontalContentAlignment="Stretch">
                <StackPanel>
                    <iconPacks:PackIconMaterial Kind="PlaylistPlay" Width="30" Height="30" Foreground="{DynamicResource App.Brush.Accent}"/>
                    <TextBlock Text="{loc:Translate Key=Ui.Logs.JobLogs}" Style="{StaticResource Heading2}" Margin="0,16,0,6"/>
                    <TextBlock Text="{loc:Translate Key=Logs.JobDescription}" TextWrapping="Wrap" Foreground="{DynamicResource App.Brush.TextMuted}"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding OpenAutomationLogsCommand}" Style="{StaticResource ButtonSecondary}" Padding="20" Margin="0,0,12,0" HorizontalContentAlignment="Stretch">
                <StackPanel>
                    <iconPacks:PackIconMaterial Kind="CalendarClock" Width="30" Height="30" Foreground="{DynamicResource App.Brush.Accent}"/>
                    <TextBlock Text="{loc:Translate Key=Logs.AutomationLogs}" Style="{StaticResource Heading2}" Margin="0,16,0,6"/>
                    <TextBlock Text="{loc:Translate Key=Logs.AutomationDescription}" TextWrapping="Wrap" Foreground="{DynamicResource App.Brush.TextMuted}"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding OpenApplicationLogsCommand}" Style="{StaticResource ButtonSecondary}" Padding="20" HorizontalContentAlignment="Stretch">
                <StackPanel>
                    <iconPacks:PackIconMaterial Kind="ApplicationBracesOutline" Width="30" Height="30" Foreground="{DynamicResource App.Brush.Accent}"/>
                    <TextBlock Text="{loc:Translate Key=Logs.ApplicationLogs}" Style="{StaticResource Heading2}" Margin="0,16,0,6"/>
                    <TextBlock Text="{loc:Translate Key=Logs.ApplicationDescription}" TextWrapping="Wrap" Foreground="{DynamicResource App.Brush.TextMuted}"/>
                </StackPanel>
            </Button>
        </UniformGrid>
    </StackPanel>
</UserControl>
