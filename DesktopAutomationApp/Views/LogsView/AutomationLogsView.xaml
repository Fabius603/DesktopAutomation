<UserControl x:Class="DesktopAutomationApp.Views.AutomationLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:DesktopAutomationApp.Localization"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Style="{StaticResource ContentViewBase}">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Command="{Binding RefreshCommand}" Style="{StaticResource ButtonSecondary}" Margin="0,0,8,0"><StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,6,0"/><TextBlock Text="{loc:Translate Key=Ui.Common.Refresh}"/></StackPanel></Button>
                <Button Command="{Binding OpenLogFolderCommand}" Style="{StaticResource ButtonSecondary}" ToolTip="{loc:Translate Key=Ui.Common.OpenFolderInExplorer}"><iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14"/></Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal"><Button Command="{Binding BackCommand}" Style="{StaticResource ButtonSecondary}" Margin="0,0,12,0"><StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="ArrowLeft" Width="14" Height="14" Margin="0,0,6,0"/><TextBlock Text="{loc:Translate Key=Ui.Common.Back}"/></StackPanel></Button><TextBlock Text="{loc:Translate Key=Logs.AutomationLogs}" Style="{StaticResource PageTitle}"/></StackPanel>
        </DockPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions><ColumnDefinition Width="320"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Style="{StaticResource CardBorderStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Translate Key=Logs.Automations}" Style="{StaticResource Heading2}" Margin="0,0,0,10"/>
                    <ListBox ItemsSource="{Binding Logs}" SelectedItem="{Binding SelectedLog}" Style="{StaticResource SharedLogListBoxStyle}" ItemContainerStyle="{StaticResource SharedLogSessionItemStyle}">
                        <ListBox.ItemTemplate><DataTemplate><StackPanel Margin="6"><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding LastEntryAt, StringFormat='{}{0:dd.MM.yyyy HH:mm:ss}'}" FontSize="11" Foreground="{DynamicResource App.Brush.TextMuted}" Margin="0,4,0,0"/></StackPanel></DataTemplate></ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" MinWidth="190" Margin="0,0,10,0" mah:TextBoxHelper.Watermark="{loc:Translate Key=Execution.LogSearch}"/>
                        <ComboBox ItemsSource="{Binding AvailableLevels}" SelectedItem="{Binding SelectedMinimumLevel}" MinWidth="140"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource LocalizedEnumConverter}}"/></DataTemplate></ComboBox.ItemTemplate></ComboBox>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Entries}" Style="{StaticResource SharedLogListBoxStyle}" ItemContainerStyle="{StaticResource SharedLogEntryItemStyle}" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate><DataTemplate><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="125"/><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{Binding TimestampText}" FontFamily="Consolas" Foreground="{DynamicResource App.Brush.TextMuted}"/><TextBlock Grid.Column="1" Text="{Binding Level, Converter={StaticResource LocalizedEnumConverter}}" Foreground="{DynamicResource App.Brush.Accent}" FontWeight="SemiBold"/><TextBlock Grid.Row="1" Grid.ColumnSpan="3" Text="{Binding Message}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,3,0,0"/><TextBlock Grid.Row="2" Grid.ColumnSpan="3" Text="{Binding Details}" Foreground="{DynamicResource App.Brush.TextMuted}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/></Grid></DataTemplate></ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
