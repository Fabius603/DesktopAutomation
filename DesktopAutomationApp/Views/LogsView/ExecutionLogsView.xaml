<UserControl xmlns:loc="clr-namespace:DesktopAutomationApp.Localization" x:Class="DesktopAutomationApp.Views.ExecutionLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             Style="{StaticResource ContentViewBase}">
    <UserControl.Resources>
        <Style x:Key="LogListBoxStyle" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="LogSessionItemContainerStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Chrome"
                                Background="{DynamicResource App.Brush.RowOdd}"
                                BorderBrush="{DynamicResource App.Brush.CardBorder}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource App.Brush.SurfaceHover}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource App.Brush.TextMuted}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource App.Brush.AccentSubtle}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogEntryItemContainerStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Chrome"
                                Background="{DynamicResource App.Brush.RowOdd}"
                                BorderBrush="{DynamicResource App.Brush.CardBorder}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource App.Brush.SurfaceHover}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource App.Brush.TextMuted}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource App.Brush.SurfaceHover}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource App.Brush.Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding RefreshCommand}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Translate Key=Ui.Common.Refresh}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding OpenLogFolderCommand}" ToolTip="{loc:Translate Key=Ui.Common.OpenFolderInExplorer}">
                    <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ButtonSecondary}" Command="{Binding BackCommand}" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconMaterial Kind="ArrowLeft" Width="14" Height="14" Margin="0,0,6,0"/><TextBlock Text="{loc:Translate Key=Ui.Common.Back}"/></StackPanel>
                </Button>
                <TextBlock Text="{loc:Translate Key=Ui.Logs.JobLogs}" Style="{StaticResource PageTitle}"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Translate Key=Ui.Logs.Executions}" Style="{StaticResource Heading2}" Margin="0,0,0,10"/>
                    <ListBox ItemsSource="{Binding Sessions}"
                             SelectedItem="{Binding SelectedSession}"
                             Style="{StaticResource LogListBoxStyle}"
                             ItemContainerStyle="{StaticResource LogSessionItemContainerStyle}"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.CanContentScroll="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <DockPanel LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding StatusText}"
                                                   Foreground="{DynamicResource App.Brush.Accent}"
                                                   FontSize="11"
                                                   Margin="8,1,0,0"/>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding StartedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm:ss}'}"
                                               Foreground="{DynamicResource App.Brush.TextMuted}"
                                               FontSize="11"
                                               Margin="0,4,0,0"/>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ExecutionNumberText}" Foreground="{DynamicResource App.Brush.Accent}" FontWeight="SemiBold" FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="{Binding OriginText}" Foreground="{DynamicResource App.Brush.TextMuted}" FontSize="11" Margin="10,0" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DurationText}" Foreground="{DynamicResource App.Brush.TextMuted}" FontFamily="Consolas" FontSize="11"/>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     MinWidth="180"
                                     Margin="0,0,12,0"
                                     mah:TextBoxHelper.Watermark="{loc:Translate Key=Execution.LogSearch}"
                                     ToolTip="{loc:Translate Key=Execution.LogSearch}"/>
                            <TextBlock Text="{loc:Translate Key=Ui.Logs.Level}" VerticalAlignment="Center" Foreground="{DynamicResource App.Brush.TextMuted}" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding AvailableLevels}"
                                      SelectedItem="{Binding SelectedMinimumLevel}"
                                      MinWidth="150">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource LocalizedEnumConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{loc:Translate Key=Ui.Logs.LiveLog}" Style="{StaticResource Heading2}"/>
                            <TextBlock Text="{Binding EntryStatusText}"
                                       Foreground="{DynamicResource App.Brush.TextMuted}"
                                       FontSize="11"
                                       Margin="0,3,0,0"/>
                            <ProgressBar IsIndeterminate="True"
                                         Height="2"
                                         Margin="0,5,0,0"
                                         Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </DockPanel>

                    <ListBox x:Name="LogEntriesList"
                             ItemsSource="{Binding Entries}"
                             SelectedItem="{Binding SelectedEntry}"
                             Style="{StaticResource LogListBoxStyle}"
                             ItemContainerStyle="{StaticResource LogEntryItemContainerStyle}"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.CacheLength="1"
                             ScrollViewer.CanContentScroll="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{Binding TimestampText}"
                                               Foreground="{DynamicResource App.Brush.TextMuted}"
                                               FontFamily="Consolas"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Level, Converter={StaticResource LocalizedEnumConverter}}"
                                               Foreground="{DynamicResource App.Brush.Accent}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2"
                                               Text="{Binding JobStateText}"
                                               Foreground="{DynamicResource App.Brush.Accent}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3"
                                               Text="{Binding StepType}"
                                               Foreground="{DynamicResource App.Brush.TextMuted}"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                                               Text="{Binding Message}"
                                               FontWeight="SemiBold"
                                               Margin="0,2,0,0"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                                               Text="{Binding DisplayDetails}"
                                               Foreground="{DynamicResource App.Brush.TextMuted}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
